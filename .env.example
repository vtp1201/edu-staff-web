# Backend API base URL. Kong gateway on :8000 (ADR 0030) routes by service prefix.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Mock-first local dev (ADR 0014/0024). MUST be unset/false for any production build.
NEXT_PUBLIC_USE_MOCK=true

# Google OAuth client id (ADR 0035). Placeholder shows a graceful "SSO unavailable" state.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id_here

# Realtime SSE upstream (US-E06.2). Unset → mock upstream serves dev frames.
# NOTI_SERVICE_URL=http://localhost:8081
