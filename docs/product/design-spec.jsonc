// EduPortal Design Spec
// Source: design_handoff_eduportal2_1406 (re-baseline 2026-06-14, ADR 0034)
// Reference: open design_src/EduPortal.html in a browser for the live prototype
// Canonical source files: design_src/edu/*.jsx (1406 = current)
{
  "meta": {
    "product": "EduPortal",
    "version": "1.1",
    "fidelity": "high — pixel-accurate, recreate exactly",
    "font": "Plus Jakarta Sans",
    "framework": "Next.js 16 + shadcn/ui + Tailwind CSS v4",
    "rebaselineNote": "Sections login, selectRole, teacherDashboard, principalTeachers, profile regenerated from design_src/edu 1406. Other sections unchanged from v1.0."
  },

  // ─────────────────────────────────────────────
  // LAYOUT SHELL
  // Source: design_src/edu/app.jsx (1406)
  // ─────────────────────────────────────────────
  "layout": {
    "sidebar": {
      "widthExpanded": 260,
      "widthCollapsed": 72,
      "background": "var(--edu-card)",
      "borderRight": "1px solid var(--edu-border)",
      "collapseTransition": "width 0.25s ease",
      "collapseStateStorage": "localStorage",
      "toggleButton": {
        "size": 24,
        "shape": "circle",
        "position": { "right": -12, "top": 18 },
        "shadow": "var(--edu-shadow-toggle)"
      },
      "navItem": {
        "active": {
          "background": "var(--edu-primary) + '12'", // 8% opacity tint
          "textColor": "var(--edu-primary)",
          "fontWeight": 700,
          "accentBar": {
            "width": 3,
            "position": "left",
            "topBottom": "20%",
            "borderRadius": "0 3px 3px 0",
            "color": "var(--edu-primary)"
          }
        },
        "inactive": {
          "background": "transparent",
          "textColor": "var(--edu-text-secondary)",
          "fontWeight": 500,
          "hoverBackground": "var(--edu-bg)"
        }
      },
      // Nav sections per role (from app.jsx getHeaderTitle map — 1406)
      "navMap": {
        "teacher": [
          "dashboard",
          "attendance",
          "classlog",
          "discipline",
          "grades",
          "schedule",
          "students",
          "messaging",
          "notifications",
          "settings",
          "profile"
        ],
        "principal": [
          "dashboard",
          "school-setup",
          "subject-parents",
          "subjects",
          "teachers",
          "classes",
          "roster",
          "timetable",
          "classlog",
          "discipline",
          "reports",
          "calendar",
          "messaging",
          "notifications",
          "settings",
          "profile"
        ],
        "student": [
          "home",
          "courses",
          "assignments",
          "exams",
          "grades",
          "discipline",
          "schedule",
          "resources",
          "messaging",
          "profile"
        ],
        "parent": [
          "children",
          "grades",
          "schedule",
          "messaging",
          "notifications",
          "profile"
        ]
      }
    },
    "header": {
      "height": 64,
      "background": "var(--edu-card)",
      "borderBottom": "1px solid var(--edu-border)",
      "search": {
        "width": 220,
        "background": "var(--edu-bg)",
        "borderRadius": 8,
        "fontSize": 13
      },
      "notificationBell": {
        "size": 38,
        "borderRadius": 10,
        "background": "var(--edu-bg)",
        "badge": {
          "size": 18,
          "background": "var(--edu-error-dark)",
          "color": "var(--edu-error-foreground)",
          "fontSize": 10,
          "fontWeight": 700,
          "offset": { "top": -4, "right": -4 }
        }
      }
    }
  },

  // ─────────────────────────────────────────────
  // SCREENS
  // ─────────────────────────────────────────────
  "screens": {
    "login": {
      // Source: design_src/edu/login.jsx — LoginScreen (1406)
      "route": "/login",
      "layout": "two-column full-viewport",
      "left": {
        "width": "42%",
        // token: bg-edu-primary gradient; hex exact from jsx: pColor (--edu-primary) + CC + #13DEB988
        "background": "linear-gradient(150deg, var(--edu-primary) 0%, var(--edu-primary)CC 55%, var(--edu-success)88 100%)",
        "padding": 52,
        "logo": {
          "iconBox": {
            "size": 76,
            "borderRadius": 22,
            "background": "rgba(255,255,255,0.18)",
            "border": "2px solid rgba(255,255,255,0.28)",
            "backdropFilter": "blur(8px)"
          },
          "icon": "school",
          "iconSize": 38,
          "iconColor": "#fff"
        },
        "brandName": {
          "text": "EduPortal",
          "size": 30,
          "fontWeight": 800,
          "letterSpacing": "-0.02em"
        },
        "tagline": { "size": 14, "opacity": 0.85, "fontWeight": 500 },
        "bullets": {
          "count": 3,
          "items": [
            "Đa vai trò — Giáo viên, Học sinh, Phụ huynh",
            "Đa trường học (multi-tenant)",
            "Theo dõi tiến độ & điểm số theo thời gian thực"
          ],
          "bulletIcon": {
            "size": 20,
            "borderRadius": 6,
            "background": "rgba(255,255,255,0.22)"
          }
        },
        // decorative circles: 3 circles with blur/opacity, positioned absolutely
        "decorativeCircles": [
          { "size": 340, "x": -100, "y": -100, "opacity": 0.07 },
          { "size": 220, "x": 80, "y": 80, "opacity": 0.05 },
          { "size": 170, "x": -50, "y": 320, "opacity": 0.06 }
        ]
      },
      "right": {
        "flex": 1,
        "padding": 48,
        "maxWidth": 400,
        "content": {
          "title": {
            "text": "Đăng nhập",
            "size": 26,
            "fontWeight": 800,
            "color": "var(--edu-text-primary)"
          },
          "subtitle": {
            "text": "Chào mừng đến với EduPortal",
            "size": 13.5,
            "color": "var(--edu-text-muted)"
          },
          // SSO: 2 buttons in 1406 — Google + VNeID (Facebook removed vs original spec)
          "ssoButtons": {
            "count": 2,
            "providers": ["Google", "VNeID"],
            "order": ["google", "vneid"],
            "style": {
              "width": "100%",
              "padding": "11px 20px",
              "border": "1.5px solid var(--edu-border)",
              "borderRadius": 10,
              "background": "var(--edu-card)",
              "fontSize": 13.5,
              "fontWeight": 600,
              "gap": 10
            },
            "gap": 10,
            "hover": {
              "borderColor": "var(--edu-primary)",
              "shadow": "var(--edu-primary)18"
            }
          },
          "divider": {
            "text": "hoặc đăng nhập bằng email",
            "fontSize": 12,
            "color": "var(--edu-text-muted)"
          },
          "emailInput": {
            "icon": "mail",
            "iconSize": 15,
            "iconLeft": 12,
            "padding": "10px 14px 10px 38px",
            "borderRadius": 9,
            "border": "1.5px solid var(--edu-border)",
            "fontSize": 13.5,
            "focusBorderColor": "var(--edu-primary)"
          },
          "passwordInput": {
            "icon": "lock",
            "iconSize": 15,
            "iconLeft": 12,
            "showHideToggle": true,
            "padding": "10px 14px 10px 38px",
            "borderRadius": 9,
            "border": "1.5px solid var(--edu-border)",
            "fontSize": 13.5
          },
          "forgotLink": {
            "align": "right",
            "color": "var(--edu-primary)",
            "fontSize": 12,
            "fontWeight": 600
          },
          "errorBanner": {
            "background": "var(--edu-error-light)",
            "border": "1px solid var(--edu-error)22",
            "borderRadius": 8,
            "icon": "info",
            "fontSize": 12
          },
          "submitButton": {
            "width": "100%",
            "padding": "12px",
            "background": "var(--edu-primary)",
            "disabledBackground": "var(--edu-text-muted)",
            "borderRadius": 10,
            "fontSize": 14,
            "fontWeight": 700,
            "color": "#fff"
          },
          "demoHint": {
            "marginTop": 20,
            "padding": "12px 14px",
            "background": "var(--edu-info-light)",
            "border": "1px solid var(--edu-info)28",
            "borderRadius": 9,
            "titleFontSize": 11.5,
            "titleColor": "var(--edu-info)",
            "titleFontWeight": 700,
            "bodyFontSize": 11,
            "bodyColor": "var(--edu-text-secondary)"
          }
        }
      }
    },

    "selectRole": {
      // Source: design_src/edu/login.jsx — select-role step (1406)
      // Shown after login when account has multiple roles (step='select-role')
      "route": "/select-role",
      "layout": "centered single-column",
      "background": "var(--edu-bg)",
      "maxWidth": 480,
      "padding": "0 24px",
      "header": {
        "logoBox": {
          "size": 60,
          "borderRadius": 16,
          "background": "var(--edu-primary)",
          "icon": "school",
          "iconSize": 28,
          "iconColor": "#fff"
        },
        "eyebrow": {
          "text": "Đăng nhập với tư cách",
          "size": 11,
          "fontWeight": 700,
          "color": "var(--edu-text-muted)",
          "textTransform": "uppercase",
          "letterSpacing": "0.08em"
        },
        "name": {
          "size": 22,
          "fontWeight": 800,
          "color": "var(--edu-text-primary)"
        },
        "roleSummary": { "size": 13, "color": "var(--edu-text-muted)" }
      },
      "roleCard": {
        "display": "flex",
        "padding": "16px 20px",
        "background": "var(--edu-card)",
        "border": "1.5px solid var(--edu-border)",
        "borderRadius": 14,
        "shadow": "0 2px 8px rgba(0,0,0,0.04)",
        "gap": 16,
        "iconBox": {
          "size": 48,
          "borderRadius": 12,
          // background = roleColor + '18' (12% opacity tint)
          "background": "roleColor + '18'"
        },
        "icon": { "size": 22, "strokeWidth": 1.7 },
        "roleName": {
          "size": 15,
          "fontWeight": 800,
          "color": "var(--edu-text-primary)"
        },
        "enumBadge": {
          "fontSize": 10,
          "background": "var(--edu-bg)",
          "color": "var(--edu-text-muted)",
          "border": "1px solid var(--edu-border)",
          "borderRadius": 4,
          "padding": "1px 6px",
          "fontWeight": 700,
          "letterSpacing": "0.05em"
        },
        "tenantName": {
          "size": 12,
          "color": "var(--edu-text-muted)",
          "icon": "school",
          "iconSize": 12
        },
        "tenantCodeBadge": {
          "fontSize": 10,
          "background": "var(--edu-bg)",
          "border": "1px solid var(--edu-border)",
          "borderRadius": 4,
          "padding": "1px 6px",
          "fontWeight": 600,
          "letterSpacing": "0.03em"
        },
        "trailingIcon": "chevronRight",
        "hover": {
          "borderColor": "roleColor",
          "shadow": "roleColor + '22' (13% opacity)",
          "translateY": -1
        }
      },
      // 6 roles defined in ROLE_META (1406 — expanded from original 4)
      "roleMeta": {
        "teacher": {
          "labelVi": "Giáo viên",
          "labelEn": "Teacher",
          "icon": "userCheck",
          "color": "var(--edu-role-teacher)",
          "enum": "TEACHER",
          "appRole": "teacher"
        },
        "admin": {
          "labelVi": "Ban giám hiệu (BGH)",
          "labelEn": "Board of Directors",
          "icon": "school",
          "color": "var(--edu-role-principal)",
          "enum": "ADMIN",
          "appRole": "principal"
        },
        "manager": {
          "labelVi": "Phó Hiệu trưởng / BGH",
          "labelEn": "Vice Principal",
          "icon": "school",
          "color": "var(--edu-role-principal)",
          "enum": "MANAGER",
          "appRole": "principal"
        },
        "staff": {
          "labelVi": "Nhân viên",
          "labelEn": "Staff",
          "icon": "briefcase",
          "color": "var(--edu-purple)",
          "enum": "STAFF",
          "appRole": "teacher"
        },
        "student": {
          "labelVi": "Học sinh",
          "labelEn": "Student",
          "icon": "bookOpen",
          "color": "var(--edu-role-student)",
          "enum": "STUDENT",
          "appRole": "student"
        },
        "parent": {
          "labelVi": "Phụ huynh",
          "labelEn": "Parent",
          "icon": "users",
          "color": "var(--edu-role-parent)",
          "enum": "PARENT",
          "appRole": "parent"
        }
      },
      "backButton": {
        "width": "100%",
        "padding": "10px",
        "border": "1px solid var(--edu-border)",
        "borderRadius": 10,
        "fontSize": 13,
        "fontWeight": 600,
        "color": "var(--edu-text-muted)",
        "icon": "chevronLeft"
      }
    },

    "teacherDashboard": {
      // Source: design_src/edu/teacher.jsx — TeacherDashboardHome (1406)
      "route": "/teacher",
      "layout": "flex column, gap 24",
      "contentMaxWidth": 1200,
      "contentPadding": "28px 32px",
      "statsRow": {
        // 5 StatCards in 1406 (was 4 in original spec — added "Điểm chờ duyệt" card)
        "count": 5,
        "gridTemplateColumns": "repeat(auto-fit, minmax(180px, 1fr))",
        "gap": 16,
        "component": "StatCard",
        "cards": [
          {
            "icon": "users",
            "iconColor": "var(--edu-primary)",
            "labelVi": "Tổng học sinh",
            "labelEn": "Total Students",
            "showTrend": true
          },
          {
            "icon": "clock",
            "iconColor": "var(--edu-success)",
            "labelVi": "Tiết học hôm nay",
            "labelEn": "Classes Today",
            "showTrend": false
          },
          {
            "icon": "clipboard",
            "iconColor": "var(--edu-warning)",
            "labelVi": "Chờ chấm điểm",
            "labelEn": "Pending Grades",
            "showTrend": true
          },
          // "Điểm chờ duyệt" — ADMIN_APPROVAL grade-publish mode only (DRAFT→PUBLISHED→LOCKED)
          {
            "icon": "clock",
            "iconColor": "var(--edu-warning)",
            "labelVi": "Điểm chờ duyệt",
            "labelEn": "Grades Awaiting Approval",
            "showTrend": false,
            "note": "ADMIN_APPROVAL mode"
          },
          {
            "icon": "message",
            "iconColor": "var(--edu-purple)",
            "labelVi": "Tin nhắn mới",
            "labelEn": "New Messages",
            "showTrend": false
          }
        ]
      },
      "bodyGrid": {
        "gridTemplateColumns": "1.4fr 1fr",
        "gap": 20
      },
      "scheduleCard": {
        // Left column — schedule list (not weekly grid — that is TeacherScheduleFull)
        "padding": { "header": "18px 24px 14px", "rows": "12px 24px" },
        "header": {
          "title": {
            "fontSize": 15,
            "fontWeight": 700,
            "color": "var(--edu-text-primary)"
          },
          "dayBadge": { "component": "Badge", "color": "var(--edu-primary)" }
        },
        "row": {
          // Live period marked by a soft success tint on the whole row (no side-stripe).
          "background": {
            "live": "var(--edu-success-light)",
            "default": "transparent"
          },
          "periodCell": {
            "width": 80,
            "periodLabel": {
              "fontSize": 12.5,
              "fontWeight": 800,
              "color": "var(--edu-text-primary)",
              "lineHeight": 1.15
            },
            // period 1–5 = Buổi sáng; period 6–10 = Buổi chiều
            "sessionLabel": { "fontSize": 10, "color": "var(--edu-text-muted)" }
          },
          "subjectCell": {
            "subjectName": {
              "fontSize": 13.5,
              "fontWeight": 700,
              "color": "var(--edu-text-primary)"
            },
            "classRoom": {
              "fontSize": 12,
              "color": "var(--edu-text-muted)",
              "marginTop": 2
            }
          },
          "statusBadge": {
            "done": {
              "color": "var(--edu-text-muted)",
              "background": "var(--edu-bg)",
              "labelVi": "Hoàn thành",
              "labelEn": "Done"
            },
            "live": {
              "color": "var(--edu-success)",
              "background": "var(--edu-success-light)",
              "labelVi": "Đang dạy",
              "labelEn": "Live"
            },
            "upcoming": {
              "color": "var(--edu-warning)",
              "background": "var(--edu-warning-light)",
              "labelVi": "Sắp tới",
              "labelEn": "Upcoming"
            }
          }
        }
      },
      "pendingGradesCard": {
        "padding": { "header": "14px 20px 10px", "rows": "10px 20px" },
        "header": {
          "title": {
            "fontSize": 14,
            "fontWeight": 700,
            "color": "var(--edu-text-primary)"
          },
          "countBadge": { "component": "Badge", "color": "var(--edu-warning)" }
        },
        "row": {
          "avatar": { "size": 30, "color": "var(--edu-primary)" },
          "studentName": {
            "fontSize": 12.5,
            "fontWeight": 600,
            "color": "var(--edu-text-primary)",
            "overflow": "ellipsis"
          },
          "typeClass": { "fontSize": 11, "color": "var(--edu-text-muted)" },
          // CTA button navigates to /teacher/grades
          "ctaButton": {
            "label": "Nhập điểm",
            "route": "grades",
            "background": "var(--edu-primary)",
            "color": "#fff",
            "borderRadius": 6,
            "padding": "5px 11px",
            "fontSize": 11,
            "fontWeight": 700,
            "icon": "penLine",
            "iconSize": 11
          }
        }
      },
      "notificationsCard": {
        "padding": { "header": "14px 20px 10px", "rows": "10px 20px" },
        "header": {
          "title": {
            "fontSize": 14,
            "fontWeight": 700,
            "color": "var(--edu-text-primary)"
          }
        },
        "row": {
          "iconBox": {
            "size": 28,
            "borderRadius": 8,
            "background": "iconColor + '18'"
          },
          "message": {
            "fontSize": 12,
            "color": "var(--edu-text-primary)",
            "lineHeight": 1.4
          },
          "time": {
            "fontSize": 11,
            "color": "var(--edu-text-muted)",
            "marginTop": 2
          }
        }
      }
    },

    "teacherScheduleFull": {
      // Source: design_src/edu/teacher.jsx — TeacherScheduleFull (1406)
      // Weekly timetable grid: Mon–Sat × 5 time slots
      "route": "/teacher/schedule",
      "grid": "5 time slots × 6 days (Mon–Sat)",
      "timeSlots": ["07:00", "08:30", "10:00", "13:00", "14:30"],
      "days": ["Thứ 2", "Thứ 3", "Thứ 4", "Thứ 5", "Thứ 6", "Thứ 7"],
      "header": { "periodColWidth": 70, "fontSize": 11, "fontWeight": 600 },
      "filledCell": {
        "background": "var(--edu-primary) + '15'",
        "border": "1px solid var(--edu-primary) + '30'",
        "borderRadius": 8,
        "padding": "8px 10px",
        "className": {
          "fontSize": 12,
          "fontWeight": 700,
          "color": "var(--edu-primary)"
        },
        "room": {
          "fontSize": 10,
          "color": "var(--edu-text-muted)",
          "marginTop": 1
        },
        "subject": {
          "fontSize": 10,
          "color": "var(--edu-text-muted)",
          "overflow": "ellipsis"
        }
      },
      "conflictCell": {
        // Shown when API flags conflict=true (double-booked period)
        "background": "var(--edu-error-light)",
        "border": "1px solid var(--edu-error) + '55'",
        "className": { "color": "var(--edu-error)" },
        "alertIcon": {
          "name": "alertTriangle",
          "size": 12,
          "color": "var(--edu-error)",
          "position": "absolute top-6 right-6"
        },
        "tooltip": "Xung đột lịch dạy — giáo viên đã có lịch tiết này"
      },
      "emptyCell": {
        "height": 46,
        "borderRadius": 8,
        "background": "var(--edu-bg)",
        "border": "1px dashed var(--edu-border)"
      }
    },

    // ── Grade screens — DR-002 (US-E13.1) — design_src/edu/gradebook.jsx,
    //    grade-entry.jsx, grade-approval.jsx. Reconciled 2026-06-20.
    //    Implementation: src/features/grades/ (fully built).
    //    i18n namespaces: gradeBook · gradeEntry · gradeApproval.

    "gradeBook": {
      // Multi-role read view. Routes vary by role.
      "routes": {
        "teacher": "/teacher/grades",
        "principal": "/principal/grades",
        "admin": "/admin/grade-book",
        "student": "/student/grades",
        "parent": "/parent/grades"
      },
      "designFile": "design_src/edu/gradebook.jsx — GradeBookScreen (role prop)",
      "i18nNamespace": "gradeBook",

      // ── Score / rank colour rules (tokens only — derived from design-system.md)
      "scoreColors": {
        "gte8": "var(--edu-success)",
        "lt5": "var(--edu-error)",
        "default": "var(--edu-text-primary)"
      },
      "rankScale": [
        {
          "id": "xs",
          "label": "Xuất sắc",
          "from": 9.5,
          "to": 10,
          "color": "var(--edu-success)"
        },
        {
          "id": "gi",
          "label": "Giỏi",
          "from": 8.0,
          "to": 9.4,
          "color": "var(--edu-primary)"
        },
        {
          "id": "kh",
          "label": "Khá",
          "from": 6.5,
          "to": 7.9,
          "color": "var(--edu-warning)"
        },
        {
          "id": "tb",
          "label": "Trung bình",
          "from": 5.0,
          "to": 6.4,
          "color": "var(--edu-text-muted)"
        },
        {
          "id": "ye",
          "label": "Yếu",
          "from": 0,
          "to": 4.9,
          "color": "var(--edu-error)"
        }
      ],

      // ── Column header tinting by assessment-component kind
      "columnKindTint": {
        "TX": "var(--edu-primary) + /14 bg, /55 bottom-border",
        "GK": "var(--edu-warning) + /14 bg, /55 bottom-border",
        "CK": "var(--edu-error)   + /14 bg, /55 bottom-border"
      },

      // ── Shared table layout
      "table": {
        "card": { "borderRadius": 12, "padding": 0, "shadow": "shadow-card" },
        "head": {
          "background": "var(--edu-bg)",
          "fontSize": 11,
          "fontWeight": 800,
          "textTransform": "uppercase",
          "letterSpacing": "0.05em"
        },
        "rowAlt": { "background": "#FBFCFE" },
        "rowDraft": { "background": "#FFFBEB" },
        "cell": {
          "padding": "8px 10px",
          "borderBottom": "1px solid var(--edu-border)"
        },
        "avgCol": {
          "background": "var(--edu-bg)",
          "borderLeft": "1px solid var(--edu-border)"
        }
      },

      // ── Role-variant layout differences
      "roleVariants": {
        "teacher": {
          "editable": true,
          "filterBar": "subject dropdown + class dropdown + term dropdown (3-col grid)",
          "stickyActionsBar": {
            "position": "fixed bottom-0",
            "height": 64,
            "items": [
              "enteredCount badge",
              "completeRows count",
              "Export PDF ghost",
              "Export Excel secondary",
              "Save All primary"
            ]
          },
          "unsavedIndicator": {
            "position": "title-row right",
            "style": "warning pill with animated dot",
            "background": "var(--edu-warning-light)",
            "color": "var(--edu-warning-foreground)",
            "border": "1px solid var(--edu-warning)/55"
          },
          "summaryPanel": { "collapsible": true, "defaultOpen": true }
        },
        "principal": {
          "editable": false,
          "filterBar": "subject dropdown + class dropdown + term dropdown (3-col grid)",
          "ctaRight": "secondary button → /admin/grades/approval",
          "summaryPanel": { "collapsible": false, "alwaysOpen": true }
        },
        "student": {
          "editable": false,
          "layout": "summary card (GPA + rank + conduct chips) → lock banner (conditional) → subject table",
          "summaryCard": {
            "gpaSize": 32,
            "gpaWeight": 900,
            "iconBox": { "size": 56, "borderRadius": 12 },
            "chips": ["Xếp loại học lực", "Hạnh kiểm"]
          },
          "lockBanner": {
            "trigger": "gradePublishMode === ADMIN_APPROVAL && any subject avg == null",
            "background": "var(--edu-warning-light)",
            "border": "1px solid var(--edu-warning)/44",
            "textColor": "var(--edu-warning-foreground)",
            "icon": "lock"
          },
          "maskedValues": {
            "blurFilter": "blur(5px)",
            "userSelect": "none"
          }
        },
        "parent": {
          // US-E13.7 — Grade Book Parent Child-Switcher (DR-002 enhancement)
          // Source: design_src/edu/gradebook.jsx ChildSwitcher (~line 1081) + VIEWER_DATA_BY_CHILD (~line 367)
          "editable": false,
          "extends": "student",
          "extras": [
            "ChildSwitcher card (minWidth 180) — per-child dataset switch",
            "TermPicker card (minWidth 140) — pill buttons",
            "Contact-teacher strip at bottom → /messaging"
          ],
          "gridTop": "minmax(0,1fr) auto auto (summary | child-switcher | term-picker)",

          // ── ChildSwitcher component spec (US-E13.7) ───────────────────────────────
          "childSwitcher": {
            "route": "/parent/grades",
            "designFile": "design_src/edu/gradebook.jsx — ChildSwitcher component (~line 1081)",
            "i18nNamespace": "gradeBook",
            "visibility": "hidden when childrenList.length === 1 (single-child: renders US-E13.6 ParentView_SingleRow unchanged)",
            "layout": {
              "component": "card — background var(--edu-card), borderRadius 12, border 1px solid var(--edu-border), boxShadow 0 2px 12px rgba(0,0,0,0.04), padding 12, flexDirection column, gap 6, minWidth 180"
            },
            "sectionLabel": {
              "fontSize": 10.5,
              "fontWeight": 800,
              "color": "var(--edu-text-muted)",
              "letterSpacing": "0.08em",
              "textTransform": "uppercase",
              "i18nKey": "gradeBook.childSwitcherLabel"
            },
            "childButton": {
              "layout": "flex row, alignItems center, gap 9, padding 7px 10px, borderRadius 8",
              "active": {
                "border": "1.5px solid child.color",
                "background": "child.color + '14'"
              },
              "inactive": {
                "border": "1.5px solid var(--edu-border)",
                "background": "var(--edu-card)"
              },
              "avatar": {
                "component": "Avatar",
                "size": 26,
                "color": "child.color"
              },
              "name": {
                "fontSize": 12.5,
                "fontWeight": 800,
                "color": "var(--edu-text-primary)",
                "lineHeight": 1.2
              },
              "className": {
                "fontSize": 10.5,
                "color": "var(--edu-text-muted)"
              }
            },
            "a11y": {
              "tablist": "role='tablist' wrapping all child buttons",
              "tab": "role='tab', aria-selected=true/false per active state",
              "tabpanel": "GradeBookTable container gets role='tabpanel'",
              "keyboard": "ArrowLeft / ArrowRight navigate between tabs; Enter/Space selects"
            },
            "states": {
              "loading": "GradeBookSkeleton shown while fetching selected child's data",
              "single child": "ChildSwitcher not rendered; behavior identical to US-E13.6"
            }
          }
        }
      },

      // ── Summary panel (teacher + principal)
      "summaryPanel": {
        "histogram": {
          "barHeight": 18,
          "barRadius": 4,
          "colorByBand": true,
          "emptyBarOpacity": 0.15
        },
        "stats": [
          "TB lớp",
          "Cao nhất (name + value)",
          "Thấp nhất (name + value)"
        ],
        "statBox": {
          "padding": "12px 14px",
          "borderRadius": 10,
          "background": "color + /0F",
          "border": "color + /22"
        }
      },

      // ── States
      "states": {
        "loading": {
          "component": "GradeBookSkeleton (src/features/grades/presentation/grade-book-screen/grade-book-skeleton.tsx)"
        },
        "empty": {
          "icon": "users",
          "iconSize": 36,
          "iconColor": "var(--edu-border)",
          "cta": "Đến Danh sách lớp → /admin/roster"
        },
        "error": {
          "i18nKey": "gradeBook.errorNetworkError | errorNotFound | errorForbidden",
          "retry": true
        },
        "locked": {
          "i18nKey": "gradeBook.tableLockedNotice",
          "cellEdit": "disabled",
          "lockIcon": true
        },
        "unpublished": {
          "i18nKey": "gradeBook.notPublishedBanner",
          "appliesTo": "student + parent",
          "maskValues": true
        }
      },

      // ── Cell states (teacher editable cells)
      "cellStates": {
        "EMPTY": {
          "border": "var(--edu-border)",
          "borderStyle": "solid",
          "placeholder": "—"
        },
        "DRAFT": {
          "background": "#FFFBEB",
          "dotIndicator": {
            "size": 6,
            "color": "var(--edu-warning)",
            "position": "absolute top:-2 right:-2"
          }
        },
        "PUBLISHED": { "background": "var(--edu-bg)", "readOnly": true },
        "LOCKED": {
          "background": "var(--edu-error-light)",
          "border": "var(--edu-error)/22",
          "icon": "lock",
          "readOnly": true
        }
      },

      // ── Responsive notes
      "responsive": {
        "tablet768": "filterBar stacks vertically; table overflowX scroll",
        "mobile375": "filterBar single-column; stickyBar icon-only on small; summaryPanel collapsed"
      }
    },

    "gradeEntry": {
      // Teacher-only screen — /teacher/grades (entry mode via GradeEntryScreen)
      // Also accessible at /teacher/grades/enter per routing.
      "route": "/teacher/grades",
      "roles": ["teacher"],
      "designFile": "design_src/edu/grade-entry.jsx — GradeEntryScreen",
      "i18nNamespace": "gradeEntry",

      "layout": {
        "padding": "28px 32px 110px",
        "maxWidth": 1280,
        "grid": "1fr 280px (table + summary panel)",
        "gap": 18
      },

      // ── Filter bar (4-column grid)
      "filterBar": {
        "columns": ["Lớp", "Môn (theo khối)", "Học kỳ", "Năm học"],
        "grid": "1fr 1fr 0.7fr 0.9fr",
        "required": true,
        "selectStyle": {
          "borderRadius": 8,
          "border": "1.5px solid var(--edu-border)",
          "fontWeight": 700
        }
      },

      // ── Master-info collapsible banner
      "masterInfoBanner": {
        "collapsible": true,
        "defaultOpen": true,
        "background": "var(--edu-bg)",
        "fields": [
          "Số tiết/tuần",
          "Số bài KT yêu cầu",
          "Chỉ tiêu đầu ra",
          "Subject ID",
          "Tên đầy đủ"
        ],
        "badge": "READ-ONLY monospace"
      },

      // ── Locked-row banner (conditional)
      "lockedBanner": {
        "trigger": "lockedCount > 0",
        "background": "var(--edu-error-light)",
        "border": "1px solid var(--edu-error)/33",
        "icon": "lock",
        "iconColor": "var(--edu-error)"
      },

      // ── Grade input cell states
      "cellStates": {
        "EMPTY": {
          "borderStyle": "dashed on hover",
          "placeholder": "—",
          "background": "var(--edu-card)"
        },
        "DRAFT": {
          "background": "var(--edu-card)",
          "dotIndicator": "● top-right 8.5px"
        },
        "PUBLISHED": { "background": "#F5F7FA", "readOnly": true },
        "PENDING_APPROVAL": {
          "background": "var(--edu-warning-light)",
          "textColor": "var(--edu-warning-foreground)",
          "icon": "clock"
        },
        "LOCKED": {
          "background": "#F5F7FA",
          "border": "var(--edu-error)/22",
          "icon": "lock",
          "textColor": "var(--edu-error)"
        }
      },

      // ── Summary panel (right, sticky top:16)
      "summaryPanel": {
        "position": "sticky top:16",
        "width": 280,
        "sections": [
          "Students complete / total",
          "ProgressBar (height 8)",
          "Cells filled count + %",
          "State breakdown (DRAFT/PUBLISHED/PENDING_APPROVAL/LOCKED/EMPTY)"
        ]
      },

      // ── Sticky action bar
      "stickyActionsBar": {
        "position": "fixed bottom-0",
        "height": 64,
        "left": ["students-complete badge", "draft-cells count"],
        "right": [
          "Save draft ghost",
          "Submit grades primary (disabled if no DRAFT cells)"
        ]
      },

      // ── Submit confirm dialog
      "submitDialog": {
        "role": "alertdialog",
        "ariaModal": true,
        "maxWidth": 480,
        "borderRadius": 14,
        "icon": "alertTriangle",
        "iconBg": "var(--edu-warning)/22",
        "stateTransition": "DRAFT → PENDING_APPROVAL",
        "footer": {
          "background": "var(--edu-bg)",
          "buttons": ["Cancel ghost", "Submit primary"]
        }
      },

      // ── States
      "states": {
        "loading": { "i18nKey": "gradeEntry.loading" },
        "noSelection": { "i18nKey": "gradeEntry.noSelection" },
        "emptyClass": { "i18nKey": "gradeEntry.emptyClass" },
        "locked": { "i18nKey": "gradeEntry.tableLockedNotice" },
        "published": { "i18nKey": "gradeEntry.published", "editDisabled": true }
      }
    },

    "gradeApproval": {
      // Principal / admin screen — /admin/grades/approval (+ /principal redirect)
      "route": "/admin/grades/approval",
      "roles": ["admin", "principal"],
      "designFile": "design_src/edu/grade-approval.jsx — GradeApprovalScreen",
      "i18nNamespace": "gradeApproval",

      // ── Filter tabs
      "filterTabs": ["Tất cả", "Chờ duyệt", "Đã công bố", "Đã khóa"],
      "activeTab": {
        "background": "var(--edu-primary)/12",
        "color": "var(--edu-primary)",
        "fontWeight": 800
      },

      // ── Batch list table
      "table": {
        "columns": [
          "Lớp",
          "Môn học",
          "Giáo viên",
          "Học kỳ",
          "Số HS",
          "Trạng thái",
          "Cập nhật",
          "Actions"
        ],
        "rowSelect": "checkbox per row + select-all",
        "ariaLabel": "gradeApproval.tableAriaLabel"
      },

      // ── Batch status badge tones (using design-system StatusBadge pattern)
      "batchStatusBadge": {
        "PENDING_APPROVAL": { "tone": "warning" },
        "PUBLISHED": { "tone": "success" },
        "LOCKED": { "tone": "error" },
        "DRAFT": { "tone": "muted" }
      },

      // ── Bulk-lock toolbar (appears when ≥1 row selected)
      "bulkToolbar": {
        "trigger": "selectedCount > 0",
        "label": "gradeApproval.bulkLockToolbar ({count})",
        "action": "bulk-lock primary-destructive"
      },

      // ── Detail sheet (slide-over)
      "detailSheet": {
        "trigger": "actionView per row",
        "sections": [
          "class/subject/teacher/term header",
          "averageScore",
          "rankDistributionChart",
          "previewTable (student | code | avg | rank)"
        ],
        "actions": ["Approve & Publish primary", "Request Revision ghost"],
        "ariaLabel": "gradeApproval.detailSheet.previewTableAriaLabel"
      },

      // ── Dialogs
      "dialogs": {
        "approveConfirm": { "role": "alertdialog", "maxWidth": 420 },
        "revisionRequest": {
          "role": "dialog",
          "maxWidth": 440,
          "hasTextarea": true,
          "minLength": 10
        },
        "bulkLockConfirm": { "role": "alertdialog", "maxWidth": 420 }
      },

      // ── Grade publish mode warning
      "publishModeWarning": {
        "trigger": "gradePublishMode === AUTO",
        "i18nKey": "gradeApproval.selfPublishModeWarning",
        "tone": "info"
      },

      // ── States
      "states": {
        "loading": { "i18nKey": "gradeApproval.loading" },
        "empty": { "i18nKey": "gradeApproval.emptyState | emptyStateAll" },
        "error": {
          "i18nKey": "gradeApproval.errorNetworkError | errorForbidden | errorUnknown"
        }
      },

      // ── A11y
      "a11y": {
        "checkboxLabel": "gradeApproval.selectBatchLabel ({id})",
        "selectAllLabel": "gradeApproval.selectAllLabel",
        "closeSheet": "gradeApproval.closeSheet",
        "filterGroupLabel": "gradeApproval.filterGroupLabel"
      }
    },

    "schedule": {
      "route": "/teacher/schedule",
      "grid": "Mon–Sat × 5 time slots",
      "filledCell": {
        "background": "primaryColor/15",
        "border": "primaryColor/30"
      },
      "emptyCell": {
        "background": "#F5F7FA",
        "border": "1px dashed #E5EAF2"
      }
    },

    "studentHome": {
      "route": "/student",
      "layout": "stats row + two columns (1.4fr / 1fr)",
      "courseProgress": {
        "colorDot": 8,
        "progressBar": { "height": 5, "borderRadius": 99 }
      }
    },

    "courseDetail": {
      "route": "/student/courses/[id]",
      "headerCard": {
        "background": "course color gradient",
        "textColor": "white",
        "badge": { "background": "white/20", "text": "Đang học" }
      },
      "videoPlaceholder": {
        "background": "#0f1117",
        "aspectRatio": "16:9",
        "playButton": { "size": 60, "background": "white/15", "blur": true }
      },
      "tabs": ["Bài học", "Tài liệu", "Kiểm tra"]
    },

    "assignments": {
      // ── Student Assignments (US-E11.7, DR-020) ─────────────────────────────
      // Source: design_src/edu/assignments.jsx — StudentAssignmentsScreen
      // Role: student only. Mock-first (decision 0014) — lms has no real
      // assignment endpoint yet; submit flow is local state transition
      // (pending → submitted) with a simulated async delay.
      "route": "/student/assignments",
      "role": "student",
      "designFile": "design_src/edu/assignments.jsx",
      "i18nNamespace": "assignments",
      "layout": "single column, maxWidth 900, page header + filter tabs + vertical card list",
      "filters": ["Tất cả", "Chưa nộp", "Đã nộp", "Đã chấm"],

      "pageHeader": {
        "title": "Bài tập",
        "subtitle": "đếm số bài đang chờ nộp (pendingCount) — 0 → 'Không có bài tập nào cần nộp'"
      },

      "filterTabs": {
        "pattern": "pill tab-bar (invitations.jsx TABS / exam.jsx filter) — role='tablist'/'tab'",
        "active": {
          "background": "primaryColor/14 (0x14 alpha)",
          "color": "primaryColor",
          "fontWeight": 800
        },
        "inactive": { "color": "text-secondary", "fontWeight": 600 },
        "container": {
          "background": "card",
          "border": "1px solid border",
          "borderRadius": 10,
          "padding": 4
        },
        "responsive": "horizontal scroll (overflow-x: auto) when tabs overflow container width"
      },

      // ── Card anatomy (Layout 1) ───────────────────────────────────────────
      "card": {
        "background": "card",
        "borderRadius": 12,
        "border": "1px solid border",
        "boxShadow": "0 2px 12px rgba(0,0,0,0.04)",
        "padding": "18px 20px",
        "iconBox": {
          "size": 44,
          "borderRadius": 10,
          "background": "courseColor/18",
          "icon": "fileText (pending) | checkSquare (submitted) | award (graded)"
        },
        "titleRow": {
          "title": "Bài tập: {title}",
          "titleWeight": 800,
          "titleSize": 14.5,
          "badge": "flex-end, same row as title on ≥481px; wraps below title at ≤480px"
        },
        "metaLine": "{subject} · Lớp {class} · GV: {teacher} — 12px text-secondary",
        "dueLine": {
          "icon": "calendar",
          "text": "Hạn nộp: {dueDate}",
          "colorNormal": "text-muted",
          "colorOverdue": "error (bold)"
        },
        "submittedLine": {
          "shownWhen": "status in [submitted, graded]",
          "icon": "check",
          "text": "Đã nộp lúc {submittedAt}",
          "color": "text-muted"
        },
        "scoreChip": {
          "shownWhen": "status === 'graded'",
          "component": "AsgScoreChip — icon award + score/maxScore, color per score mapping"
        },
        "cta": {
          "pending": {
            "label": "Nộp bài",
            "icon": "upload",
            "variant": "primary"
          },
          "submitted": {
            "label": "Xem bài đã nộp",
            "icon": "eye",
            "variant": "secondary"
          },
          "graded": {
            "label": "Xem điểm & nhận xét",
            "icon": "award",
            "variant": "secondary"
          }
        },
        "daysLeftBadge": {
          "lte1day": "error",
          "lte3days": "warning",
          "gt3days": "success",
          "labelPattern": "Còn {n} ngày | Còn 1 ngày | Hạn hôm nay | Quá hạn {n} ngày",
          "icon": "clock (pending) | alertTriangle (overdue/dueToday) — never color-only (decision 0013)"
        },
        "submittedBadge": {
          "label": "Đã nộp",
          "color": "primary",
          "icon": "check"
        },
        "gradedBadge": {
          "label": "Đã chấm",
          "color": "success",
          "icon": "checkSquare"
        },
        "overdue": {
          "borderColor": "error/40",
          "dueLineColor": "error",
          "badge": "Quá hạn {n} ngày (error)"
        }
      },

      // ── Submit sheet anatomy (Layout 2) ───────────────────────────────────
      "submitSheet": {
        "shell": "side sheet — position fixed top/right/bottom, width 520, maxWidth 100vw (full-bleed <520px), scrim rgba(20,30,50,0.45)",
        "pattern": "subjects-dialogs.jsx SubjectDetailSheet shell",
        "a11y": "role='dialog' aria-modal='true' aria-labelledby, focus trap (Tab/Shift+Tab cycle), Escape closes + restores focus to trigger",
        "header": {
          "iconBox": 40,
          "title": "Nộp bài / Bài đã nộp",
          "subtitle": "{subject} · Lớp {class}",
          "closeButton": "icon x, aria-label Đóng"
        },
        "body": {
          "assignmentSummary": "title (read-only) + description (read-only) + due line",
          "fileAttach": {
            "label": "Đính kèm tệp (+ '(không bắt buộc)' when allowFile-optional)",
            "control": "mock file-picker button (paperclip icon, dashed border, minHeight 44) → hidden <input type=file multiple>",
            "attachedList": "filename chip row (fileText icon + name + remove x), background primaryColor/light-tint",
            "validationError": "role='alert', errorText color, e.g. 'Tệp quá lớn (tối đa 20MB)'"
          },
          "contentTextarea": {
            "label": "Nội dung bài làm (không bắt buộc)",
            "rows": 6,
            "border": "1.5px solid border",
            "borderRadius": 9
          },
          "alreadySubmittedView": "read-only card (bg) — submittedAt + fileName, no edit controls"
        },
        "footer": {
          "default": [
            "Lưu nháp (secondary, icon penLine)",
            "Nộp bài (primary, icon send)"
          ],
          "submitting": "primary CTA replaced with spinner (asg-spinner, motion-safe, 0.7s linear) + 'Đang nộp…', disabled",
          "overdueConfirm": {
            "trigger": "clicking Nộp bài when assignment is overdue (pending + daysLeft < 0)",
            "prompt": "Bạn đang nộp trễ hạn, tiếp tục? (icon alertTriangle, errorText color)",
            "actions": [
              "Quay lại (ghost, back to form)",
              "Vẫn nộp bài (danger, confirms submit)"
            ]
          },
          "postSubmit": "card status → submitted, sheet closes, toast confirmation (bottom-center, 3.2s auto-dismiss)"
        }
      },

      // ── Graded feedback anatomy (Layout 3) ────────────────────────────────
      "gradedSheet": {
        "shell": "same side-sheet shell as submitSheet (520/100vw), separate component (GradedSheet) — read-only",
        "a11y": "role='dialog' aria-modal='true' aria-labelledby, Escape closes + restores focus",
        "scoreChip": {
          "icon": "award",
          "layout": "icon + value(20px/800) + '/'+maxScore(13px/600)",
          "color": "score mapping (score≥8 success · <5 error · else text-primary)"
        },
        "teacherComment": {
          "sectionLabel": "Nhận xét của giáo viên — 11.5px/800 uppercase text-muted",
          "block": "background bg, border 1px solid border, borderRadius 10, padding 14px 16px, text 13.5px/1.65"
        },
        "gradedFileLink": {
          "shownWhen": "gradedFileName present",
          "icon": "download",
          "text": "Tải tệp GV đã chấm — {gradedFileName}",
          "color": "primary"
        },
        "timestamps": [
          "Đã nộp lúc {submittedAt} (icon check)",
          "Đã chấm lúc {gradedAt} (icon award)"
        ]
      },

      // ── States (mandatory) ────────────────────────────────────────────────
      "states": {
        "loading": {
          "component": "EduSkeleton",
          "variant": "rows",
          "count": 4
        },
        "empty": {
          "component": "EduEmpty",
          "perTab": {
            "pending": {
              "icon": "checkSquare",
              "color": "success",
              "title": "Không có bài tập nào cần nộp 🎉"
            },
            "submitted": {
              "icon": "inbox",
              "color": "primaryColor",
              "title": "Chưa có bài nộp nào"
            },
            "graded": {
              "icon": "inbox",
              "color": "primaryColor",
              "title": "Chưa có bài nộp nào"
            },
            "all": {
              "icon": "inbox",
              "color": "primaryColor",
              "title": "Chưa có bài tập nào được giao"
            }
          }
        },
        "error": {
          "component": "EduError",
          "trigger": "fetch failure",
          "action": "onRetry — Thử lại button"
        },
        "submitting": {
          "buttonState": "spinner + disabled",
          "inlineError": "mock file-too-large validation message, role='alert'"
        }
      },

      // ── Accessibility notes ───────────────────────────────────────────────
      "a11y": {
        "statusNeverColorOnly": "every badge pairs an icon (clock/alertTriangle/check/checkSquare) with a text label — decision 0013",
        "focusManagement": "sheets trap focus (Tab cycle), Escape closes, focus restored to the triggering element on close",
        "touchTargets": "CTA buttons + file-picker control ≥44px minHeight at <820px viewport (isMobile)",
        "motionSafe": "spinner + sheet-slide-in + toast-in animations gated behind @media (prefers-reduced-motion: reduce) → animation: none",
        "ariaLive": "toast role='status'; validation error role='alert'; overdue confirm prompt uses errorText color + icon (not color-only)",
        "contrast": "overdue due-line + badge text use --edu-error-text (not raw --edu-error) per ADR 0027/0049"
      },

      // ── Responsive ────────────────────────────────────────────────────────
      "responsive": {
        "375": "card stacks full-width (single column, always); title-row wraps to column at ≤480px so badge moves under title instead of inline; meta line wraps to 2 lines naturally (flex-wrap not needed, text wraps); sheet becomes full-bleed (maxWidth 100vw)",
        "768": "1-column list retained (list-first content, unlike courses grid); filter tabs scroll horizontally (overflow-x auto) if they overflow the tab-bar width",
        "1024+": "content maxWidth 900, centered"
      }
    },

    "exams": {
      "route": "/student/exams",
      "subScreens": ["list", "briefing", "taking", "result"],
      "examTaking": {
        "timer": {
          "normal": "success",
          "warning": "warning (< 5min)",
          "critical": "error"
        },
        "questionNavigator": {
          "states": ["answered", "flagged", "current", "blank"]
        },
        "autoSubmitOnTimeout": true
      },
      "result": {
        "hero": "score circle (PASSED / FAILED)",
        "stats": ["correct", "incorrect", "skipped"],
        "reviewFilters": true,

        // ── Mixed-exam / pending-essay variant (US-E11.5) ─────────────────────────
        // Source: design_src/edu/exam.jsx ExamResultScreen isPendingEssay branch (~line 620)
        // Activated when: exam.status === 'submitted_pending_essay'
        "mixedExamPendingEssay": {
          "trigger": "result.status === 'submitted_pending_essay'",
          "designFile": "design_src/edu/exam.jsx — ExamResultScreen isPendingEssay branch (~line 620)",
          "i18nNamespace": "exam",

          "scoreHero": {
            "circle": {
              "value": "partialScore (MCQ score only, e.g. 6.0)",
              "denominator": "/{mcqMax} · 'TN' label",
              "totalScore": "hidden — displayed as '--/10'",
              "i18nKey_label": "exam.result.mcqLabel"
            },
            "badge": {
              "text": "⏱ CHƯA CÓ ĐIỂM TỔNG",
              "i18nKey": "exam.result.partialResultBadge",
              "style": "white text on rgba(255,255,255,0.20) — same hero gradient bg"
            },
            "passFailBadge": "hidden (no pass/fail until essay graded)"
          },

          "pendingEssayBanner": {
            "background": "var(--edu-warning-light)",
            "border": "1px solid var(--edu-warning) + '40'",
            "borderRadius": 12,
            "padding": "14px 18px",
            "icon": {
              "name": "clock",
              "size": 18,
              "color": "var(--edu-warning)",
              "boxSize": 38,
              "boxBg": "var(--edu-warning) + '22'",
              "boxRadius": 10
            },
            "title": {
              "fontSize": 14,
              "fontWeight": 800,
              "color": "var(--edu-warning)",
              "i18nKey": "exam.result.pendingEssayTitle"
            },
            "body": {
              "fontSize": 12.5,
              "color": "var(--edu-text-secondary)",
              "lineHeight": 1.55,
              "i18nKey": "exam.result.pendingEssayBody"
            },
            "a11y": "role='alert' + aria-live='assertive'"
          },

          "statsRow": {
            "mcqCorrect": { "i18nKey": "exam.result.correct" },
            "mcqIncorrect": { "i18nKey": "exam.result.incorrect" },
            "essayCount": {
              "label": "exam.result.essayPending",
              "color": "var(--edu-warning)",
              "icon": "fileText"
            }
          },

          "questionReview": {
            "mcqQuestions": "normal correct/incorrect/skipped display",
            "essayQuestions": {
              "label": {
                "i18nKey": "exam.result.essayQuestionLabel",
                "value": "Câu tự luận — Chờ chấm"
              },
              "answerArea": "shows student's text answer (read-only)",
              "statusIndicator": "warning badge 'Chờ chấm' — no correct/incorrect marker"
            }
          },

          "examListCard": {
            "statusBadge": {
              "color": "warning",
              "bg": "var(--edu-warning-light)",
              "i18nKey": "exam.status.submittedPendingEssay"
            },
            "cta": {
              "text": "exam.cta.viewPendingResult",
              "value": "Xem kết quả tạm thời"
            }
          },

          "briefingMixedIndicator": {
            "badge": {
              "i18nKey": "exam.briefing.mixedType",
              "value": "Bài thi kết hợp",
              "color": "var(--edu-purple)"
            },
            "typeRow": {
              "i18nKey": "exam.briefing.mixedTypeValue",
              "value": "Trắc nghiệm + Tự luận"
            },
            "essayNote": {
              "i18nKey": "exam.briefing.essayGradingNote",
              "value": "Phần tự luận sẽ được giáo viên chấm và cập nhật kết quả sau."
            }
          },

          "takingEssayQuestion": {
            "textarea": {
              "placeholder": {
                "i18nKey": "exam.taking.essayPlaceholder",
                "value": "Nhập câu trả lời của bạn..."
              },
              "maxLength": 2000,
              "charCount": {
                "i18nKey": "exam.taking.essayCharCount",
                "pattern": "{count}/2000 ký tự",
                "a11y": "aria-describedby on textarea"
              }
            },
            "navigatorIcon": "fileText (distinct from MCQ checkCircle)",
            "submitWithEmptyEssay": {
              "allowed": true,
              "warning": {
                "i18nKey": "exam.taking.essayEmptyWarning",
                "value": "Bạn chưa trả lời câu tự luận."
              }
            }
          },

          "filterChip": {
            "id": "submitted_pending_essay",
            "i18nKey": "exam.filter.pendingEssay",
            "value": "Chờ chấm"
          },

          "completedTransition": {
            "trigger": "result.status transitions from 'submitted_pending_essay' → 'completed'",
            "behavior": "score hero shows full total score + PASSED/FAILED badge (E11.1 normal flow)"
          }
        }
      }
    },

    "profile": {
      // Source: design_src/edu/profile.jsx — ProfileScreen (1406)
      "route": "/profile",
      "layout": "two-column grid: 260px left + 1fr right",
      "contentMaxWidth": 1000,
      "contentPadding": "28px 32px",
      "pageTitle": {
        "text": "Hồ sơ cá nhân",
        "size": 22,
        "fontWeight": 800,
        "color": "var(--edu-text-primary)"
      },
      "leftColumn": {
        "width": 260,
        "gap": 16,
        "avatarCard": {
          "background": "var(--edu-card)",
          "borderRadius": 14,
          "border": "1px solid var(--edu-border)",
          "shadow": "var(--edu-shadow-card)",
          "cover": {
            "height": 72,
            "background": "linear-gradient(135deg, roleColor 0%, roleColor + '99' 100%)",
            "decorativeIcon": {
              "name": "school",
              "size": 40,
              "color": "#fff",
              "opacity": 0.2,
              "position": "absolute right-10 bottom-10"
            }
          },
          "avatar": {
            "size": 72,
            "borderRadius": "50%",
            "border": "4px solid var(--edu-card)",
            "background": "roleColor + '25'",
            "fontSize": 24,
            "fontWeight": 800,
            "marginTop": -32,
            "editButton": {
              "size": 22,
              "borderRadius": "50%",
              "background": "roleColor",
              "border": "2px solid var(--edu-card)",
              "icon": "plus",
              "iconSize": 10
            }
          },
          "name": {
            "fontSize": 15,
            "fontWeight": 800,
            "color": "var(--edu-text-primary)",
            "marginBottom": 4
          },
          "roleBadge": { "component": "Badge", "color": "roleColor" },
          "school": { "fontSize": 12, "color": "var(--edu-text-muted)" },
          "infoRows": {
            "padding": "14px 20px",
            "borderTop": "1px solid var(--edu-border)",
            "icons": ["mail", "clock", "calendar"],
            "fontSize": 12,
            "color": "var(--edu-text-secondary)"
          }
        },
        // Account Requests card — NEW in 1406 (deactivation is ADMIN-only)
        "accountRequestsCard": {
          "background": "var(--edu-card)",
          "borderRadius": 14,
          "border": "1px solid var(--edu-border)",
          "shadow": "var(--edu-shadow-card)",
          "padding": 16,
          "label": {
            "text": "Yêu cầu tài khoản",
            "fontSize": 12,
            "fontWeight": 700,
            "color": "var(--edu-text-muted)",
            "textTransform": "uppercase",
            "letterSpacing": "0.06em"
          },
          "body": {
            "fontSize": 11.5,
            "color": "var(--edu-text-muted)",
            "lineHeight": 1.55,
            "marginBottom": 10
          },
          "contactButton": {
            "display": "flex",
            "padding": "8px",
            "border": "1px solid var(--edu-border)",
            "borderRadius": 8,
            "background": "var(--edu-bg)",
            "color": "var(--edu-text-secondary)",
            "fontSize": 12,
            "fontWeight": 700,
            "icon": "mail",
            "iconSize": 13
          }
        }
      },
      "tabs": [
        {
          "id": "info",
          "labelVi": "Thông tin cá nhân",
          "labelEn": "Personal Info",
          "icon": "user"
        },
        {
          "id": "security",
          "labelVi": "Bảo mật & Mật khẩu",
          "labelEn": "Security & Password",
          "icon": "lock"
        },
        {
          "id": "sessions",
          "labelVi": "Phiên đăng nhập",
          "labelEn": "Active Sessions",
          "icon": "eye"
        }
      ],
      "tabBar": {
        "activeTab": {
          "fontWeight": 700,
          "color": "roleColor",
          "borderBottom": "2px solid roleColor"
        },
        "inactiveTab": {
          "fontWeight": 500,
          "color": "var(--edu-text-muted)",
          "borderBottom": "2px solid transparent"
        }
      },
      "infoTab": {
        "grid": "1fr 1fr, gap 18",
        "fullWidthFields": ["fullName"],
        "fields": [
          "fullName",
          "dob",
          "gender",
          "phone",
          "email (disabled)",
          "cccd",
          "address (textarea)",
          "dept (teacher/principal only)",
          "school (disabled)"
        ],
        "genderToggle": {
          "border": "1.5px solid roleColor (active) / var(--edu-border) (inactive)",
          "background": "roleColor + '12' (active) / transparent (inactive)",
          "color": "roleColor (active) / var(--edu-text-secondary) (inactive)"
        },
        "editActions": ["Chỉnh sửa", "Lưu thay đổi", "Huỷ"],
        "successToast": {
          "background": "var(--edu-success-light)",
          "border": "var(--edu-success) + '40'",
          "color": "var(--edu-success)"
        }
      },
      "security": {
        "changePassword": {
          "maxWidth": 440,
          "fields": ["current password", "new password", "confirm password"],
          "passwordStrength": {
            "segments": 4,
            "segmentHeight": 4,
            "borderRadius": 2,
            "levels": [
              { "score": 0, "label": "Rất yếu", "color": "var(--edu-error)" },
              { "score": 1, "label": "Yếu", "color": "var(--edu-error)" },
              {
                "score": 2,
                "label": "Trung bình",
                "color": "var(--edu-warning)"
              },
              { "score": 3, "label": "Mạnh", "color": "var(--edu-success)" },
              { "score": 4, "label": "Rất mạnh", "color": "var(--edu-success)" }
            ]
          },
          "checklist": [
            "Ít nhất 8 ký tự",
            "Có chữ hoa (A–Z)",
            "Có chữ số (0–9)",
            "Có ký tự đặc biệt"
          ],
          "checklistIcon": { "pass": "check", "fail": "x", "size": 12 }
        },
        "twoFactor": {
          "iconBox": {
            "size": 42,
            "borderRadius": 10,
            "background": "var(--edu-warning) + '18'",
            "icon": "lock",
            "iconSize": 20,
            "iconColor": "var(--edu-warning)"
          },
          "title": "Ứng dụng xác thực",
          "subtitle": "Chưa được bật — Google Authenticator, Authy...",
          "ctaButton": "Bật 2FA"
        },
        // Linked Accounts — NEW in 1406 (was absent in original spec)
        "linkedAccounts": {
          "sectionTitle": {
            "text": "Liên kết tài khoản",
            "fontSize": 15,
            "fontWeight": 800,
            "color": "var(--edu-text-primary)"
          },
          "sectionSubtitle": {
            "fontSize": 12,
            "color": "var(--edu-text-muted)"
          },
          "row": {
            "padding": "14px 18px",
            "background": "var(--edu-bg)",
            "borderRadius": 10,
            "border": "1px solid var(--edu-border)",
            "gap": 16,
            "iconBox": {
              "size": 42,
              "borderRadius": 10,
              "background": "#fff",
              "border": "1px solid var(--edu-border)"
            },
            "providerName": {
              "fontSize": 13.5,
              "fontWeight": 700,
              "color": "var(--edu-text-primary)"
            },
            "linkedBadge": {
              "linked": {
                "text": "Đã liên kết",
                "fontSize": 10,
                "fontWeight": 700,
                "background": "var(--edu-success-light)",
                "color": "var(--edu-success)",
                "border": "1px solid var(--edu-success) + '33'",
                "borderRadius": 4,
                "padding": "2px 7px"
              },
              "unlinked": {
                "text": "Chưa liên kết",
                "fontSize": 10,
                "fontWeight": 700,
                "background": "var(--edu-card)",
                "color": "var(--edu-text-muted)",
                "border": "1px solid var(--edu-border)",
                "borderRadius": 4,
                "padding": "2px 7px"
              }
            },
            "desc": {
              "fontSize": 11.5,
              "color": "var(--edu-text-muted)",
              "overflow": "ellipsis"
            },
            "unlinkButton": {
              "padding": "7px 14px",
              "border": "1px solid var(--edu-border)",
              "borderRadius": 8,
              "background": "transparent",
              "color": "var(--edu-text-secondary)",
              "fontSize": 12,
              "fontWeight": 700,
              "labelVi": "Hủy liên kết",
              "labelEn": "Unlink"
            },
            "linkButton": {
              "padding": "7px 14px",
              "border": "none",
              "borderRadius": 8,
              "background": "var(--edu-primary)",
              "color": "#fff",
              "fontSize": 12,
              "fontWeight": 700,
              "labelVi": "Liên kết ngay",
              "labelEn": "Link Now"
            }
          },
          "providers": [
            {
              "key": "vneid",
              "name": "VNeID",
              "descVi": "Định danh điện tử quốc gia",
              "descEn": "Vietnam National e-ID"
            },
            {
              "key": "google",
              "name": "Google",
              "descVi": "email (khi đã liên kết)",
              "descEn": "email (when linked)"
            }
          ]
        }
      },
      "sessions": {
        "padding": 28,
        "row": {
          "padding": "14px 18px",
          "border": "1.5px solid roleColor + '40' (current) / var(--edu-border) (other)",
          "background": "roleColor + '06' (current) / var(--edu-card) (other)",
          "borderRadius": 10,
          "iconBox": {
            "size": 42,
            "borderRadius": 10,
            "background": "(current: roleColor + '14') / (other: textMuted + '14')"
          },
          "deviceName": {
            "fontSize": 13.5,
            "fontWeight": 700,
            "color": "var(--edu-text-primary)"
          },
          "thisDeviceBadge": {
            "component": "Badge",
            "color": "var(--edu-success)",
            "fontSize": 10
          },
          "location": { "fontSize": 11.5, "color": "var(--edu-text-muted)" },
          "logoutButton": {
            "padding": "6px 14px",
            "border": "1px solid var(--edu-error) + '40'",
            "borderRadius": 7,
            "background": "var(--edu-error-light)",
            "color": "var(--edu-error)",
            "fontSize": 12,
            "fontWeight": 700
          }
        },
        "bulkLogout": {
          "marginTop": 16,
          "padding": "10px 20px",
          "border": "1px solid var(--edu-error) + '40'",
          "borderRadius": 9,
          "background": "var(--edu-error-light)",
          "color": "var(--edu-error)",
          "fontSize": 13,
          "fontWeight": 700
        },
        "thisDeviceBadge": "success",
        "perSessionLogout": true
      },

      // ── DR-016 Email verification (P5) — extends this EXISTING profile screen ──
      // Source: design_src/edu/email-verify.jsx — EmailVerifyBanner / EVEmailField / EmailVerifyDialog.
      // NOT a new screen: augments profile.infoTab email row + adds an app-shell
      // banner (rendered by app.jsx, above content, below header — all routes).
      "emailVerify": {
        "us": "US-E01.x (planned)",
        "source": "design_src/edu/email-verify.jsx",
        // 1. App-shell banner — shown on every route when email unverified
        "banner": {
          "component": "EmailVerifyBanner",
          "position": "below header (T.headerHeight), above route content",
          "role": "status",
          "padding": "9px 24px",
          "background": "var(--edu-warning) + '1A'",
          "borderBottom": "1px solid var(--edu-warning) + '55'",
          "textColor": "var(--edu-warning-foreground)",
          "iconBox": {
            "size": 28,
            "borderRadius": 8,
            "background": "var(--edu-warning) + '26'",
            "icon": "mail"
          },
          "badgeDot": {
            "size": 11,
            "background": "var(--edu-warning)",
            "text": "!"
          },
          "dismissButton": {
            "size": 26,
            "borderRadius": 7,
            "icon": "x",
            "sessionOnly": true
          },
          "states": {
            "default": {
              "text": "Email của bạn chưa được xác thực. Xác thực để nhận thông báo quan trọng.",
              "cta": "Gửi mail xác thực (ghost, inline)"
            },
            "sent": {
              "text": "Đã gửi. Kiểm tra hộp thư <email>.",
              "resendLink": "cooldown 60s, aria-live polite countdown, then 'Gửi lại' link"
            }
          },
          "animation": "ev-banner-in 0.2s ease-out (opacity + translateY(-6px)→0); respects prefers-reduced-motion via global rule"
        },
        // 2. profile.infoTab email row — augments the existing "email (disabled)" field
        //    listed in profile.infoTab.fields above with a status badge + inline CTA.
        "profileEmailField": {
          "component": "EVEmailField",
          "context": "profile.infoTab, email field (disabled input) — ADD status badge, do not remove existing disabled-input spec",
          "badge": {
            "verified": {
              "text": "Đã xác thực",
              "color": "var(--edu-teal)",
              "icon": "check"
            },
            "unverified": {
              "text": "Chưa xác thực",
              "color": "var(--edu-warning-text)",
              "background": "var(--edu-warning-light)",
              "icon": "alertTriangle"
            }
          },
          "verifyNowLink": {
            "fontSize": 11.5,
            "fontWeight": 800,
            "color": "var(--edu-primary)",
            "icon": "userCheck",
            "shownWhen": "!verified"
          }
        },
        // 3. OTP dialog
        "dialog": {
          "component": "EmailVerifyDialog",
          "maxWidth": 420,
          "otpInput": {
            "cells": 6,
            "cellSize": "46x52",
            "borderRadius": 10,
            "fontSize": 20,
            "fontWeight": 800,
            "a11y": "each cell aria-label 'Chữ số thứ N'; group role=group aria-label 'Mã xác thực 6 chữ số'; autoComplete one-time-code on first cell",
            "errorState": {
              "border": "1.5px solid var(--edu-error-dark)",
              "background": "var(--edu-error-dark-light) + '55'",
              "textColor": "var(--edu-error-text)",
              "messages": {
                "wrong": "Mã không đúng. Vui lòng kiểm tra lại email và nhập lại.",
                "expired": "Mã đã hết hạn. Bấm \"Gửi lại mã\" để nhận mã mới."
              }
            },
            "resendCooldown": "60s, aria-live polite"
          },
          "successState": {
            "iconCircle": {
              "size": 72,
              "background": "var(--edu-teal-light)",
              "icon": "check",
              "iconColor": "var(--edu-teal)"
            },
            "title": "Email đã được xác thực",
            "cta": "Hoàn tất"
          }
        },
        "a11y": [
          "banner role=status (not alert — non-urgent, matches accessibility.md)",
          "OTP cells 1-digit-1-input with per-digit aria-label; error text uses --edu-error-text (never plain destructive bg color)",
          "cooldown countdown announced via aria-live=polite, not color-only"
        ],
        "tokensNote": "warning banner text uses var(--edu-warning-foreground) on warning bg — never white (WCAG, decision 0013)"
      }
    },

    // US-E08.5 implementation anchors — discrete screen-anchor entries for the
    // two components shipped in the profile screen (cross-ref profile.security
    // .linkedAccounts and profile.leftColumn.accountRequestsCard above).
    "#profile-linked-accounts": {
      // Source: features/user/presentation/profile/linked-accounts-section.tsx
      "context": "Section inside the profile Security tab (#profile security)",
      "purpose": "Link/unlink third-party identity providers to the account",
      "providers": [
        {
          "key": "vneId",
          "name": "VNeID",
          "descVi": "Định danh điện tử quốc gia"
        },
        { "key": "google", "name": "Google", "descVi": "Tài khoản Google" }
      ],
      "rowStates": {
        "linked": {
          "badge": {
            "text": "Đã liên kết",
            "color": "var(--edu-success-text)",
            "background": "var(--edu-success) + '15'"
          },
          "action": {
            "labelVi": "Hủy liên kết",
            "variant": "outline",
            "minTouchTarget": 44
          }
        },
        "unlinked": {
          "badge": {
            "text": "Chưa liên kết",
            "color": "var(--edu-text-secondary)",
            "background": "var(--edu-card)"
          },
          "action": {
            "labelVi": "Liên kết ngay",
            "variant": "primary",
            "minTouchTarget": 44
          }
        },
        "pending": "spinner + aria-busy; button stays in tab order (aria-disabled, guarded onClick)",
        "error": "role=alert text in var(--edu-error-text), description below the row"
      },
      "behavior": "optimistic toggle via TanStack Query setQueryData; rollback to previous on failure; mock-first write (no HTTP service yet)",
      "a11y": "provider-specific aria-label on action buttons; provider icon decorative (aria-hidden, has adjacent text); contrast tokens *-text variants"
    },
    "#profile-account-requests": {
      // Source: features/user/presentation/profile/account-requests-card.tsx
      "context": "Card in the profile left sidebar column",
      "purpose": "Informational — account deactivation/deletion is admin-only",
      "padding": 16,
      "borderRadius": 14,
      "title": {
        "text": "Yêu cầu tài khoản",
        // INTENTIONAL a11y override (US-E08.5, DEF-03): AC-2 / legacy entry
        // accountRequestsCard.label.color (line ~835) says --edu-text-muted, but
        // muted (#8898A9) fails WCAG 1.4.3 (2.95:1 on white). The a11y auditor
        // chose --edu-text-primary (text-foreground) as the AA-safe value.
        // Accessibility rule wins over design prose — this is the source of truth.
        "color": "var(--edu-text-primary)",
        "textTransform": "uppercase"
      },
      "body": { "color": "var(--edu-text-secondary)", "fontSize": 11.5 },
      "contactButton": {
        "type": "mailto link",
        "minTouchTarget": 44,
        "color": "var(--edu-text-secondary)",
        "icon": "mail"
      },
      "behavior": "no write API call (AC-5); single mailto affordance to admin contact"
    },

    "principalTeachers": {
      // Source: design_src/edu/teacher.jsx — PrincipalTeachersScreen + TeacherAssignmentSheet (1406)
      // Route: /principal/teachers (principal section)
      "route": "/principal/teachers",
      "layout": "single column",
      "contentMaxWidth": 1200,
      "contentPadding": "28px 32px",
      "listCard": {
        "background": "var(--edu-card)",
        "borderRadius": 12,
        "border": "1px solid var(--edu-border)",
        "shadow": "var(--edu-shadow-card)",
        "header": {
          "padding": "18px 24px",
          "borderBottom": "1px solid var(--edu-border)",
          "title": {
            "fontSize": 15,
            "fontWeight": 800,
            "color": "var(--edu-text-primary)"
          },
          "subtitle": {
            "fontSize": 12,
            "color": "var(--edu-text-muted)",
            "marginTop": 2
          },
          "countChip": {
            "display": "inline-flex",
            "padding": "6px 12px",
            "background": "var(--edu-bg)",
            "borderRadius": 8,
            "border": "1px solid var(--edu-border)",
            "icon": "userCheck",
            "iconSize": 13,
            "iconColor": "var(--edu-primary)",
            "fontSize": 12,
            "fontWeight": 700
          },
          "addButton": {
            "icon": "plus",
            "label": "Thêm giáo viên",
            "size": "sm"
          }
        },
        "table": {
          "head": {
            "background": "var(--edu-bg)",
            "columns": [
              "Giáo viên",
              "Môn chính",
              "GVCN",
              "Phân công bộ môn",
              "Trạng thái",
              "Actions"
            ],
            "fontSize": 11,
            "fontWeight": 700,
            "color": "var(--edu-text-muted)",
            "textTransform": "uppercase",
            "letterSpacing": "0.06em"
          },
          "row": {
            "padding": "12px 20px",
            "hoverBackground": "var(--edu-bg)",
            "borderTop": "1px solid var(--edu-border)"
          },
          "cells": {
            "teacher": {
              "avatar": { "size": 32, "color": "var(--edu-primary)" },
              "name": {
                "fontSize": 13.5,
                "fontWeight": 700,
                "color": "var(--edu-text-primary)"
              },
              "students": { "fontSize": 11, "color": "var(--edu-text-muted)" }
            },
            "subject": { "fontSize": 13, "color": "var(--edu-text-secondary)" },
            "gvcn": {
              // Assigned homeroom
              "assignedBadge": {
                "display": "inline-flex",
                "alignItems": "center",
                "gap": 5,
                "fontSize": 11,
                "fontWeight": 700,
                "padding": "3px 9px",
                "borderRadius": 4,
                "background": "var(--edu-success) + '15'",
                "color": "var(--edu-success)",
                "border": "1px solid var(--edu-success) + '33'",
                "icon": "users",
                "iconSize": 11
              },
              "unassignedLabel": {
                "fontSize": 12,
                "color": "var(--edu-text-muted)",
                "fontStyle": "italic",
                "text": "Chưa phân công"
              }
            },
            "assignments": {
              "badge": {
                "component": "Badge",
                "color": "var(--edu-primary)",
                "fontSize": 10
              },
              "overflowBadge": {
                "component": "Badge",
                "color": "var(--edu-text-muted)",
                "fontSize": 10
              },
              "emptyLabel": {
                "fontSize": 12,
                "color": "var(--edu-text-muted)",
                "fontStyle": "italic",
                "text": "Chưa có"
              }
            },
            "status": {
              "active": {
                "component": "Badge",
                "color": "var(--edu-success)",
                "labelVi": "Đang dạy",
                "labelEn": "Active"
              },
              "leave": {
                "component": "Badge",
                "color": "var(--edu-warning)",
                "labelVi": "Nghỉ phép",
                "labelEn": "On Leave"
              }
            },
            "actions": {
              "assignButton": {
                "padding": "6px 12px",
                "borderRadius": 7,
                "border": "1.5px solid var(--edu-primary)",
                "background": "transparent",
                "color": "var(--edu-primary)",
                "fontSize": 12,
                "fontWeight": 700,
                "icon": "users",
                "iconSize": 11,
                "labelVi": "Phân công lớp",
                "labelEn": "Assign classes",
                "hover": { "background": "var(--edu-primary) + '12'" }
              },
              "detailButton": {
                "padding": "6px 12px",
                "borderRadius": 7,
                "border": "1px solid var(--edu-border)",
                "background": "transparent",
                "color": "var(--edu-text-secondary)",
                "fontSize": 12,
                "fontWeight": 700,
                "icon": "eye",
                "iconSize": 11,
                "labelVi": "Chi tiết",
                "labelEn": "Details",
                "hover": {
                  "borderColor": "var(--edu-primary)",
                  "color": "var(--edu-primary)"
                }
              }
            }
          }
        }
      },
      "assignmentSheet": {
        // Side sheet (drawer) opened by "Phân công lớp" button
        "width": 480,
        "position": "fixed right-0 top-0 bottom-0",
        "background": "var(--edu-card)",
        "shadow": "-12px 0 40px rgba(0,0,0,0.18)",
        "zIndex": 1001,
        "backdrop": { "background": "rgba(20,30,50,0.45)", "zIndex": 1000 },
        "header": {
          "padding": "20px 24px",
          "borderBottom": "1px solid var(--edu-border)",
          "avatar": { "size": 42, "color": "var(--edu-primary)" },
          "teacherName": {
            "fontSize": 16,
            "fontWeight": 800,
            "color": "var(--edu-text-primary)"
          },
          "subtitle": { "fontSize": 12, "color": "var(--edu-text-muted)" },
          "closeButton": {
            "size": 16,
            "color": "var(--edu-text-muted)",
            "hoverBackground": "var(--edu-bg)"
          },
          "summaryChips": {
            "marginTop": 14,
            "gvcnChip": {
              "fontSize": 11.5,
              "labelColor": "var(--edu-text-secondary)",
              "fontWeight": 700
            },
            "assignCountChip": {
              "fontSize": 11.5,
              "labelColor": "var(--edu-text-secondary)",
              "fontWeight": 700
            }
          }
        },
        "body": {
          "padding": "22px 24px",
          "gvcnSection": {
            "iconBox": {
              "size": 28,
              "borderRadius": 8,
              "background": "var(--edu-success) + '18'",
              "icon": "users",
              "iconSize": 14,
              "iconColor": "var(--edu-success)"
            },
            "title": {
              "fontSize": 13.5,
              "fontWeight": 800,
              "color": "var(--edu-text-primary)"
            },
            "subtitle": { "fontSize": 11, "color": "var(--edu-text-muted)" },
            "select": {
              "width": "100%",
              "padding": "11px 36px 11px 14px",
              "borderRadius": 9,
              "border": "1.5px solid var(--edu-border)",
              "fontSize": 13.5,
              "appearance": "none",
              "trailingIcon": "chevronDown",
              "constraint": "1 teacher = max 1 homeroom class"
            }
          },
          "gvbmSection": {
            "iconBox": {
              "size": 28,
              "borderRadius": 8,
              "background": "var(--edu-primary) + '18'",
              "icon": "bookOpen",
              "iconSize": 14,
              "iconColor": "var(--edu-primary)"
            },
            "title": {
              "fontSize": 13.5,
              "fontWeight": 800,
              "color": "var(--edu-text-primary)"
            },
            "subtitle": { "fontSize": 11, "color": "var(--edu-text-muted)" },
            "emptyState": {
              "padding": "24px 16px",
              "border": "1.5px dashed var(--edu-border)",
              "borderRadius": 10,
              "background": "var(--edu-bg)",
              "icon": "bookOpen",
              "iconSize": 22,
              "title": { "fontSize": 12.5, "fontWeight": 700 },
              "subtitle": { "fontSize": 11.5, "color": "var(--edu-text-muted)" }
            },
            "addRowButton": {
              "border": "1px dashed var(--edu-primary)",
              "background": "var(--edu-primary) + '08'",
              "color": "var(--edu-primary)",
              "borderRadius": 8,
              "fontSize": 12.5,
              "fontWeight": 700,
              "icon": "plus",
              "iconSize": 13,
              "hover": { "background": "var(--edu-primary) + '14'" }
            }
          },
          "assignmentRow": {
            "grid": "1fr 1fr 30px, gap 8",
            "padding": 10,
            "background": "var(--edu-bg)",
            "borderRadius": 10,
            "border": "1px solid var(--edu-border)",
            "classPicker": {
              // Custom dropdown — groups by grade, shows grade badge
              "label": {
                "fontSize": 10,
                "fontWeight": 700,
                "textTransform": "uppercase",
                "letterSpacing": "0.06em"
              },
              "button": {
                "padding": "8px 11px",
                "borderRadius": 8,
                "border": "1.5px solid var(--edu-border)",
                "fontSize": 12.5
              }
            },
            "subjectPicker": {
              // Custom grouped dropdown — subjects greyed out (opacity 0.45) if no ClassSubject row for selected class
              "disabledOpacity": 0.45,
              "disabledCursor": "not-allowed",
              "disabledTooltip": "Chưa có tiết học — thêm môn vào lớp trước.",
              "groupHeader": {
                "fontSize": 10,
                "fontWeight": 700,
                "color": "var(--edu-text-muted)",
                "textTransform": "uppercase",
                "background": "var(--edu-bg)",
                "borderTop": "1px solid var(--edu-border)"
              },
              // Grade mismatch soft warning
              "gradeMismatchWarning": {
                "icon": "alertTriangle",
                "iconSize": 11,
                "color": "var(--edu-warning)",
                "fontSize": 10.5,
                "fontWeight": 600
              }
            },
            "pickerMenu": {
              "position": "absolute top-calc(100%+4px)",
              "background": "#fff",
              "border": "1px solid var(--edu-border)",
              "borderRadius": 9,
              "shadow": "0 8px 24px rgba(0,0,0,0.12)",
              "maxHeight": 240,
              "overflowY": "auto"
            },
            "deleteButton": {
              "size": 30,
              "borderRadius": 7,
              "border": "1px solid var(--edu-border)",
              "background": "transparent",
              "color": "var(--edu-text-muted)",
              "hoverBorder": "var(--edu-error)",
              "hoverColor": "var(--edu-error)",
              "hoverBackground": "var(--edu-error-light)",
              "icon": "x",
              "iconSize": 13
            }
          }
        },
        "footer": {
          "padding": "14px 24px",
          "borderTop": "1px solid var(--edu-border)",
          "background": "var(--edu-bg)",
          "actions": ["Hủy (ghost)", "Lưu phân công (primary, icon check)"]
        }
      }
    },

    "forgotPassword": {
      "route": "/forgot-password",
      "maxWidth": 420,
      "steps": [
        "email input → Gửi mã OTP",
        "6-cell OTP input → Xác nhận",
        "new password + confirm + strength → Đặt lại",
        "success illustration → Quay lại đăng nhập"
      ],
      "otpSlot": {
        "width": 46,
        "height": 52,
        "fontSize": 20,
        "fontWeight": 800,
        "borderRadius": 10
      }
    },

    "messaging": {
      "route": "/messages",
      "layout": "two-pane (convo list + chat window)",
      "features": [
        "Direct / Groups tabs",
        "unread badges",
        "online indicators",
        "typing dots",
        "date dividers"
      ],
      "input": { "enterToSend": true, "attachments": true, "emoji": true },

      // ── DR-008 Group-Chat extension ───────────────────────────────────────────
      // Source: design_src/edu/messaging.jsx — MessagingScreen (DR-008 group-chat extension)
      // DR-008 header references US-E10.1 (base messaging screen); the net-new
      // group-chat feature set below feeds US-E10.4 (planned, not yet built).
      // Realtime / SSE wiring per decision-0009 is omitted from the mock.
      "groupChat": {
        "us": "US-E10.4",
        "source": "design_src/edu/messaging.jsx — MessagingScreen (DR-008 group-chat extension)",

        // ── Group list rows (Groups tab, ConvoItem component) ────────────────
        // Lines 1400–1494 in messaging.jsx
        "groupList": {
          "avatarSize": 42,
          "avatarBorderRadius": 12,
          "avatarBackground": "groupColor + '20'",
          "avatarFontSize": 14,
          "avatarFontWeight": 800,
          // No online-dot on group avatars (online dot only on direct contacts).
          "onlineDot": false,
          "nameMaxWidth": 140,
          "nameFontSize": 13.5,
          "nameFontWeight": "800 (unread) | 600 (read)",
          "nameColor": "var(--edu-text-primary)",
          "timestamp": { "fontSize": 11, "color": "var(--edu-text-muted)" },
          // Last-activity line: "Sender: preview…" with 1-line ellipsis overflow
          "lastActivity": {
            "fontSize": 11.5,
            "senderFontWeight": 700,
            "senderColor": "var(--edu-text-secondary)",
            "previewFontWeight": "700 (unread) | 400 (read)",
            "previewColor": "var(--edu-text-secondary) (unread) | var(--edu-text-muted) (read)",
            "overflow": "single-line ellipsis"
          },
          // Unread badge (group): uses var(--edu-error) not pColor (distinct from direct badge)
          "unreadBadge": {
            "background": "var(--edu-error)",
            "color": "#fff",
            "borderRadius": 99,
            "fontSize": 10,
            "fontWeight": 800,
            "padding": "1px 6px",
            "minWidth": 18
          },
          // Member-count chip below the last-activity line
          "memberCountChip": {
            "display": "inline-flex",
            "padding": "1px 7px",
            "borderRadius": 4,
            "background": "var(--edu-bg)",
            "fontSize": 10,
            "fontWeight": 700,
            "color": "var(--edu-text-muted)",
            "icon": { "name": "users", "size": 9 }
          },
          // Active row highlight (same as direct pane)
          "activeRow": {
            "background": "pColor + '16'"
          },
          // "+ Tạo nhóm" sub-header CTA above list in Groups tab
          "createCTA": {
            "background": "pColor + '08'",
            "backgroundHover": "pColor + '12'",
            "fontSize": 13,
            "fontWeight": 800,
            "color": "pColor",
            "iconBox": {
              "size": 22,
              "borderRadius": 6,
              "background": "pColor",
              "iconColor": "#fff",
              "iconSize": 12
            },
            "borderBottom": "1px solid var(--edu-border)"
          }
        },

        // ── Create-group modal (CreateGroupModal, 2-step) ────────────────────
        // Lines 518–833 in messaging.jsx
        "createGroupModal": {
          "maxWidth": 460,
          "maxHeight": "92vh",
          "borderRadius": 14,
          "background": "var(--edu-card)",
          "boxShadow": "0 24px 60px rgba(0,0,0,0.25)",
          "animation": "msg-fadein 0.18s ease-out (opacity + translateY(-6px)→0)",
          "backdrop": "rgba(20,30,50,0.5) + blur(3px)",
          // Header
          "header": {
            "padding": "18px 22px",
            "iconBox": {
              "size": 38,
              "borderRadius": 10,
              "background": "pColor + '18'",
              "icon": { "name": "users", "size": 18 }
            },
            "titleFontSize": 16,
            "titleFontWeight": 800,
            // Step indicators (StepDot + label inline)
            "stepIndicator": {
              "dotSize": 18,
              "dotBorderRadius": "50%",
              "activeDot": {
                "background": "pColor",
                "border": "1.5px solid pColor",
                "color": "#fff"
              },
              "doneDot": {
                "background": "var(--edu-success)",
                "border": "1.5px solid var(--edu-success)",
                "icon": "check/10px"
              },
              "inactiveDot": {
                "background": "var(--edu-bg)",
                "border": "1.5px solid var(--edu-border)"
              },
              "activeLabelColor": "pColor",
              "activeLabelFontWeight": 800,
              "inactiveLabelColor": "var(--edu-text-muted)",
              "separator": "→ (color: var(--edu-border))"
            }
          },
          "bodyPadding": "18px 22px",
          // Step 1: Group info
          "step1": {
            // Avatar preview
            "avatarPreview": {
              "size": 56,
              "borderRadius": 14,
              "background": "selectedColor + '20'",
              "border": "2px solid selectedColor + '55'",
              "fontSize": 15,
              "fontWeight": 900,
              "initials": "first 2 words initials, max 3 chars"
            },
            // Color picker: 8-swatch row drawn from design tokens
            "colorPicker": {
              "swatchSize": 24,
              "swatchBorderRadius": 7,
              "selectedBorder": "2.5px solid var(--edu-text-primary)",
              "selectedRing": "0 0 0 2px selectedColor",
              "palette": [
                "var(--edu-primary)",
                "var(--edu-success)",
                "var(--edu-warning)",
                "var(--edu-error)",
                "var(--edu-purple)",
                "var(--edu-teal)",
                "#6366F1",
                "#FB923C"
              ]
            },
            // Fields
            "nameField": {
              "label": "Tên nhóm (required)",
              "maxLength": 60,
              "validationMinLength": 2
            },
            "descField": {
              "label": "Mô tả (optional)",
              "rows": 3,
              "maxLength": 140,
              "resize": "vertical"
            },
            // Group type: 2-col radio grid
            "typeSelector": {
              "columns": 2,
              "gap": 8,
              "itemPadding": "10px 12px",
              "itemBorderRadius": 9,
              "activeBorder": "1.5px solid pColor",
              "activeBackground": "pColor + '12'",
              "inactiveBorder": "1.5px solid var(--edu-border)",
              "types": [
                { "id": "class", "vi": "Lớp học", "icon": "users" },
                { "id": "dept", "vi": "Bộ môn", "icon": "briefcase" },
                { "id": "club", "vi": "Câu lạc bộ", "icon": "sparkles" },
                { "id": "other", "vi": "Khác", "icon": "message" }
              ]
            }
          },
          // Step 2: Member search + chips
          "step2": {
            // Selected-member chips
            "chipArea": {
              "padding": "8px 10px",
              "background": "var(--edu-bg)",
              "borderRadius": 8,
              "border": "1px solid var(--edu-border)",
              "chip": {
                "padding": "4px 4px 4px 10px",
                "borderRadius": 99,
                "background": "memberColor + '14'",
                "border": "1px solid memberColor + '33'",
                "miniAvatar": {
                  "size": 18,
                  "background": "memberColor + '22'",
                  "fontSize": 9,
                  "fontWeight": 800
                },
                "labelFontSize": 12,
                "labelFontWeight": 700,
                "labelColor": "memberColor",
                "removeBtnSize": 16
              }
            },
            // Search field
            "searchField": {
              "paddingLeft": 34,
              "icon": {
                "name": "search",
                "size": 13,
                "color": "var(--edu-text-muted)"
              },
              "placeholder": "Tìm theo tên hoặc vai trò…"
            },
            // User list (bordered container)
            "userList": {
              "border": "1px solid var(--edu-border)",
              "borderRadius": 10,
              "row": {
                "padding": "10px 14px",
                "divider": "1px solid var(--edu-border)",
                "checkedBackground": "pColor + '0A'",
                "customCheckbox": {
                  "size": 18,
                  "borderRadius": 5,
                  "checkedBackground": "pColor",
                  "checkedIcon": "check/11px"
                },
                "avatar": {
                  "size": 32,
                  "borderRadius": "50%",
                  "background": "memberColor + '22'",
                  "fontSize": 11,
                  "fontWeight": 800
                },
                "nameFontSize": 13,
                "nameFontWeight": 700,
                "roleFontSize": 11,
                "roleColor": "var(--edu-text-muted)"
              },
              "emptyState": {
                "fontSize": 12.5,
                "color": "var(--edu-text-muted)",
                "text": "Không có người dùng nào khớp."
              }
            },
            "minMembersRequired": 1
          },
          // Footer
          "footer": {
            "padding": "14px 22px",
            "background": "var(--edu-bg)",
            "borderTop": "1px solid var(--edu-border)"
          }
        },

        // ── Group info panel (GroupInfoPanel, 320px slide-in from right) ────
        // Lines 868–1139 in messaging.jsx
        "groupInfoPanel": {
          "width": 320,
          "side": "right",
          "animation": "msg-slide-in 0.22s ease-out (translateX(100%)→0)",
          "backdrop": "rgba(20,30,50,0.35) + blur(2px)",
          "background": "var(--edu-card)",
          "boxShadow": "-12px 0 40px rgba(0,0,0,0.18)",
          // Header
          "header": {
            "padding": "16px 18px",
            "titleFontSize": 14,
            "titleFontWeight": 800,
            // Edit button (admin only, icon-button 28×28)
            "editBtn": {
              "size": 28,
              "borderRadius": 7,
              "adminOnly": true,
              "icon": "penLine/13px"
            }
          },
          // Avatar + name section
          "avatarSection": {
            "padding": "22px 18px",
            "background": "groupColor + '08'",
            "avatar": {
              "size": 80,
              "borderRadius": 20,
              "background": "groupColor + '22'",
              "border": "3px solid groupColor + '33'",
              "fontSize": 22,
              "fontWeight": 900
            },
            // Admin-only avatar-edit badge overlaid on avatar
            "avatarEditBadge": {
              "size": 28,
              "borderRadius": "50%",
              "background": "pColor",
              "border": "3px solid var(--edu-card)",
              "position": "bottom-right -4px -4px",
              "adminOnly": true,
              "icon": "penLine/11px"
            },
            // View mode
            "nameFontSize": 16,
            "nameFontWeight": 800,
            "descFontSize": 12,
            "descColor": "var(--edu-text-muted)",
            // Member count pill
            "memberCountPill": {
              "padding": "3px 9px",
              "borderRadius": 99,
              "background": "var(--edu-bg)",
              "border": "1px solid var(--edu-border)",
              "fontSize": 11,
              "fontWeight": 700,
              "color": "var(--edu-text-secondary)",
              "icon": { "name": "users", "size": 11 }
            },
            // Edit mode: name input + desc textarea, centered, save/cancel buttons
            "editMode": {
              "adminOnly": true,
              "nameInput": {
                "textAlign": "center",
                "fontWeight": 800,
                "fontSize": 16
              },
              "descTextarea": {
                "rows": 2,
                "resize": "vertical",
                "fontSize": 12.5
              }
            }
          },
          // Members section
          "membersSection": {
            "sectionLabelFontSize": 10.5,
            "sectionLabelFontWeight": 800,
            "sectionLabelColor": "var(--edu-text-muted)",
            "sectionLabelUppercase": true,
            // Admin "Thêm" quick-action link (right of section header)
            "addMemberCTA": {
              "adminOnly": true,
              "fontSize": 11.5,
              "fontWeight": 800,
              "color": "pColor"
            },
            "row": {
              "padding": "8px 18px",
              "offlineMemberOpacity": 0.6,
              // Avatar with online dot
              "avatar": {
                "size": 32,
                "borderRadius": "50%",
                "background": "memberColor + '22'",
                "fontSize": 11,
                "fontWeight": 800,
                "offlineFilter": "grayscale(20%)"
              },
              "onlineDot": {
                "size": 9,
                "background": "var(--edu-success)",
                "border": "2px solid var(--edu-card)",
                "position": "bottom-right 0 0"
              },
              "nameFontSize": 12.5,
              "nameFontWeight": 700,
              // "(Bạn)" suffix on self row
              "selfSuffix": {
                "fontSize": 10,
                "color": "var(--edu-text-muted)",
                "fontWeight": 600
              },
              "roleFontSize": 10.5,
              "roleColor": "var(--edu-text-muted)",
              // Admin badge (Badge component: bg error-light, color error)
              "adminBadge": {
                "text": "Admin",
                "background": "var(--edu-error-light)",
                "color": "var(--edu-error)"
              },
              // Remove button (admin only, not shown on self or other admins)
              "removeBtn": {
                "adminOnly": true,
                "hiddenForSelf": true,
                "hiddenForOtherAdmins": true,
                "size": 22,
                "borderRadius": 5,
                "icon": "x/10px/error",
                "hoverBackground": "var(--edu-error-light)",
                "hoverBorderColor": "var(--edu-error)"
              }
            }
          },
          // Pinned messages section
          "pinnedSection": {
            // Empty state
            "emptyState": {
              "padding": "18px 18px",
              "textAlign": "center",
              "fontSize": 12,
              "fontStyle": "italic",
              "color": "var(--edu-text-muted)"
            },
            // Pinned message row (clickable → scroll to message)
            "row": {
              "padding": "10px 18px",
              "iconBox": {
                "size": 22,
                "borderRadius": "50%",
                "background": "var(--edu-warning) + '22'",
                "icon": "star/10px/var(--edu-warning)"
              },
              "senderFontSize": 11,
              "senderFontWeight": 800,
              "senderColor": "var(--edu-text-primary)",
              "timeFontWeight": 600,
              "timeColor": "var(--edu-text-muted)",
              "textFontSize": 12,
              "textColor": "var(--edu-text-secondary)",
              "hoverBackground": "var(--edu-bg)"
            }
          },
          // Footer CTAs
          "footer": {
            "padding": "14px 18px",
            "borderTop": "1px solid var(--edu-border)",
            "leaveBtn": {
              "label": "Rời nhóm",
              "border": "1px solid var(--edu-warning) + '55'",
              "color": "var(--edu-warning)",
              "background": "var(--edu-warning-light)",
              "fullWidth": true
            },
            "deleteBtn": {
              "label": "Xoá nhóm",
              "adminOnly": true,
              "border": "1px solid var(--edu-error) + '55'",
              "color": "var(--edu-error)",
              "background": "var(--edu-error-light)",
              "fullWidth": true
            },
            // Two-step delete confirmation inline
            "deleteConfirm": {
              "warningText": "Xoá nhóm là hành động không thể hoàn tác.",
              "cancelBtn": "ghost",
              "confirmBtn": "danger",
              "confirmLabel": "Xác nhận xoá"
            }
          }
        },

        // ── Message context menu (MessageContextMenu) ────────────────────────
        // Lines 411–476 in messaging.jsx — triggered by right-click / long-press
        "contextMenu": {
          "width": 200,
          "borderRadius": 10,
          "background": "var(--edu-card)",
          "border": "1px solid var(--edu-border)",
          "boxShadow": "0 12px 40px rgba(0,0,0,0.18)",
          "padding": 5,
          "animation": "msg-ctx-in 0.12s ease-out (opacity + translateY(-3px)→0)",
          "closeOnEscape": true,
          "backdropClickDismiss": true,
          // Viewport clamping: position clamped to keep menu within viewport bounds
          "viewportClamp": true,
          // 4 items
          "items": [
            {
              "id": "reply",
              "icon": "arrowLeft",
              "label": "Trả lời",
              "alwaysEnabled": true
            },
            {
              "id": "pin",
              "icon": "star",
              "label": "Ghim tin nhắn",
              // Enabled only for: direct messages (always) OR group messages when selfIsAdmin
              "enabledWhen": "!isGroup || selfIsGroupAdmin",
              "disabledHint": "Chỉ admin mới có thể ghim"
            },
            {
              "id": "copy",
              "icon": "fileText",
              "label": "Sao chép văn bản",
              "alwaysEnabled": true
            },
            {
              "id": "delete",
              "icon": "x",
              "label": "Xóa",
              "danger": true,
              // Only own messages, and only within 1 hour of sending
              "enabledWhen": "isMine && withinOneHour",
              "disabledHint": "Chỉ xoá tin nhắn của bạn | Đã quá 1 giờ",
              // Delete requires confirm dialog before executing
              "requiresConfirm": true
            }
          ],
          // Danger item styling
          "dangerItem": {
            "color": "var(--edu-error)",
            "iconColor": "var(--edu-error)",
            "hoverBackground": "var(--edu-error-light)",
            "borderTopSeparator": "1px solid var(--edu-border)"
          },
          "itemRow": {
            "padding": "8px 10px",
            "borderRadius": 7,
            "gap": 9,
            "fontSize": 13,
            "fontWeight": 600,
            "disabledOpacity": 0.4
          }
        },

        // ── Reply / quote (ReplyStrip + ChatBubble quoted block) ────────────
        // ReplyStrip: lines 480–514; ChatBubble quote: lines 364–389
        "replyQuote": {
          // Strip shown above input while composing a reply
          "replyStrip": {
            "padding": "8px 12px",
            "marginBottom": 8,
            "background": "pColor + '0F'",
            "border": "1px solid pColor + '33'",
            "borderRadius": 9,
            "animation": "msg-reply-in 0.15s ease-out (opacity + translateY(4px)→0)",
            "labelFontSize": 10.5,
            "labelFontWeight": 800,
            "labelColor": "pColor",
            "labelUppercase": true,
            "labelLetterSpacing": "0.04em",
            "previewFontSize": 12,
            "previewColor": "var(--edu-text-secondary)",
            "previewOverflow": "single-line ellipsis",
            "cancelBtn": { "size": 22, "borderRadius": 5, "icon": "x/12px" }
          },
          // Quoted block inside the sent/received bubble
          "quotedBubble": {
            "padding": "6px 10px",
            "marginBottom": 8,
            "marginTop": -2,
            "borderRadius": 8,
            // Own message context: white-ish semi-transparent
            "isMe": {
              "background": "rgba(255,255,255,0.18)",
              "border": "1px solid rgba(255,255,255,0.35)",
              "senderColor": "rgba(255,255,255,0.9)",
              "previewColor": "rgba(255,255,255,0.85)"
            },
            // Others' message context
            "isOther": {
              "background": "var(--edu-bg)",
              "border": "1px solid var(--edu-primary) + '33'",
              "senderColor": "pColor",
              "previewColor": "var(--edu-text-secondary)"
            },
            "senderFontSize": 11,
            "senderFontWeight": 800,
            "previewFontSize": 12,
            "previewFontWeight": 500,
            "previewOverflow": "single-line ellipsis",
            // Clicking the quote scrolls to the original message
            "clickable": true
          }
        },

        // ── Role permissions ─────────────────────────────────────────────────
        // Derived from GROUPS_BY_ROLE seeding + selfIsAdmin logic in MessagingScreen
        "rolePermissions": {
          // All roles can create groups; creator becomes admin automatically
          "createGroup": ["teacher", "principal", "student", "parent"],
          // Group admin = the user who created the group (selfIsAdmin: true in seed)
          // or whoever is flagged admin in GROUP_MEMBERS_BY_GROUP
          "groupAdmin": {
            "description": "Group creator is admin; additional admins can be designated",
            "seedExamples": {
              "teacher": "selfIsAdmin: true on gT2 (homeroom group they own)",
              "principal": "selfIsAdmin: true on gT3 + gA1",
              "student": "selfIsAdmin: false on all seeded groups",
              "parent": "selfIsAdmin: false on all seeded groups"
            }
          },
          // Pin a message: allowed for direct messages (always) and group messages only when selfIsGroupAdmin
          "pinMessage": "!isGroup || selfIsGroupAdmin",
          // Delete a message: only own messages, and only within 1 hour of send time
          "deleteMessage": "isMine && withinOneHour",
          // Remove a member: admin only, cannot remove self or other admins
          "removeMember": "isAdmin && !targetIsSelf && !targetIsAdmin",
          // Edit group name/description/avatar: admin only
          "editGroupInfo": "isAdmin",
          // Delete entire group: admin only (with confirmation step)
          "deleteGroup": "isAdmin"
        },

        // ── States ───────────────────────────────────────────────────────────
        "states": {
          // Empty: user has no groups
          "emptyGroups": {
            "icon": {
              "name": "users",
              "size": 36,
              "color": "var(--edu-border)",
              "strokeWidth": 1.4
            },
            "titleFontSize": 13,
            "titleFontWeight": 700,
            "titleColor": "var(--edu-text-secondary)",
            "subtitleFontSize": 11.5,
            "subtitleColor": "var(--edu-text-muted)",
            // Inline "Tạo nhóm mới" primary button
            "ctaButton": {
              "variant": "primary",
              "icon": "plus",
              "size": "sm",
              "label": "Tạo nhóm mới"
            }
          },
          // Loading: skeleton bubbles shown during chat-pane switch (320ms)
          "loadingSkeletonBubbles": {
            "duration": "320ms",
            "bubbleCount": 5,
            "pattern": [
              "left-220",
              "left-160",
              "right-200",
              "left-240",
              "right-140"
            ],
            "height": 28,
            "borderRadiusLeft": "16px 16px 16px 4px",
            "borderRadiusRight": "16px 16px 4px 16px",
            "animation": "msg-shimmer 1.2s linear infinite (background-position sweep)",
            "shimmerGradient": "linear-gradient(90deg, var(--edu-bg) 0%, #F2F5F9 50%, var(--edu-bg) 100%)",
            "staggerDelay": "0.08s per bubble"
          },
          // Group member offline: row opacity 0.6, avatar grayscale(20%)
          "memberOffline": {
            "rowOpacity": 0.6,
            "avatarFilter": "grayscale(20%)",
            "noOnlineDot": true
          }
        }
      },

      // ── DR-017 Presence indicator (P6) — extends messaging.jsx in place ──────
      // Source: design_src/edu/messaging.jsx — "P6: Presence" block (lines ~40–76),
      // ConvoItem avatar dot (line ~1479), chat header dot + caption (~1684/1697),
      // group-panel member list (~1015–1053). BE: notification service
      // GET /api/v1/presence + SSE /api/v1/stream (decision-0009, mock in this file).
      "presence": {
        "us": "US-E10.6 (implemented)",
        "source": "design_src/edu/messaging.jsx — msgPresence()/MSGPresenceDot()/msgPresenceCaption()",
        // presence value union: 'online' | 'recent' (left <5 min ago) | 'offline'.
        // Contacts without an explicit `presence` field derive it from legacy `online` boolean
        // via msgPresence(c) = c.presence || (c.online ? 'online' : 'offline').
        "presenceValues": ["online", "recent", "offline"],
        // Status dot on avatar — bottom-right, MSGPresenceDot component
        "dot": {
          "size": 10,
          "offset": 1,
          "groupPanelSize": 9,
          "groupPanelOffset": 0,
          "position": "absolute bottom-right of avatar",
          "online": {
            // --edu-success-text, NOT --edu-success: the raw success token is ~1.72:1
            // against card (fails WCAG 1.4.11 non-text contrast); -text variant is 5.24:1.
            "background": "var(--edu-success-text)",
            "border": "none",
            "ring": "0 0 0 2px var(--edu-card)"
          },
          "recent": {
            "background": "var(--edu-card)",
            "border": "2px solid var(--edu-success-text)",
            "ring": "0 0 0 2px var(--edu-card)",
            "note": "hollow ring, not solid — visually distinct from online"
          },
          "offline": {
            "render": "none",
            "note": "no dot at all for offline — NOT a gray dot (reduces visual noise per P6 prompt)"
          },
          "animation": "none — static, no blink/pulse (motion-safe / anti-noise)",
          "a11y": "sr-only text on the dot span: 'đang hoạt động' (online) / 'vừa hoạt động gần đây' (recent) — status not color-only"
        },
        // Applies to: conversation-list avatar (direct only, NOT group avatars),
        // chat header avatar (DM only), group-info-panel member rows.
        "appliesTo": {
          "convoListAvatar": "direct contacts only — group avatars never show a presence dot",
          "chatHeaderAvatar": "DM (1:1) only — group chat header shows member count instead, never per-member presence",
          "groupMemberPanel": "every member row shows its own dot"
        },
        // DM chat-header caption under the contact name (msgPresenceCaption)
        "headerCaption": {
          "fontSize": 12,
          // --edu-text-secondary (5.48:1), NOT --edu-text-muted (2.95:1 — decorative only, ADR 0049)
          "color": "var(--edu-text-secondary)",
          "values": {
            "online": { "vi": "Đang hoạt động", "en": "Active now" },
            "recent": {
              "vi": "Hoạt động {n} phút trước (or contact.lastSeen)",
              "en": "Active {n} minutes ago (or contact.lastSeen)"
            },
            "offline": {
              "vi": "Hoạt động hôm qua (or contact.lastSeen)",
              "en": "Active yesterday (or contact.lastSeen)"
            }
          },
          "note": "full words, no cryptic shorthand (e.g. never just 'online'/'5m')"
        },
        // Group-info-panel members section (GroupInfoPanel.membersSection extension)
        "groupPanel": {
          "onlineCountBanner": {
            "position": "top of members list, before the sorted rows",
            "padding": "7px 18px",
            "background": "var(--edu-bg)",
            "dot": { "size": 7, "background": "var(--edu-success-text)" },
            "label": {
              "fontSize": 11,
              "fontWeight": 800,
              "color": "var(--edu-text-secondary)"
            },
            "text": { "vi": "{n} đang hoạt động", "en": "{n} online now" },
            "count": "members.filter(m => msgPresence(m) !== 'offline').length"
          },
          "sortOrder": "online (rank 2) → recent (rank 1) → offline (rank 0), stable sort by msgPresence(); NOT the old boolean `online` — fixes recent being miscounted as offline",
          "offlineRow": { "opacity": 0.6, "avatarFilter": "grayscale(20%)" }
        },
        "unaffected": [
          "typing indicator (unchanged, out of scope for P6)",
          "SSE 'Trực tuyến/Tin mới' connection pill in chat header (separate feature, unchanged)"
        ]
      }
    },

    // ── Notifications Center — US-E10.2 (DR-006) ─────────────────────────────
    // Source: design_src/edu/notifications.jsx — NotificationsCenterScreen (DR-006)
    // Roles: ALL (teacher, principal, admin, student, parent)
    // Realtime: SSE event `notification.new` per decision-0009 / US-E06.2
    "notifications": {
      "route": "/notifications",
      "roles": ["teacher", "principal", "admin", "student", "parent"],
      "source": "design_src/edu/notifications.jsx — NotificationsCenterScreen",
      "us": "US-E10.2",

      "page": {
        "maxWidth": 920,
        "padding": "28px 32px 40px"
      },

      "breadcrumb": {
        "fontSize": 12.5,
        "color": "var(--edu-text-muted)",
        "activeColor": "var(--edu-text-primary)",
        "fontWeight": 700
      },

      "header": {
        "iconBox": {
          "size": 44,
          "borderRadius": 12,
          "background": "primaryColor + '18'"
        },
        "icon": { "name": "bell", "size": 22, "strokeWidth": 1.8 },
        "unreadBadge": {
          "size": 18,
          "borderRadius": 99,
          "background": "var(--edu-error)",
          "color": "#fff",
          "fontSize": 10.5,
          "fontWeight": 800,
          "border": "2px solid var(--edu-card)",
          "offset": { "top": -4, "right": -4 },
          "maxDisplay": "99+"
        },
        "title": {
          "fontSize": 22,
          "fontWeight": 800,
          "color": "var(--edu-text-primary)"
        },
        "subtitle": {
          "fontSize": 13,
          "fontWeight": 500,
          "color": "var(--edu-text-muted)",
          "allReadColor": "var(--edu-success)",
          "allReadFontWeight": 700
        },
        "markAllReadButton": {
          "padding": "7px 12px",
          "borderRadius": 8,
          "fontSize": 12.5,
          "fontWeight": 800,
          "color": "primaryColor",
          "disabledColor": "var(--edu-text-muted)",
          "disabledOpacity": 0.5,
          "hoverBackground": "primaryColor + '10'",
          "icon": { "name": "check", "size": 12, "strokeWidth": 2.6 }
        }
      },

      "filterPills": {
        "containerBackground": "var(--edu-card)",
        "containerBorderRadius": 12,
        "containerPadding": 8,
        "border": "1px solid var(--edu-border)",
        "shadow": "0 2px 12px rgba(0,0,0,0.04)",
        "gap": 8,
        "pill": {
          "padding": "7px 13px",
          "borderRadius": 8,
          "fontSize": 12.5,
          "fontWeight": { "active": 800, "inactive": 600 },
          "activeBackground": "primaryColor + '14'",
          "activeBorder": "1.5px solid primaryColor",
          "activeColor": "primaryColor",
          "inactiveColor": "var(--edu-text-secondary)",
          "hoverBackground": "var(--edu-bg)"
        },
        "countBadge": {
          "fontSize": 10.5,
          "fontWeight": 800,
          "borderRadius": 99,
          "activeBackground": "primaryColor + '22'",
          "activeColor": "primaryColor",
          "inactiveBackground": "var(--edu-bg)",
          "inactiveColor": "var(--edu-text-muted)"
        },
        "tabs": [
          { "id": "all", "labelVi": "Tất cả", "type": null },
          { "id": "unread", "labelVi": "Chưa đọc", "type": "unread" },
          { "id": "grade", "labelVi": "Điểm số", "type": "grade" },
          { "id": "attendance", "labelVi": "Điểm danh", "type": "attendance" },
          { "id": "discipline", "labelVi": "Kỷ luật", "type": "discipline" },
          {
            "id": "announcement",
            "labelVi": "Thông báo trường",
            "type": "announcement"
          }
        ]
      },

      "notificationTypes": {
        "grade": {
          "icon": "chart",
          "color": "var(--edu-success)",
          "labelVi": "Điểm số"
        },
        "attendance": {
          "icon": "calendar",
          "color": "var(--edu-primary)",
          "labelVi": "Điểm danh"
        },
        "discipline": {
          "icon": "alertTriangle",
          "color": "var(--edu-warning)",
          "labelVi": "Kỷ luật"
        },
        "announcement": {
          "icon": "megaphone",
          "color": "var(--edu-info)",
          "labelVi": "Thông báo trường"
        },
        "system": {
          "icon": "bell",
          "color": "var(--edu-text-muted)",
          "labelVi": "Hệ thống"
        }
      },

      "list": {
        "background": "var(--edu-card)",
        "borderRadius": 12,
        "border": "1px solid var(--edu-border)",
        "shadow": "0 2px 12px rgba(0,0,0,0.04)",
        "overflow": "hidden",
        "marginTop": 16
      },

      "notificationRow": {
        "layout": "grid — 28px icon | flex-1 content | chevron",
        "gap": 14,
        "padding": "14px 20px",
        "unread": {
          "background": "primaryColor + '12'",
          "hoverBackground": "primaryColor + '1C'",
          "titleFontWeight": 800,
          "titleColor": "var(--edu-text-primary)"
        },
        "read": {
          "background": "var(--edu-card)",
          "hoverBackground": "var(--edu-bg)",
          "titleFontWeight": 500,
          "titleColor": "var(--edu-text-secondary)"
        },
        "separator": "1px solid var(--edu-border) (omitted on last row)",
        "animation": "nc-row-in 0.18s ease-out (gated by prefers-reduced-motion)",
        "iconBox": {
          "size": 28,
          "borderRadius": 8,
          "background": "typeColor + '18'"
        },
        "title": { "fontSize": 14, "lineHeight": 1.35 },
        "unreadDot": { "size": 7, "shape": "circle", "color": "primaryColor" },
        "body": {
          "fontSize": 12.5,
          "lineHeight": 1.55,
          "webkitLineClamp": 2,
          "unreadColor": "var(--edu-text-secondary)",
          "readColor": "var(--edu-text-muted)"
        },
        "meta": {
          "gap": 9,
          "timestamp": {
            "fontSize": 11,
            "fontWeight": 700,
            "color": "var(--edu-text-muted)",
            "icon": { "name": "clock", "size": 10, "strokeWidth": 2.2 }
          },
          "typeBadge": "Badge component — canonical bg=color/15, radius full, 11px/600"
        },
        "chevron": {
          "name": "chevronRight",
          "size": 13,
          "color": "var(--edu-text-muted)"
        }
      },

      "loadMore": {
        "padding": "10px 22px",
        "borderRadius": 9,
        "background": "var(--edu-card)",
        "border": "1.5px solid var(--edu-border)",
        "fontSize": 13,
        "fontWeight": 700,
        "hoverBorderColor": "primaryColor",
        "countChip": {
          "fontSize": 11,
          "fontWeight": 800,
          "fontFamily": "ui-monospace",
          "background": "var(--edu-bg)",
          "color": "var(--edu-text-muted)",
          "borderRadius": 4,
          "padding": "2px 8px"
        },
        "pageSize": 8
      },

      "states": {
        "loading": {
          "type": "skeleton rows (3–4)",
          "rowLayout": "28px box | two text lines | spacer",
          "animation": "nc-shimmer shimmer gradient (gated by prefers-reduced-motion)",
          "gradientLight": "#EEF1F6 → #F8FAFC → #EEF1F6",
          "duration": "~420ms simulated"
        },
        "emptyAll": {
          "iconBox": {
            "size": 80,
            "borderRadius": 20,
            "border": "1px dashed var(--edu-border)",
            "background": "var(--edu-bg)"
          },
          "icon": { "name": "bell", "size": 36, "color": "var(--edu-border)" },
          "titleFontSize": 15,
          "titleFontWeight": 700,
          "titleColor": "var(--edu-text-secondary)",
          "padding": "60px 24px"
        },
        "emptyUnread": {
          "icon": {
            "name": "check",
            "size": 36,
            "color": "var(--edu-success)"
          },
          "titleColor": "var(--edu-text-secondary)"
        },
        "allLoaded": {
          "icon": {
            "name": "check",
            "size": 12,
            "color": "var(--edu-success)"
          },
          "fontSize": 12,
          "color": "var(--edu-text-muted)",
          "marginTop": 18
        },
        "error": {
          "layout": "icon + title + retry button",
          "titleFontSize": 14,
          "titleFontWeight": 700,
          "titleColor": "var(--edu-text-secondary)"
        }
      },

      "realtimeSSE": {
        "event": "notification.new",
        "decision": "0009",
        "behavior": "prepend new item to list + show sonner toast",
        "toast": {
          "position": "bottom-right",
          "offset": { "bottom": 28, "right": 28 },
          "borderRadius": 12,
          "border": "1px solid typeColor + '33'",
          "shadow": "0 16px 48px rgba(0,0,0,0.18)",
          "minWidth": 280,
          "maxWidth": 360,
          "autoDismiss": 4500,
          "animation": "nc-toast-in 0.22s ease-out (gated by prefers-reduced-motion)",
          "iconBox": {
            "size": 30,
            "borderRadius": 9,
            "background": "typeColor + '18'"
          },
          "title": { "fontSize": 13, "fontWeight": 700 },
          "body": { "fontSize": 12, "webkitLineClamp": 2 },
          "dismissButton": { "size": "22×22", "borderRadius": 5, "icon": "x" }
        }
      },

      "a11y": {
        "listAriaLabel": "i18n: notifications.listAriaLabel",
        "rowAriaLabel": "i18n: notifications.rowAriaLabel ({title} — {read})",
        "unreadAriaLabel": "i18n: notifications.unreadCountAriaLabel ({count})",
        "markAllReadAriaLabel": "i18n: notifications.markAllReadAriaLabel",
        "animations": "all gated by prefers-reduced-motion: reduce → disabled",
        "skeletonNote": "aria-busy=true on list container while loading",
        "focusRing": "var(--ring) — all interactive elements",
        "colorNote": "status never conveyed by color alone — always icon + label (type badge)"
      },

      "i18nNamespace": "notifications",
      "i18nKeyCount": 30,
      "i18nNote": "All keys exist in src/bootstrap/i18n/messages/{vi,en}.json — zero new keys added (DR-006 reconcile)"
    },

    "discipline": {
      "teacher": "/teacher/discipline",
      "principal": "/principal/discipline",
      "student": "/student/conduct",
      "tabs": ["Violations", "Conduct (Hạnh kiểm)", "Leave Management"],
      "conductThresholds": {
        "Tốt": 90,
        "Khá": 70,
        "TB": 50,
        "Yếu": 0
      },
      "violationStatus": [
        "recorded",
        "notified",
        "parent_notified",
        "resolved"
      ],

      // ── Parent view (US-E09.4) ────────────────────────────────────────────────
      // Source: design_src/edu/discipline.jsx ParentDisciplineScreen (~line 969)
      //         PARENT_CHILDREN_DISCIPLINE mock (~line 939)
      // Route:  /parent/discipline
      "parent": {
        "route": "/parent/discipline",
        "designFile": "design_src/edu/discipline.jsx — ParentDisciplineScreen (~line 969)",
        "i18nNamespace": "discipline.studentConduct",
        "rbac": "parent role only — childId scoped (BE enforce)",
        "layout": {
          "contentPadding": "28px 32px",
          "maxWidth": 1100,
          "grid": "3-column on ≥1024 (childSelector 220px | conductCard 1fr | violations+leave 1fr); single-column on <768"
        },

        "childSelector": {
          "visibility": "hidden when childrenList.length === 1",
          "type": "pill tabs — horizontal scroll on overflow",
          "activeState": {
            "border": "1.5px solid child.color",
            "background": "child.color + '14'"
          },
          "inactiveState": {
            "border": "1.5px solid var(--edu-border)",
            "background": "var(--edu-card)"
          },
          "avatar": {
            "component": "Avatar",
            "size": 30,
            "color": "child.color"
          },
          "a11y": "role='tablist'; each pill role='tab' + aria-selected; tabpanel on content area"
        },

        "conductCard": {
          "background": "var(--edu-card)",
          "borderRadius": 14,
          "border": "1px solid var(--edu-border)",
          "shadow": "0 2px 12px rgba(0,0,0,0.04)",
          "padding": "20px",
          "scoreCircle": {
            "size": 80,
            "borderRadius": "50%",
            "background": "conductColor + '18'",
            "border": "3px solid conductColor + '44'",
            "valueFontSize": 28,
            "valueFontWeight": 800,
            "conductColor": "score>=90→var(--edu-success) | >=70→var(--edu-primary) | >=50→var(--edu-warning) | <50→var(--edu-error)"
          },
          "gradeBadge": {
            "component": "Badge",
            "colorMapping": "Tốt→success | Khá→primary | TB→warning | Yếu→error",
            "a11y": "aria-label includes full grade name + score (not color alone)"
          },
          "childInfo": {
            "fontSize": 13,
            "fontWeight": 600,
            "color": "var(--edu-text-secondary)"
          },
          "gvcnLine": {
            "fontSize": 12,
            "color": "var(--edu-text-muted)",
            "icon": "user"
          }
        },

        "violationHistory": {
          "readOnly": true,
          "noAddButton": "parent role never sees 'Ghi nhận vi phạm' button",
          "emptyState": {
            "icon": "shieldCheck",
            "iconColor": "var(--edu-success)",
            "i18nKey": "discipline.studentConduct.myViolations.empty"
          },
          "listRow": {
            "date": { "fontSize": 12, "color": "var(--edu-text-muted)" },
            "description": {
              "fontSize": 13,
              "fontWeight": 600,
              "color": "var(--edu-text-primary)"
            },
            "severityBadge": {
              "component": "Badge",
              "Nhẹ": "warning",
              "Vừa": "error",
              "Nặng": "destructive"
            },
            "pointDeduction": {
              "fontSize": 12,
              "color": "var(--edu-error)",
              "fontWeight": 700
            }
          }
        },

        "leaveRequestForm": {
          "trigger": "Nộp đơn nghỉ cho con button — opens inline panel (not modal)",
          "fields": [
            {
              "id": "startDate",
              "type": "date",
              "validation": "≥ today",
              "i18nKey": "discipline.studentConduct.leaveRequest.startDate"
            },
            {
              "id": "endDate",
              "type": "date",
              "validation": "≥ startDate",
              "i18nKey": "discipline.studentConduct.leaveRequest.endDate"
            },
            {
              "id": "type",
              "type": "select",
              "options": ["medical", "event", "personal", "other"],
              "i18nKey": "discipline.studentConduct.leaveRequest.type"
            },
            {
              "id": "reason",
              "type": "textarea",
              "minLength": 10,
              "i18nKey": "discipline.studentConduct.leaveRequest.reason"
            }
          ],
          "submitLabel": "discipline.studentConduct.leaveRequest.submit",
          "successToast": "discipline.studentConduct.leaveRequest.success",
          "formReset": "on child switch — half-filled draft does not persist to other child"
        },

        "leaveHistory": {
          "statusBadge": {
            "pending": {
              "color": "warning",
              "i18nKey": "discipline.studentConduct.status.pending"
            },
            "approved": {
              "color": "success",
              "i18nKey": "discipline.studentConduct.status.approved"
            },
            "rejected": {
              "color": "error",
              "i18nKey": "discipline.studentConduct.status.rejected"
            }
          },
          "rejectedReason": {
            "visible": "when status=rejected",
            "i18nKey": "discipline.studentConduct.leaveHistory.rejectionReason"
          },
          "emptyState": {
            "i18nKey": "discipline.studentConduct.leaveHistory.empty"
          }
        },

        "states": {
          "loading": "skeleton — conductCard + violationList + leaveHistory shimmer",
          "error": {
            "retry": true,
            "i18nKey": "discipline.studentConduct.loadError"
          },
          "singleChild": "childSelector hidden; content renders directly for the single child"
        },

        "a11yNotes": [
          "ConductCard score badge: aria-label='Hạnh kiểm {grade}: {score} điểm' (not color alone)",
          "Severity badges: aria-label includes full severity name (Nhẹ/Vừa/Nặng)",
          "Leave form: all inputs have <label> + aria-invalid + aria-describedby on error",
          "Date inputs: touch target ≥ 44×44px",
          "Child selector tabs: role='tablist' + role='tab' + aria-selected"
        ]
      }
    },

    "attendance": {
      "route": "/teacher/attendance",
      "states": ["Có mặt", "Vắng phép", "Vắng KP"],
      "features": [
        "class/date/period selectors",
        "search + filter",
        "summary panel",
        "history tab"
      ]
    },

    // ═════════════════════════════════════════════════════════════════════════
    // GROUP B RECONCILE (DR-012 → DR-019) — 8 screens gen'd via
    // docs/design-requests/PROMPTS-group-b-ui-gen.md (P1–P7 + P8 audit fix pass).
    // BE has these APIs already; web had no UI — reconcile transcribes the
    // already-built + already-audited (P8) design_src/edu/*.jsx into this spec.
    // ═════════════════════════════════════════════════════════════════════════

    // ── Social Feed — DR-012 (US-097→100, social service) ─────────────────────
    // Source: design_src/edu/feed.jsx — FeedScreen
    "feed": {
      "route": "/feed",
      "roles": ["teacher", "principal", "student", "parent"],
      "source": "design_src/edu/feed.jsx — FeedScreen",
      "layout": {
        "columnMaxWidth": 680,
        "columnAlign": "centered",
        "padding": "28px 32px (16px 12px <=640px)",
        "gap": 16
      },
      // Scope tab switcher: "Toàn trường" (globe icon) + "Lớp <tên>" (users icon,
      // dropdown listbox if user belongs to >1 class). role=tablist.
      "scopeTabs": {
        "component": "role=tablist, 2 role=tab buttons",
        "padding": "8px 16px",
        "borderRadius": 99,
        "active": {
          "border": "1.5px solid pColor",
          "background": "pColor + '12'",
          "color": "pColor",
          "fontWeight": 700
        },
        "inactive": {
          "border": "1.5px solid var(--edu-border)",
          "color": "var(--edu-text-secondary)",
          "fontWeight": 600
        },
        "classDropdown": "role=listbox when user has >1 class; single static tab otherwise",
        "mobileScroll": "horizontal scroll, scrollbar hidden (.feed-tabs)"
      },
      // Composer — hidden ENTIRELY (not disabled) for roles without post permission
      // in the active scope: school scope = teacher/principal only; class scope =
      // teacher/principal/student (policy: students may post to their own class feed).
      "composer": {
        "component": "FeedComposer",
        "card": { "padding": 16 },
        "avatarSize": 38,
        "textarea": {
          "rowsCollapsed": 1,
          "rowsExpanded": 3,
          "borderRadius": 10,
          "background": "var(--edu-bg)",
          "focusBorder": "pColor"
        },
        "attachToggle": {
          "icon": "image",
          "activeBackground": "pColor + '12'",
          "activeColor": "pColor"
        },
        "submitButton": {
          "variant": "primary",
          "size": "sm",
          "icon": "send",
          "disabledWhenEmpty": true
        },
        "visibilityRule": "canPost = (scope===school ? role in [teacher,principal] : role in [teacher,principal,student]) — composer NOT rendered at all when false"
      },
      // Post card (FeedPostCard)
      "postCard": {
        "padding": 20,
        "pinnedBorder": "1px solid pColor + '4D'",
        "defaultBorder": "1px solid var(--edu-border)",
        "header": {
          "avatarSize": 40,
          "authorName": { "fontSize": 13.5, "fontWeight": 700 },
          "roleBadge": {
            "component": "Badge",
            "colorMap": "teacher→primary, principal→success, student→warning, parent→purple"
          },
          "pinnedBadge": {
            "icon": "pin",
            "color": "pColor",
            "label": "Đã ghim"
          },
          "timeMeta": {
            "fontSize": 11.5,
            "color": "var(--edu-text-muted)",
            "fullTimeInTitle": true,
            "scopeIcon": "globe (school) | users (class)"
          },
          "menu": {
            "component": "FeedMenu",
            "trigger": {
              "size": 30,
              "borderRadius": 8,
              "icon": "moreHorizontal"
            },
            "semantics": "aria-haspopup=menu, role=menu/menuitem, Escape + outside-click dismiss, viewport-anchored",
            "items": {
              "pinToggle": "moderator only (principal, or teacher when class scope is own class)",
              "report": "any role except the post's own author",
              "remove": "moderator only, danger styled"
            }
          }
        },
        "body": {
          "fontSize": 13.5,
          "lineHeight": 1.65,
          "clamp": {
            "lines": 5,
            "threshold": "text.length > 320",
            "toggleLabel": "Xem thêm / Thu gọn",
            "className": "feed-clamp"
          },
          "imageGrid": {
            "component": "FeedImageGrid + FeedImg (placeholder: repeating-linear-gradient stripe + monospace caption, NOT real photos in mock)",
            "layouts": {
              "1": "16/9 full width",
              "2": "2-col 4/3",
              "3": "1 wide (21/9) + 2 below (4/3)",
              "4+": "2x2 grid, max 4 shown"
            },
            "gap": 6,
            "borderRadius": 10,
            "alt": "required, describes image content"
          }
        },
        "footer": {
          "reactionBar": {
            "component": "FeedReactionBar",
            "reactions": [
              "👍 Thích",
              "❤️ Yêu thích",
              "🎉 Chúc mừng",
              "👏 Tuyệt vời"
            ],
            "chip": {
              "padding": "4px 10px",
              "borderRadius": 99,
              "mine": {
                "border": "1px solid pColor",
                "background": "pColor + '1F'",
                "color": "pColor",
                "fontWeight": 700
              },
              "notMine": {
                "border": "1px solid var(--edu-border)",
                "color": "var(--edu-text-secondary)",
                "fontWeight": 600
              },
              "aria": "aria-pressed=mine, aria-label 'Thả cảm xúc {reason}, {count} người'"
            },
            "addReactionPicker": {
              "trigger": {
                "size": 28,
                "borderRadius": 99,
                "border": "1px dashed var(--edu-border)",
                "icon": "smile"
              },
              "popover": "row of emoji buttons, hover scale(1.25)"
            }
          },
          "commentsToggle": {
            "padding": "5px 12px",
            "borderRadius": 8,
            "activeBackground": "pColor + '12'",
            "activeColor": "pColor",
            "icon": "message",
            "countSuffix": " · {n}"
          }
        }
      },
      // Comment thread (FeedComments) — expands under post footer
      "commentThread": {
        "borderTop": "1px solid var(--edu-border)",
        "row": {
          "avatarSize": 28,
          "bubble": {
            "background": "var(--edu-bg)",
            "borderRadius": 10,
            "padding": "8px 12px"
          }
        },
        "menu": "same FeedMenu semantics; Báo cáo bình luận (non-author) / Gỡ bình luận (author or moderator, danger)",
        "input": {
          "avatarSize": 28,
          "pillBackground": "var(--edu-bg)",
          "borderRadius": 99,
          "sendButton": {
            "size": 28,
            "borderRadius": "50%",
            "disabledBackground": "var(--edu-border)"
          }
        }
      },
      // Report entry point — see screens.moderation.reportDialog (SHARED, not duplicated here)
      "reportEntryPoint": "post/comment '…' menu → 'Báo cáo' → opens screens.moderation.reportDialog (ReportContentDialog in ui.jsx)",
      "states": {
        "loading": {
          "component": "EduSkeleton",
          "variant": "rows",
          "count": 3
        },
        "empty": {
          "component": "EduEmpty",
          "icon": "newspaper",
          "title": "Chưa có bài viết nào",
          "cta": "Đăng bài viết đầu tiên — only when canPost"
        },
        "error": {
          "component": "EduError",
          "title": "Không tải được bảng tin",
          "retry": true
        },
        "endOfFeed": {
          "text": "Bạn đã xem hết bảng tin",
          "layout": "divider — label — divider"
        },
        "pagination": "cursor-based; 'Tải thêm bài viết' button (secondary, sm), loading label 'Đang tải…'"
      },
      "a11y": [
        "reaction buttons: aria-pressed + Vietnamese aria-label including reaction name and count",
        "'…' menus: proper menu/menuitem roles, Escape + outside-click close, focus not trapped (non-modal)",
        "images: alt required, decorative time separator '·' aria-hidden",
        "tab switcher: role=tablist/tab + aria-selected"
      ],
      "responsive": {
        "mobile375": "single column full width, no composer sticky (in-flow), scope tabs scroll horizontally"
      }
    },

    // ── Content Moderation — DR-013 (US-098, social service) ──────────────────
    // Source: design_src/edu/moderation.jsx — ModerationScreen (principal/admin,
    // route /principal/moderation) + shared ReportContentDialog (design_src/edu/ui.jsx).
    "moderation": {
      "route": "/principal/moderation",
      "roles": ["principal", "admin"],
      "source": "design_src/edu/moderation.jsx — ModerationScreen",
      "layout": {
        "maxWidth": 1200,
        "padding": "28px 32px (16px 12px <=760px)",
        "gap": 20
      },
      "statRow": {
        "grid": "repeat(auto-fit, minmax(240px, 1fr))",
        "cards": [
          {
            "icon": "clock",
            "iconColor": "var(--edu-warning)",
            "label": "Chờ xử lý",
            "source": "pending count"
          },
          {
            "icon": "checkSquare",
            "iconColor": "var(--edu-success)",
            "label": "Đã xử lý tuần này",
            "source": "resolved count"
          },
          {
            "icon": "trash",
            "iconColor": "var(--edu-error-dark)",
            "label": "Đã gỡ nội dung",
            "source": "removed count"
          }
        ],
        "component": "StatCard (canonical)"
      },
      "viewTabs": {
        "role": "tablist",
        "tabs": [
          "Hàng chờ báo cáo (flag icon)",
          "Nhật ký kiểm duyệt (scrollText icon)"
        ],
        "activeStyle": {
          "borderBottom": "2px solid pColor",
          "color": "pColor",
          "fontWeight": 700
        }
      },
      "queueFilterBar": {
        "statusTabs": {
          "role": "tablist",
          "options": ["Chờ xử lý", "Đã xử lý", "Tất cả"],
          "countBadge": "inline, tabular-nums"
        },
        "typeSelect": {
          "options": ["Mọi loại nội dung", "Bài viết", "Bình luận", "Tin nhắn"]
        },
        "search": { "placeholder": "Tìm nội dung, người đăng, người báo cáo…" },
        "refreshButton": { "size": 32, "borderRadius": 8, "icon": "refreshCw" }
      },
      "table": {
        "columns": [
          "Nội dung (icon+2-line clamp preview+location)",
          "Người báo cáo (+duplicate count)",
          "Lý do (badge)",
          "Người bị báo cáo",
          "Thời gian",
          "Trạng thái (badge)",
          "Hành động (chevronRight icon button, sr-only label)"
        ],
        "rowClickable": true,
        "reasonBadgeTones": {
          "spam": "warning",
          "language": "error",
          "bully": "error",
          "misinfo": "warning",
          "other": "muted (textSecondary)"
        },
        "statusBadges": {
          "pending": {
            "color": "var(--edu-warning)",
            "icon": "clock",
            "label": "Chờ xử lý"
          },
          "removed": {
            "color": "var(--edu-error-dark)",
            "background": "var(--edu-error-dark-light)",
            "icon": "trash",
            "label": "Đã gỡ"
          },
          "dismissed": {
            "color": "var(--edu-text-secondary)",
            "icon": "check",
            "label": "Đã bỏ qua"
          }
        },
        "mobileVariant": "card list (<=760px), same fields stacked"
      },
      "detailSheet": {
        "component": "ModDetailSheet",
        "width": 440,
        "side": "right",
        "role": "dialog, aria-modal, focus-trapped (Tab loop + Escape + return focus)",
        "sections": [
          "Nội dung bị báo cáo (author + full content, muted bg)",
          "Ngữ cảnh — original post (comment reports) OR 3 nearby messages (message reports, reported one highlighted errorDark tint)",
          "Báo cáo — reporter + time + reason badge + optional reasonNote quote",
          "Báo cáo trùng (N) — list of other reporters for same content",
          "Kết quả xử lý — resolvedBy/resolvedAt/resolveNote, shown only when status=resolved"
        ],
        "footerActions": {
          "shownWhen": "status===pending",
          "dismiss": "ghost, icon check",
          "remove": "danger, icon trash → opens confirmRemove dialog"
        }
      },
      "confirmRemoveDialog": {
        "component": "ModConfirmRemove",
        "role": "alertdialog",
        "maxWidth": 400,
        "iconBox": {
          "size": 38,
          "borderRadius": 10,
          "background": "var(--edu-error-dark-light)",
          "icon": "trash",
          "iconColor": "var(--edu-error-dark)"
        },
        "body": "explicit not-undoable + author-will-be-notified copy, content quote clamp 2 lines",
        "actions": ["Hủy (ghost)", "Gỡ nội dung (danger)"],
        "focusTrap": true
      },
      "auditTimelineTab": {
        "component": "ModAuditTimeline",
        "layout": "vertical timeline, left rail 2px var(--edu-border), dot per entry (removed=errorDark ring, dismissed=textSecondary ring)",
        "row": "actor + action badge + '{type} của {author}' + timestamp (right-aligned) + reason text below",
        "empty": "Chưa có hành động kiểm duyệt nào."
      },
      "states": {
        "loading": {
          "component": "EduSkeleton",
          "variant": "rows",
          "count": 5
        },
        "empty": {
          "component": "EduEmpty",
          "pendingTab": {
            "icon": "checkSquare",
            "color": "var(--edu-success)",
            "title": "Không có báo cáo nào chờ xử lý",
            "tone": "positive"
          },
          "otherTabs": {
            "icon": "search",
            "title": "Không tìm thấy báo cáo nào"
          }
        },
        "error": {
          "component": "EduError",
          "title": "Không tải được danh sách báo cáo",
          "retry": true
        }
      },
      "a11y": [
        "destructive remove is role-gated (principal/admin) + always confirm-dialog gated",
        "status badges carry icon + text, never color-only",
        "detail sheet + confirm dialog both focus-trapped with Escape + return-focus-on-close"
      ],

      // ── Report-content dialog — SHARED, single source of truth ───────────────
      // Source: design_src/edu/ui.jsx — ReportContentDialog + REPORT_REASONS.
      // Triggered from feed.jsx (post/comment '…' menu) AND messaging.jsx
      // (message context menu "reply/pin/copy/delete" sibling action). Both
      // callers reference THIS entry — do not duplicate under screens.feed or
      // messaging.groupChat.
      "reportDialog": {
        "component": "ReportContentDialog",
        "source": "design_src/edu/ui.jsx",
        "usedBy": ["feed.jsx (post + comment)", "messaging.jsx (message)"],
        "maxWidth": 430,
        "role": "dialog, aria-modal, focus-trapped",
        "header": {
          "iconBox": {
            "size": 36,
            "borderRadius": 10,
            "background": "var(--edu-warning-light)",
            "icon": "flag",
            "iconColor": "var(--edu-warning)"
          }
        },
        "quotePreview": {
          "background": "var(--edu-bg)",
          "borderRadius": 8,
          "clampLines": 3
        },
        "reasonRadioGroup": {
          "role": "radiogroup",
          "options": [
            "Spam",
            "Ngôn từ không phù hợp",
            "Bắt nạt",
            "Thông tin sai",
            "Khác"
          ],
          "otherReasonRequiresNote": true,
          "active": {
            "border": "1.5px solid pColor",
            "background": "pColor + '0D'"
          }
        },
        "footer": {
          "cancel": "ghost",
          "submit": {
            "label": "Gửi báo cáo",
            "icon": "flag",
            "disabledUntilValid": true
          }
        },
        "postSubmitBehavior": "toast 'Đã gửi báo cáo. BGH sẽ xem xét.' — reported content is NOT hidden from the reporter's own view"
      }
    },

    // ── Parent–Student Links & Consent — DR-014 (US-047, US-094/095, core service) ──
    // Source: design_src/edu/parent-links.jsx — ParentLinksScreen (admin) +
    // ParentConsentSection/ParentConsentScreen (parent)
    "parentLinks": {
      "route": "/admin/parent-links",
      "roles": ["principal", "admin"],
      "source": "design_src/edu/parent-links.jsx — ParentLinksScreen",
      "layout": {
        "maxWidth": 1200,
        "padding": "28px 32px (20px 16px on mobile <760px)"
      },
      "pageHeader": {
        "titleFontSize": 22,
        "titleFontWeight": 800,
        "createButton": {
          "variant": "primary",
          "icon": "plus",
          "label": "Tạo liên kết"
        }
      },
      "filterBar": {
        "search": { "placeholder": "Tìm học sinh hoặc phụ huynh…" },
        "classSelect": { "options": "PL_CLASSES + 'Tất cả các lớp'" }
      },
      "table": {
        "columns": [
          "Học sinh (avatar+name+class)",
          "Phụ huynh (avatar+name+phone)",
          "Quan hệ (badge)",
          "Trạng thái consent (badge+icon)",
          "Ngày liên kết",
          "Hành động (row menu)"
        ],
        "relationBadges": {
          "father": "info tone (Bố)",
          "mother": "purple tone (Mẹ)",
          "guardian": "textSecondary tone (Người giám hộ)"
        },
        "consentBadges": {
          "agreed": {
            "color": "var(--edu-teal)",
            "icon": "check",
            "label": "Đã đồng ý nhận TB"
          },
          "pending": {
            "color": "var(--edu-warning-text)",
            "icon": "clock",
            "label": "Chưa phản hồi"
          },
          "declined": {
            "color": "var(--edu-error-dark)",
            "icon": "x",
            "label": "Đã từ chối"
          }
        },
        "rowMenu": {
          "component": "PLRowMenu",
          "items": ["Xem chi tiết", "Gỡ liên kết (danger)"]
        },
        "mobileVariant": "card list <760px, same fields stacked, relation shown as icon+label row"
      },
      "createDialog": {
        "component": "PLCreateDialog",
        "maxWidth": 470,
        "studentCombobox": {
          "component": "PLCombobox",
          "role": "combobox+listbox",
          "placeholder": "Tìm theo tên học sinh…"
        },
        "parentCombobox": {
          "role": "combobox+listbox",
          "placeholder": "Tìm theo tên phụ huynh…",
          "subLabel": "phone"
        },
        "relationSelect": { "options": ["father", "mother", "guardian"] },
        "noteTextarea": { "rows": 2, "optional": true },
        "duplicateValidation": {
          "rule": "1 studentId+parentId pair may not repeat",
          "errorText": "Liên kết đã tồn tại",
          "errorStyle": "role=alert, errorDark, alertTriangle icon"
        }
      },
      "unlinkConfirmDialog": {
        "component": "PLUnlinkDialog",
        "maxWidth": 430,
        "iconBox": {
          "background": "var(--edu-error-dark-light)",
          "icon": "alertTriangle",
          "iconColor": "var(--edu-error-dark)"
        },
        "body": "explicit consequence copy: parent loses access to grades/conduct/attendance/notifications; neither account is deleted",
        "actions": ["Hủy (ghost)", "Gỡ liên kết (danger)"]
      },
      "detailDialog": {
        "component": "PLDetailDialog",
        "maxWidth": 440,
        "layout": "label-value rows (120px label column)"
      },
      "states": {
        "loading": {
          "component": "PLSkeleton (rows=5), same shimmer pattern as other admin tables"
        },
        "empty": {
          "component": "PLEmpty",
          "noFilters": "Lớp này chưa có liên kết nào + Tạo liên kết CTA",
          "filtered": "Không có liên kết nào khớp bộ lọc + Xoá bộ lọc"
        },
        "error": {
          "component": "PLError",
          "title": "Không tải được dữ liệu",
          "retry": true
        }
      },
      "toast": {
        "component": "PLToast",
        "position": "bottom-right, fixed",
        "borderRadius": 12
      },
      "a11y": [
        "consent badges carry icon + text, never color-only",
        "unlink is destructive + role-gated (principal/admin) + confirm dialog states the consequence",
        "combobox uses role=combobox/listbox/option correctly"
      ],

      // ── Parent-facing consent section — separate surface, embedded in parent profile ──
      // Source: design_src/edu/parent-links.jsx — ParentConsentSection (embeddable
      // Card) + ParentConsentScreen (standalone route wrapper for the parent role).
      "consentSection": {
        "route": "/consent (standalone) OR embedded card in parent profile/settings",
        "roles": ["parent"],
        "component": "ParentConsentSection",
        "header": {
          "iconBox": {
            "size": 38,
            "borderRadius": 10,
            "background": "pColor + '15'",
            "icon": "bell"
          },
          "titleFontSize": 15,
          "titleFontWeight": 800
        },
        "childCard": {
          "component": "PLChildConsentCard",
          "header": {
            "background": "var(--edu-bg)",
            "avatarSize": 38,
            "linkedBadge": "Đã liên kết"
          },
          "toggles": [
            {
              "id": "discipline",
              "icon": "shield",
              "label": "Thông báo vi phạm / hạnh kiểm"
            },
            {
              "id": "absence",
              "icon": "calendarX",
              "label": "Thông báo vắng học"
            },
            { "id": "grades", "icon": "award", "label": "Thông báo điểm số" }
          ],
          "toggleRow": {
            "iconBox": {
              "size": 34,
              "borderRadius": 9,
              "background": "(pColor or textMuted) + '14'"
            },
            "description": "1-line muted explainer under each toggle label",
            "switch": {
              "component": "PLSwitch",
              "width": 42,
              "height": 24,
              "role": "switch",
              "aria-checked": true
            }
          },
          "onChangeConfirm": "toast 'Đã cập nhật quyền nhận thông báo' (no modal confirm — instant + toast)"
        },
        "footerNote": {
          "icon": "lockClosed",
          "fontSize": 11.5,
          "color": "var(--edu-text-muted)",
          "copy": "explains school only sends with consent, scoped to linked students, toggling off doesn't affect in-app data access — privacy-respecting tone"
        },
        "states": {
          "loading": { "component": "PLConsentSkeleton" },
          "empty": {
            "icon": "users",
            "title": "Chưa có con nào được liên kết",
            "body": "contact-school guidance"
          },
          "error": { "component": "PLError" }
        },
        "a11y": "each PLSwitch has aria-labelledby + aria-describedby pointing at the toggle's own label + description text"
      }
    },

    // ── Tenant Invitations — DR-015 (iam service) ──────────────────────────────
    // Source: design_src/edu/invitations.jsx — InvitationsScreen (admin)
    "invitations": {
      "route": "/admin/invitations",
      "roles": ["principal", "admin"],
      "source": "design_src/edu/invitations.jsx — InvitationsScreen",
      "layout": { "maxWidth": 1200, "padding": "28px 32px (20px 16px <820px)" },
      "pageHeader": {
        "titleFontSize": 22,
        "actions": [
          "Làm mới (secondary, icon refreshCw)",
          "Gửi lời mời (primary, icon send)"
        ]
      },
      "statusTabs": {
        "role": "tablist",
        "options": [
          "Tất cả",
          "Chờ chấp nhận",
          "Đã chấp nhận",
          "Hết hạn",
          "Đã thu hồi"
        ],
        "countBadge": true
      },
      "search": { "placeholder": "Tìm theo email…" },
      "table": {
        "columns": [
          "Email",
          "Vai trò (badge)",
          "Người mời",
          "Ngày gửi",
          "Hết hạn (countdown)",
          "Trạng thái (badge)",
          "Hành động"
        ],
        "roleBadgeColors": {
          "teacher": "var(--edu-primary)",
          "student": "var(--edu-warning)",
          "parent": "var(--edu-purple)",
          "manager": "var(--edu-success) (BGH)",
          "admin": "var(--edu-error) (Admin)"
        },
        "statusBadges": {
          "pending": {
            "color": "var(--edu-warning-text)",
            "icon": "clock",
            "label": "Chờ chấp nhận"
          },
          "accepted": {
            "color": "var(--edu-teal)",
            "icon": "check",
            "label": "Đã chấp nhận"
          },
          "expired": {
            "color": "var(--edu-text-muted)",
            "icon": "calendarX",
            "label": "Hết hạn"
          },
          "revoked": {
            "color": "var(--edu-error-dark)",
            "icon": "x",
            "label": "Đã thu hồi"
          }
        },
        "expiryCountdown": {
          "component": "INVExpiryCell",
          "rule": "daysLeft < 3 → warning tone (var(--edu-warning-text)) + bold + alertTriangle icon; else textSecondary",
          "note": "countdown never color-only — always paired with 'Còn N ngày' text + icon when urgent",
          "acceptedOrRevoked": "em-dash placeholder",
          "expired": "'Hết hạn {date}' + calendarX icon, muted"
        },
        "rowActions": {
          "copyLink": "pending only, icon copy",
          "resend": "expired only, icon refreshCw",
          "revoke": "pending only, icon x, danger"
        },
        "revokedRowOpacity": 0.65,
        "mobileVariant": "card list <820px"
      },
      "sendDialog": {
        "component": "INVSendDialog",
        "maxWidth": 480,
        "emailChips": {
          "component": "INVEmailChips",
          "minHeight": 44,
          "chipValid": {
            "background": "pColor + '14'",
            "color": "pColor",
            "border": "pColor + '33'"
          },
          "chipInvalid": {
            "background": "var(--edu-error-dark-light)",
            "color": "var(--edu-error-dark)",
            "border": "var(--edu-error-dark) + '55'",
            "icon": "alertTriangle"
          },
          "commitKeys": ["Enter", ",", "Space"],
          "backspaceRemovesLastChip": true,
          "pasteMultiple": true,
          "errorText": {
            "role": "alert",
            "copy": "Một số email không đúng định dạng — xóa hoặc sửa trước khi gửi."
          }
        },
        "roleRadioGroup": {
          "role": "radiogroup",
          "options": ["teacher", "student", "parent", "manager", "admin"],
          "activeStyle": "border+bg tinted by role color, bold"
        },
        "expirySelect": {
          "options": ["7 ngày", "14 ngày", "30 ngày"],
          "default": "14 ngày"
        },
        "submitLabel": "Gửi lời mời | Gửi N lời mời (when >1 chip)"
      },
      "revokeConfirmDialog": {
        "component": "INVRevokeDialog",
        "maxWidth": 420,
        "role": "alertdialog-style",
        "body": "explains link becomes invalid immediately; new invite can be sent anytime",
        "actions": ["Hủy", "Thu hồi lời mời (danger)"]
      },
      "empty": {
        "component": "INVEmpty",
        "noFilters": "Chưa có lời mời nào + Gửi lời mời CTA",
        "filtered": "Không có lời mời nào khớp bộ lọc + Xoá bộ lọc"
      },
      // P8 fix: admin table now has full loading/error states (previously the only
      // screen in this batch missing them) — uses the mandatory states.jsx pair.
      "states": {
        "loading": {
          "component": "EduSkeleton",
          "variant": "rows",
          "count": 5
        },
        "error": {
          "component": "EduError",
          "title": "Không tải được danh sách lời mời",
          "retry": true,
          "pattern": "failedOnce ref — first refresh fails, retry succeeds (demo only)"
        }
      },
      "toast": { "component": "INVToast", "position": "bottom-right fixed" },
      "a11y": [
        "email chips removable by keyboard (button per chip)",
        "countdown urgency never color-only",
        "revoke is destructive + confirm-gated"
      ]
    },

    // ── Invite Accept (public onboarding) — DR-015 companion screen ───────────
    // Source: design_src/edu/invitations.jsx — InviteAcceptScreen
    // Layout family: SAME 2-column auth shell as screens.login (left brand panel
    // + right content card) — reuse screens.login.left tokens, do not respecify.
    "inviteAccept": {
      "route": "/invitations/accept?token=...",
      "roles": ["public (unauthenticated or authenticated, pre-tenant-join)"],
      "source": "design_src/edu/invitations.jsx — InviteAcceptScreen",
      "layoutReuse": "screens.login.left (42% brand gradient panel, decorative circles, bullet list) — same family, content bullets swapped for invite-specific copy",
      "card": { "maxWidth": 440, "padding": "32px 32px 28px" },
      "invitationSummary": {
        "iconBox": {
          "size": 54,
          "borderRadius": 15,
          "background": "pColor",
          "icon": "school"
        },
        "roleBadge": { "component": "INVRoleBadge", "size": "lg" },
        "metaLine": "Được mời bởi {invitedBy} ({title}) · Còn {daysLeft} ngày (đến {expiresAt})"
      },
      "userStates": {
        "guest": {
          "form": [
            "Email (readOnly, locked icon, describedby hint)",
            "Họ và tên (required)",
            "Mật khẩu (required, min 6 chars, inline hint/error)"
          ],
          "submitLabel": "Tạo tài khoản & tham gia",
          "switchToSignedIn": "Đã có tài khoản? Đăng nhập để tham gia"
        },
        "signedin": {
          "primaryButton": "Tham gia {school}",
          "caption": "Đang đăng nhập với {email} — Đổi tài khoản? (link back to guest)"
        }
      },
      "tokenErrorStates": {
        "component": "INVTokenError",
        "layout": "96px dashed-ring icon circle + title + body + school-contact chip",
        "expired": {
          "icon": "clock",
          "color": "var(--edu-warning-text)",
          "bg": "var(--edu-warning-light)",
          "title": "Lời mời đã hết hạn"
        },
        "used": {
          "icon": "userCheck",
          "color": "var(--edu-teal)",
          "bg": "var(--edu-teal-light)",
          "title": "Lời mời đã được sử dụng"
        },
        "invalid": {
          "icon": "alertTriangle",
          "color": "var(--edu-error-dark)",
          "bg": "var(--edu-error-dark-light)",
          "title": "Liên kết không hợp lệ"
        }
      },
      "successState": {
        "iconCircle": {
          "background": "var(--edu-teal-light)",
          "icon": "check",
          "iconColor": "var(--edu-teal)"
        },
        "cta": "Vào trang chính (redirect by role)"
      },
      "responsive": { "brandPanel": "hidden <=900px (.inv-left display:none)" },
      "a11y": [
        "email readOnly field has describedby hint explaining it's locked",
        "form errors: role=alert + aria-invalid + aria-describedby",
        "expiry countdown text always paired with words, not color-only"
      ]
    },

    // ── Multi-Tenant Switch — DR-018 (iam service) ─────────────────────────────
    // Source: design_src/edu/tenant-switch.jsx — TenantSwitchDialog (header menu)
    // + design_src/edu/app.jsx "P7 Multi-tenant" wiring (Header user-menu item).
    "tenantSwitch": {
      "roles": ["teacher", "principal", "student", "parent"],
      "source": "design_src/edu/tenant-switch.jsx — TenantSwitchDialog + TenantCard + TenantLogo",
      "zeroNoiseRule": "user belongs to exactly 1 school → no 'Đổi trường' menu item is rendered, no dialog, no post-login select screen — verified via tenants.length >= 2 checks in app.jsx/ui.jsx Header",
      "userMenuBlock": {
        "context": "Header avatar dropdown (design_src/edu/ui.jsx Header component), top of menu, before role-switch radio items",
        "tenantLogo": {
          "component": "TenantLogo",
          "size": 36,
          "borderRadius": 16,
          "background": "tenant.color + '1A'",
          "border": "1px solid tenant.color + '33'"
        },
        "roleBadge": { "component": "Badge", "color": "tenant.roleColor" },
        "switchMenuItem": {
          "shownWhen": "tenants.length >= 2",
          "icon": "switchHorizontal",
          "label": "Đổi trường",
          "role": "menuitem"
        }
      },
      "dialog": {
        "component": "TenantSwitchDialog",
        "maxWidth": 440,
        "role": "dialog, aria-modal, focus-trapped (Tab loop, Escape, backdrop click when not busy)",
        "header": {
          "iconBox": {
            "size": 36,
            "borderRadius": 10,
            "background": "pColor + '15'",
            "icon": "switchHorizontal"
          },
          "titleFontSize": 15
        },
        "tenantCard": {
          "component": "TenantCard",
          "element": "<button> — real interactive element, not a styled div",
          "minHeight": 80,
          "logoSize": 56,
          "hover": {
            "shadow": "0 4px 20px rgba(0,0,0,0.08)",
            "transform": "translateY(-2px)"
          },
          "focus": { "ring": "0 0 0 2px var(--edu-primary)" },
          "currentBadge": {
            "text": "Hiện tại",
            "color": "var(--edu-success)",
            "icon": "check"
          },
          "loadingState": {
            "spinner": "20px, tenant.color border-top",
            "ariaBusy": true,
            "srOnlyLabel": "Đang chuyển…"
          },
          "ariaLabel": "full sentence: '{name}, {address}, vai trò {role}[, trường hiện tại]'"
        },
        "switchFlow": "select non-current card → 900ms simulated loading on that card → TenantSwitchOverlay full-screen 'Đang tải dữ liệu {name}…' → toast 'Đã chuyển sang {name}' → app context reload"
      },
      "overlay": {
        "component": "TenantSwitchOverlay",
        "background": "rgba(245,247,250,0.92) + blur(4px)",
        "role": "status, aria-live=polite",
        "content": "TenantLogo 64px + loading label + spinner"
      },
      "a11y": [
        "card is a real <button>, keyboard operable",
        "current-school state conveyed by text badge, not border color alone",
        "dialog standard focus-trap semantics"
      ]
    },

    // ── Select Tenant (post-login) — DR-018 companion screen ──────────────────
    // Source: design_src/edu/tenant-switch.jsx — TenantSelectScreen
    // Layout family: SAME auth shell pattern as screens.login (centered card,
    // T.bg background, logo top) — reuse those tokens; only shown when
    // tenants.length >= 2 immediately after login (see app.jsx routing guard).
    "selectTenant": {
      "route": "(post-login gate, before entering the app shell)",
      "roles": ["teacher", "principal", "student", "parent"],
      "source": "design_src/edu/tenant-switch.jsx — TenantSelectScreen",
      "layoutReuse": "screens.login centered single-column variant (no left brand panel here — logo icon box 60px + heading, centered column maxWidth 480)",
      "shownWhen": "memberships.length >= 2 AND no active tenant selected yet",
      "heading": {
        "fontSize": 22,
        "fontWeight": 800,
        "text": "Chọn trường để tiếp tục"
      },
      "subheading": "Xin chào {userName} — tài khoản của bạn thuộc {n} trường.",
      "cardGrid": {
        "gap": 12,
        "cardComponent": "TenantCard (same as tenantSwitch.dialog.tenantCard, isCurrent always false here)"
      },
      "footerNote": "Bạn có thể đổi trường bất kỳ lúc nào từ menu tài khoản.",
      "switchFlow": "pick card → 900ms simulated loading → onSelect(tenant) → proceeds into app shell",
      "a11y": "identical TenantCard a11y contract as screens.tenantSwitch.dialog.tenantCard"
    },

    // ── Principal Reports — DR-019 (core service, school-wide analytics) ─────
    // Source: design_src/edu/reports.jsx — ReportsScreen
    "reports": {
      "route": "/principal/reports",
      "roles": ["principal"],
      "source": "design_src/edu/reports.jsx — ReportsScreen",
      "layout": { "maxWidth": 1200, "padding": "28px 32px" },
      "toolbar": {
        "termRadioGroup": {
          "role": "radiogroup",
          "options": ["Học kỳ I", "Học kỳ II", "Cả năm"],
          "activeBackground": "pColor",
          "activeColor": "#fff"
        },
        "actions": [
          "Làm mới (secondary, icon refreshCw)",
          "Xuất Excel (primary, icon download)"
        ]
      },
      "statGrid": {
        "grid": "repeat(auto-fit, minmax(230px, 1fr))",
        "cards": [
          { "icon": "users", "label": "Tổng số học sinh", "trend": true },
          {
            "icon": "award",
            "iconColor": "var(--edu-success)",
            "label": "Điểm TB toàn trường",
            "trend": true
          },
          {
            "icon": "userCheck",
            "iconColor": "var(--edu-warning)",
            "label": "Tỷ lệ chuyên cần",
            "trend": true
          },
          {
            "icon": "shield",
            "iconColor": "var(--edu-error)",
            "label": "Vi phạm trong kỳ",
            "trend": true
          }
        ],
        "component": "StatCard (canonical), trendLabel 'so với HK trước'"
      },
      "charts": {
        "gridColumns": "minmax(0,3fr) minmax(0,2fr)",
        "subjectBarChart": {
          "type": "bar, one bar per subject, scale of 10",
          "barGradient": "linear-gradient(180deg, pColor, pColor + '99')",
          "height": 180,
          "a11y": "role=img aria-label describing the whole chart (no per-bar SR detail — acceptable for a summary aggregate chart)"
        },
        "attendanceColumnChart": {
          "type": "column, 6 weeks",
          "lowThreshold": "pct < 96 → var(--edu-warning) bar + warning-colored value label; else var(--edu-success)",
          "height": 180,
          "a11y": "role=img aria-label describing chart"
        }
      },
      "periodicReportsTable": {
        "header": "title + 'Tạo báo cáo' ghost button (icon plus)",
        "columns": [
          "Tên báo cáo (icon+name)",
          "Kỳ",
          "Ngày tạo",
          "Trạng thái (badge)",
          "Tải về (icon download, disabled unless ready)"
        ],
        "statusBadges": {
          "ready": "success — Sẵn sàng",
          "generating": "warning — Đang tạo…"
        }
      },
      "states": {
        "loading": {
          "component": "EduSkeleton",
          "variant": "cards",
          "count": 4
        },
        "error": {
          "component": "EduError",
          "title": "Không tải được báo cáo",
          "retry": true,
          "pattern": "failedOnce ref — first refresh fails, retry succeeds (demo only)"
        }
      },
      "a11y": [
        "charts use role=img + descriptive aria-label",
        "low-attendance weeks flagged by value color AND numeric label, not bar color alone",
        "download action disabled state communicated via disabled attribute, not just opacity"
      ]
    }
  },

  // ─────────────────────────────────────────────
  // CLASS LOG — Sổ đầu bài (US-E13.3)
  // Derived from design_src/edu/classops.jsx ClassLogScreen; aligned to the
  // REAL core homeroom-entries contract (summary + notableEvents only).
  // ─────────────────────────────────────────────
  "class-log": {
    "statusBadgeTones": {
      "DRAFT": "muted",
      "SUBMITTED": "warning",
      "APPROVED": "success",
      "REJECTED": "error"
    },
    "teacherScreen": {
      "route": "/teacher/class-log?classId=<id>",
      "pageTitle": "Sổ đầu bài",
      "subtitle": "Ghi lại nội dung từng tiết dạy để BGH phê duyệt",
      "newEntryButton": "Ghi tiết mới",
      "statsRow": [
        {
          "label": "Chờ duyệt",
          "tone": "warning",
          "source": "SUBMITTED count"
        },
        { "label": "Đã duyệt", "tone": "success", "source": "APPROVED count" },
        { "label": "Nháp", "tone": "muted", "source": "DRAFT count" }
      ],
      "listRow": {
        "statusBar": "3px (w-1) left bar colored by status (bg-edu-* token)",
        "columns": ["entryDate", "summary excerpt", "status badge"],
        "card": "white card, radius 12, shadow-card, hover shadow-card-hover"
      },
      "entryForm": {
        "maxWidth": 720,
        "title": "Ghi sổ đầu bài",
        "fields": [
          { "name": "entryDate", "type": "date", "required": true },
          {
            "name": "summary",
            "type": "textarea",
            "required": true,
            "ariaRequired": true,
            "maps": "API summary (lesson content)"
          },
          {
            "name": "notableEvents",
            "type": "textarea",
            "required": false,
            "maps": "API notableEvents (class notes)"
          }
        ],
        "actions": ["Lưu nháp (outline)", "Gửi BGH phê duyệt (primary)"]
      },
      "detail": {
        "header": "primary band, summary title + entryDate + status badge",
        "readonlyAfterSubmit": true,
        "teacherSubmitAction": "visible when status DRAFT or REJECTED"
      }
    },
    "principalScreen": {
      "route": "/principal/class-log?classId=<id>",
      "pageTitle": "Sổ đầu bài",
      "subtitle": "Xem xét và phê duyệt sổ đầu bài của giáo viên",
      "noCreateButton": true,
      "statsRow": [
        {
          "label": "Chờ duyệt",
          "tone": "warning",
          "source": "SUBMITTED count"
        },
        { "label": "Đã duyệt", "tone": "success", "source": "APPROVED count" },
        { "label": "Từ chối", "tone": "error", "source": "REJECTED count" }
      ],
      "filterChips": ["Tất cả", "Nháp", "Chờ duyệt", "Đã duyệt", "Từ chối"],
      "approvalActions": {
        "shownWhen": "status === SUBMITTED",
        "approve": "Phê duyệt (bg-edu-success)",
        "reject": "Từ chối → inline reason textarea → Xác nhận từ chối (destructive)"
      }
    }
  },

  // ─────────────────────────────────────────────
  // SHARED COMPONENTS
  // ─────────────────────────────────────────────
  "components": {
    "StatCard": {
      "padding": "20px 24px",
      "background": "white",
      "border": "1px solid #E5EAF2",
      "shadow": "0 2px 12px rgba(0,0,0,0.04)",
      "borderRadius": 12,
      "iconBox": {
        "size": 52,
        "borderRadius": 12,
        "background": "iconColor + '18'"
      },
      "value": { "size": 26, "fontWeight": 800 },
      "trend": {
        "size": 12,
        "fontWeight": 700,
        "up": "#13DEB9",
        "down": "#FA896B"
      }
    },
    "Badge": {
      "padding": "3px 10px",
      "borderRadius": 20,
      "fontSize": 11,
      "fontWeight": 600,
      "backgroundDefault": "color + '18'"
    },
    "ProgressBar": {
      "track": "#E5EAF2",
      "defaultHeight": 6,
      "borderRadius": 99,
      "transition": "width 0.6s ease"
    }
  },

  // ─────────────────────────────────────────────
  // ASSESSMENT SCHEME CONFIG
  // Source: design_src/edu/assessment.jsx (1506 handoff)
  // Route: /admin/assessment — ADMIN role only — US-E12.6
  // ─────────────────────────────────────────────
  "assessmentScheme": {
    "route": "(app)/admin/assessment",
    "role": "admin",
    "us": "US-E12.6",
    "designFile": "design_src/edu/assessment.jsx",

    // ── Page container ────────────────────────────────────────────────────────
    // AssessmentSchemeScreen: flex:1, overflowY:auto, padding:28px 32px
    // maxWidth 1280, margin 0 auto (inner wrapper)
    "layout": {
      "pageContainer": {
        "flex": 1,
        "overflowY": "auto",
        "padding": "28px 32px"
      },
      "innerWrapper": {
        "maxWidth": 1280,
        "margin": "0 auto"
      },
      // Two-column grid: 40% left (Grade Scale) | 60% right (Assessment Scheme)
      // Component: direct child of inner wrapper after header
      "twoColumnGrid": {
        "display": "grid",
        "gridTemplateColumns": "minmax(0, 4fr) minmax(0, 6fr)",
        "gap": 18,
        "alignItems": "start"
      }
    },

    // ── Breadcrumb ────────────────────────────────────────────────────────────
    // fontSize 12.5, color textMuted, marginBottom 12, gap 6
    // Links: Home (home icon 12px) → Thiết lập trường → Thang điểm & Khung ĐG (active, textPrimary/700)
    // chevronRight icon 11px between segments
    "breadcrumb": {
      "fontSize": 12.5,
      "color": "var(--edu-text-muted)",
      "marginBottom": 12,
      "gap": 6,
      "items": [
        {
          "label": "Trang chủ / Home",
          "icon": "home",
          "size": 12,
          "nav": "dashboard"
        },
        { "label": "Thiết lập trường / School setup", "nav": "school-setup" },
        {
          "label": "Thang điểm & Khung ĐG / Assessment Scheme",
          "active": true,
          "color": "textPrimary",
          "fontWeight": 700
        }
      ]
    },

    // ── Page header ───────────────────────────────────────────────────────────
    // Component: title row div — display:flex, alignItems:center, gap:14, marginBottom:22
    "pageHeader": {
      // Icon box: 44×44, radius 12, bg pColor+'18', icon "percent" 22px pColor strokeWidth 1.8
      "iconBox": {
        "width": 44,
        "height": 44,
        "borderRadius": 12,
        "background": "pColor + '18'",
        "icon": "percent",
        "iconSize": 22,
        "iconStrokeWidth": 1.8
      },
      // Title: 22px/800, textPrimary
      "title": {
        "vi": "Thang điểm & Khung đánh giá",
        "en": "Grade Scale & Assessment Scheme",
        "fontSize": 22,
        "fontWeight": 800,
        "color": "var(--edu-text-primary)"
      },
      // Step badge: pill next to title — bg pColor+'14', border pColor+'33', color pColor
      // "sparkles" icon 10px, 11px/800, letterSpacing 0.04em
      "stepBadge": {
        "vi": "Bước 4/5 · Onboarding",
        "en": "Step 4/5 · Onboarding",
        "padding": "3px 10px",
        "borderRadius": 99,
        "background": "pColor + '14'",
        "border": "1px solid pColor + '33'",
        "color": "pColor",
        "fontSize": 11,
        "fontWeight": 800,
        "icon": "sparkles",
        "iconSize": 10
      },
      // Subtitle: 13px textMuted, marginTop 2
      "subtitle": {
        "fontSize": 13,
        "color": "var(--edu-text-muted)",
        "marginTop": 2
      },
      // ADMIN badge: right side — Badge component, color T.error, icon "shield" 11px
      "adminBadge": {
        "label": "ADMIN",
        "color": "var(--edu-error)",
        "icon": "shield",
        "iconSize": 11
      }
    },

    // ── Section card (AsCard) ─────────────────────────────────────────────────
    // Shared wrapper for both columns
    // bg T.card (#FFF), radius 14, border 1px T.border, shadow '0 2px 12px rgba(0,0,0,0.04)', padding 24
    "sectionCard": {
      "background": "var(--edu-card)",
      "borderRadius": 14,
      "border": "1px solid var(--edu-border)",
      "boxShadow": "0 2px 12px rgba(0,0,0,0.04)",
      "padding": 24
    },

    // ── Section header (AsSectionHeader) ─────────────────────────────────────
    // display:flex, alignItems:flex-start, gap:14, marginBottom:20
    // Icon box: 40×40, radius 10, bg iconColor+'18'; icon 20px iconColor strokeWidth 1.8
    // Title: 16px/800 textPrimary
    // Unsaved indicator pill (when dirty): bg warningLight, 10.5px/800 warning, 6px dot, padding 2px 8px radius 99
    "sectionHeader": {
      "display": "flex",
      "alignItems": "flex-start",
      "gap": 14,
      "marginBottom": 20,
      "iconBox": {
        "width": 40,
        "height": 40,
        "borderRadius": 10,
        "background": "iconColor + '18'"
      },
      "iconSize": 20,
      "iconStrokeWidth": 1.8,
      "titleFontSize": 16,
      "titleFontWeight": 800,
      "subtitleFontSize": 12.5,
      "subtitleColor": "var(--edu-text-muted)",
      // Unsaved indicator — shown when dirty===true
      "unsavedIndicator": {
        "display": "inline-flex",
        "alignItems": "center",
        "gap": 5,
        "fontSize": 10.5,
        "fontWeight": 800,
        "color": "var(--edu-warning)",
        "background": "var(--edu-warning-light)",
        "padding": "2px 8px",
        "borderRadius": 99,
        "dot": {
          "width": 6,
          "height": 6,
          "borderRadius": "50%",
          "background": "var(--edu-warning)"
        }
      }
    },

    // ── States ────────────────────────────────────────────────────────────────
    "states": {
      // NoSubjectsBanner — shown when allSubjects.length === 0 (no active subjects in catalogue)
      // Shown above the two-column grid, marginBottom 18
      "noSubjects": {
        "component": "NoSubjectsBanner",
        "container": {
          "padding": "14px 18px",
          "marginBottom": 18,
          "background": "var(--edu-warning-light)",
          "border": "1px solid var(--edu-warning) + '44'",
          "borderRadius": 12,
          "display": "flex",
          "alignItems": "center",
          "gap": 14
        },
        // Warning icon box: 36×36 radius 10, bg warning+'22'
        "iconBox": {
          "width": 36,
          "height": 36,
          "borderRadius": 10,
          "background": "T.warning + '22'",
          "icon": "alertTriangle",
          "iconSize": 17
        },
        "title": {
          "vi": "Cần thiết lập danh mục môn học trước",
          "en": "Subject catalogue must be configured first",
          "fontSize": 14,
          "fontWeight": 800,
          // WCAG note: use #9A6A0F (--edu-warning-foreground), NOT white — contrast on warningLight bg
          "color": "#9A6A0F"
        },
        "body": {
          "fontSize": 12.5,
          "color": "var(--edu-text-secondary)",
          "marginTop": 2
        },
        "cta": {
          "label": {
            "vi": "Đến Danh mục môn học",
            "en": "Open Subject catalogue"
          },
          "variant": "secondary",
          "icon": "arrowRight",
          "navigatesTo": "subjects"
        }
      },

      // NoSubjectPicked — right column body when no subject is selected in the picker
      // Component: NoSubjectPicked
      "noSubjectPicked": {
        "component": "NoSubjectPicked",
        "container": {
          "background": "var(--edu-bg)",
          "borderRadius": 12,
          "border": "1px dashed var(--edu-border)",
          "padding": "36px 22px",
          "textAlign": "center"
        },
        "icon": {
          "name": "bookOpen",
          "size": 30,
          "color": "T.border",
          "strokeWidth": 1.6
        },
        "title": {
          "vi": "Chọn khối và môn học để bắt đầu",
          "en": "Pick a grade and subject to begin",
          "fontSize": 13,
          "fontWeight": 700,
          "color": "var(--edu-text-secondary)",
          "marginTop": 8
        },
        "body": { "fontSize": 11.5, "marginTop": 4 }
      },

      // NoSchemeYet — right column body when subject picked but no scheme configured
      // Component: NoSchemeYet
      "noSchemeYet": {
        "component": "NoSchemeYet",
        "container": {
          "background": "var(--edu-bg)",
          "borderRadius": 12,
          "border": "1px dashed var(--edu-border)",
          "padding": "32px 22px",
          "textAlign": "center"
        },
        "icon": {
          "name": "clipboardList",
          "size": 30,
          "color": "T.border",
          "strokeWidth": 1.6
        },
        "title": {
          "vi": "Chưa có khung đánh giá cho môn học này.",
          "en": "No assessment scheme for this subject yet.",
          "fontSize": 14,
          "fontWeight": 800,
          "color": "var(--edu-text-secondary)",
          "marginTop": 8
        },
        "body": { "fontSize": 12, "marginBottom": 16 },
        // Inline preset buttons: border pColor+'55', bg T.card, color pColor, 12.5px/800 radius 8
        "presetButtons": {
          "display": "inline-flex",
          "flexWrap": "wrap",
          "gap": 8,
          "justifyContent": "center",
          "button": {
            "padding": "8px 14px",
            "borderRadius": 8,
            "border": "1.5px solid pColor + '55'",
            "background": "T.card",
            "color": "pColor",
            "fontSize": 12.5,
            "fontWeight": 800
          }
        }
      }
    },

    // ── Left column — Grade Scale (GradeScaleSection) ─────────────────────────
    "leftColumn": {
      "widthFraction": "4fr (≈40%)",
      // Section header: icon "percent", iconColor pColor, title "Thang điểm / Grade Scale"
      "sectionHeader": {
        "icon": "percent",
        "iconColor": "pColor",
        "titleVi": "Thang điểm",
        "titleEn": "Grade Scale",
        "subtitleVi": "Áp dụng cho toàn trường. Xếp loại sẽ hiển thị trên học bạ & báo cáo.",
        "subtitleEn": "Applied school-wide. Ranks appear on transcripts and reports."
      },

      // Preset pills (AsPill): flexWrap, gap 8, marginBottom 18
      // Three presets: vn10 / gpa4 / letter
      // Active pill: border pColor, bg pColor+'14', color pColor
      // Inactive: border T.border, bg T.card, color textSecondary
      // Pill layout: flexDirection column, gap 2; title 12.5px/800, subtitle 10.5px/600
      "presetPills": {
        "gap": 8,
        "flexWrap": "wrap",
        "marginBottom": 18,
        "pillPadding": "8px 14px",
        "pillBorderRadius": 9,
        "pillActiveBorder": "1.5px solid pColor",
        "pillActiveBackground": "pColor + '14'",
        "pillInactiveBorder": "1.5px solid T.border",
        "pillInactiveBackground": "T.card",
        "titleFontSize": 12.5,
        "titleFontWeight": 800,
        "subtitleFontSize": 10.5,
        "subtitleFontWeight": 600,
        "presets": [
          {
            "id": "vn10",
            "vi": "Thang 10",
            "en": "Scale 10",
            "descVi": "Mặc định Việt Nam · Thông tư 22/2021"
          },
          {
            "id": "gpa4",
            "vi": "Thang 4.0",
            "en": "Scale 4.0 (GPA)",
            "descVi": "GPA chuẩn quốc tế"
          },
          {
            "id": "letter",
            "vi": "Xếp loại chữ",
            "en": "Letter grades",
            "descVi": "Quy đổi từ phần trăm"
          }
        ]
      },

      // Band list container: bg T.bg, radius 10, border 1px T.border, padding 10, marginBottom 14
      "bandListContainer": {
        "background": "var(--edu-bg)",
        "borderRadius": 10,
        "border": "1px solid var(--edu-border)",
        "padding": 10,
        "marginBottom": 14
      },

      // Band list header row (column labels)
      // Grid: 14px | 1.4fr | 0.85fr | 0.85fr | 1fr | 26px | 26px
      // 9.5px/800 textMuted uppercase letterSpacing 0.08em, padding 6px 8px
      "bandListHeader": {
        "gridTemplateColumns": "14px minmax(0, 1.4fr) minmax(0, 0.85fr) minmax(0, 0.85fr) minmax(0, 1fr) 26px 26px",
        "gap": 8,
        "padding": "6px 8px",
        "fontSize": 9.5,
        "fontWeight": 800,
        "color": "var(--edu-text-muted)",
        "letterSpacing": "0.08em",
        "textTransform": "uppercase",
        "columns": [
          "(swatch)",
          "Xếp loại / Rank",
          "Từ / From",
          "Đến / To",
          "Màu / Color",
          "(move)",
          "(delete)"
        ]
      },

      // BandRow — one row per band, same grid template as header
      // Component: BandRow
      "bandRow": {
        "gridTemplateColumns": "14px minmax(0, 1.4fr) minmax(0, 0.85fr) minmax(0, 0.85fr) minmax(0, 1fr) 26px 26px",
        "gap": 8,
        "padding": "6px 8px",
        "borderBottom": "1px dashed T.border",
        "colorSwatch": {
          "width": 12,
          "height": 12,
          "borderRadius": 3,
          "border": "1px solid T.border"
        },
        "labelInput": {
          "padding": "6px 8px",
          "borderRadius": 6,
          "border": "1px solid T.border",
          "fontSize": 12.5,
          "fontWeight": 700,
          "color": "var(--edu-text-primary)"
        },
        // Live rank badge next to input (shown when labelVi non-empty)
        "rankBadge": {
          "fontSize": 10.5,
          "fontWeight": 800,
          "color": "band.color",
          "background": "band.color + '20'",
          "padding": "2px 7px",
          "borderRadius": 4
        },
        "numberInput": {
          "padding": "6px 8px",
          "borderRadius": 6,
          "border": "1px solid T.border",
          "fontSize": 12.5,
          "fontWeight": 700,
          "fontFamily": "ui-monospace, Menlo, monospace",
          "fontVariantNumeric": "tabular-nums"
        },
        // Color picker: native <input type="color"> 28×26 radius 5
        // Hex label: 10px monospace textMuted
        "colorPicker": { "width": 28, "height": 26, "borderRadius": 5 },
        "hexLabel": {
          "fontSize": 10,
          "fontFamily": "ui-monospace",
          "color": "var(--edu-text-muted)"
        },
        // Move up/down buttons: 22×12 each, stacked, iconBtn style, disabled opacity 0.35
        "moveButtons": {
          "width": 22,
          "height": 12,
          "borderRadius": 4,
          "disabledOpacity": 0.35
        },
        // Delete button: 24×24 radius 6, hover bg errorLight border error
        "deleteButton": { "width": 24, "height": 24, "borderRadius": 6 }
      },

      // Add band button: dashed border, width 100%, marginTop 8, pColor, 12.5px/800
      "addBandButton": {
        "width": "100%",
        "marginTop": 8,
        "padding": "8px 10px",
        "borderRadius": 7,
        "border": "1.5px dashed T.border",
        "color": "pColor",
        "fontSize": 12.5,
        "fontWeight": 800,
        "icon": "plus",
        "iconSize": 13
      },

      // Callout component — used for validation warnings/errors
      // Component: Callout (shared by both left and right columns)
      "callout": {
        "marginTop": 10,
        "padding": "11px 14px",
        "borderRadius": 10,
        "display": "flex",
        "gap": 10,
        "icon": "alertTriangle",
        "iconSize": 14,
        "titleFontSize": 12.5,
        "titleFontWeight": 800,
        "bodyFontSize": 11.5,
        "bodyColor": "var(--edu-text-secondary)",
        "kinds": {
          "warning": {
            "background": "var(--edu-warning-light)",
            "border": "var(--edu-warning) + '44'",
            "color": "var(--edu-warning)"
          },
          "error": {
            "background": "var(--edu-error-light)",
            "border": "var(--edu-error) + '44'",
            "color": "var(--edu-error)"
          }
        }
      },

      // Validation states (shown inline below band list)
      "validation": {
        "gapWarning": {
          "trigger": "bands don't fully cover domain.min → domain.max",
          "calloutKind": "warning",
          "titleVi": "Các ngưỡng chưa phủ kín từ {min} đến {max}{unit}"
        },
        "overlapError": {
          "trigger": "two or more bands share score ranges",
          "calloutKind": "error",
          "titleVi": "Các ngưỡng bị chồng lấn"
        }
      },

      // Save row: marginTop 16, flex, gap 10
      // Button: variant=primary icon="check" label "Lưu thang điểm / Save grade scale", disabled when !dirty
      // Success toast: inline pill successLight bg, success color, check icon 11px, 11.5px/800
      //   animation: as-fadein 0.2s (from opacity 0 translateY(-2px) to opacity 1 translateY(0))
      "saveRow": {
        "marginTop": 16,
        "gap": 10,
        "saveButton": {
          "variant": "primary",
          "icon": "check",
          "labelVi": "Lưu thang điểm",
          "labelEn": "Save grade scale",
          "disabledWhen": "!dirty"
        },
        "unsavedHint": {
          "fontSize": 11.5,
          "color": "var(--edu-text-muted)",
          "fontWeight": 600
        },
        "successToast": {
          "display": "inline-flex",
          "padding": "5px 10px",
          "borderRadius": 99,
          "background": "var(--edu-success-light)",
          "color": "var(--edu-success)",
          "fontSize": 11.5,
          "fontWeight": 800,
          "icon": "check",
          "iconSize": 11,
          "animation": "as-fadein 0.2s ease-out",
          "autoDismissMs": 2400
        }
      }
    },

    // ── Right column — Assessment Scheme (AssessmentSchemeSection) ────────────
    "rightColumn": {
      "widthFraction": "6fr (≈60%)",
      // Section header: icon "bookOpen", iconColor T.teal (#00B8A9)
      "sectionHeader": {
        "icon": "bookOpen",
        "iconColor": "#00B8A9",
        "iconColorToken": "T.teal",
        "titleVi": "Khung đánh giá môn học",
        "titleEn": "Per-subject Assessment Scheme",
        "subtitleVi": "Cấu trúc cột điểm cho từng môn theo khối. Tổng trọng số bắt buộc bằng 100%.",
        "subtitleEn": "Grade-book column structure per grade-scoped subject. Weights must total 100%."
      },

      // Subject picker — two-level (SelectField × 2)
      // Grid: 1fr | 2fr, gap 12, marginBottom 18
      "subjectPicker": {
        "gridTemplateColumns": "minmax(0, 1fr) minmax(0, 2fr)",
        "gap": 12,
        "marginBottom": 18,
        "select": {
          "padding": "9px 32px 9px 12px",
          "borderRadius": 8,
          "border": "1.5px solid T.border",
          "background": "T.card (disabled: T.bg)",
          "fontSize": 13.5,
          "fontWeight": 700,
          "backgroundImage": "chevron SVG data-uri at right 10px center",
          "disabledOpacity": 0.6
        },
        "label": {
          "fontSize": 10.5,
          "fontWeight": 800,
          "color": "var(--edu-text-muted)",
          "textTransform": "uppercase",
          "letterSpacing": "0.08em"
        },
        "fields": [
          {
            "id": "grade",
            "labelVi": "Khối lớp",
            "labelEn": "Grade level",
            "disabledWhen": "never"
          },
          {
            "id": "subject",
            "labelVi": "Môn học",
            "labelEn": "Subject",
            "disabledWhen": "!grade"
          }
        ]
      },

      // Scheme editor — shown when subject is picked AND scheme exists
      "schemeEditor": {
        // Subject heading tile
        // Component: top block inside SchemeEditor
        // bg pColor+'0A', border pColor+'33', radius 12, padding 14 16, display flex gap 14 flexWrap
        "subjectHeading": {
          "background": "pColor + '0A'",
          "border": "1px solid pColor + '33'",
          "borderRadius": 12,
          "padding": "14px 16px",
          "marginBottom": 14,
          "display": "flex",
          "alignItems": "center",
          "gap": 14,
          "flexWrap": "wrap",
          // Grade icon box: 40×40 radius 10, bg pColor+'22', color pColor
          // "LỚP" label 9px/800 letterSpacing 0.06em + grade number 14px/900 tabular-nums
          "gradeIconBox": {
            "width": 40,
            "height": 40,
            "borderRadius": 10,
            "background": "pColor + '22'",
            "color": "pColor",
            "flexDirection": "column",
            "labelFontSize": 9,
            "labelFontWeight": 800,
            "numberFontSize": 14,
            "numberFontWeight": 900
          },
          // Title: "Khung đánh giá — {subjectName}" 15px/800 textPrimary
          "title": {
            "fontSize": 15,
            "fontWeight": 800,
            "color": "var(--edu-text-primary)"
          },
          // Code: "{subjectId} · {subjectCode}" 11px monospace textMuted, marginTop 2
          "code": {
            "fontSize": 11,
            "fontFamily": "ui-monospace, Menlo, monospace",
            "color": "var(--edu-text-muted)"
          },
          // LockedMeta tiles: flexDirection column, gap 2, padding 6px 10px, radius 8, bg T.bg, border T.border
          // Label: 9.5px/800 textMuted uppercase lock icon 9px; Value: 13px/800 textPrimary tabular-nums
          "lockedMetaTile": {
            "padding": "6px 10px",
            "borderRadius": 8,
            "background": "var(--edu-bg)",
            "border": "1px solid var(--edu-border)",
            "labelFontSize": 9.5,
            "labelFontWeight": 800,
            "labelIcon": "lock",
            "labelIconSize": 9,
            "valueFontSize": 13,
            "valueFontWeight": 800,
            "fields": [
              "Số tiết / năm (Periods / year)",
              "Số bài KT / kỳ (Required exams / term)"
            ]
          }
        },

        // Preset pills for scheme (AsPill, same component as grade scale)
        // display flex, gap 10, marginBottom 14, flexWrap
        // Label prefix: "Khung mẫu / Preset" 10.5px/800 textMuted uppercase
        "presetPills": {
          "gap": 10,
          "marginBottom": 14,
          "labelFontSize": 10.5,
          "labelFontWeight": 800,
          "labelColor": "var(--edu-text-muted)",
          "presets": [
            {
              "id": "tt22",
              "vi": "Theo Thông tư 22/2021",
              "en": "Per Circular 22/2021",
              "descVi": "Áp dụng cho THPT"
            },
            {
              "id": "tt26",
              "vi": "THCS Thông tư 26",
              "en": "Circular 26 · Lower secondary",
              "descVi": "Áp dụng cho THCS"
            },
            {
              "id": "custom",
              "vi": "Tùy chỉnh",
              "en": "Custom",
              "descVi": "Tự định nghĩa cột & trọng số"
            }
          ]
        },

        // Column table: bg T.card, border T.border, radius 12, overflow hidden, marginBottom 14
        "columnTable": {
          "background": "var(--edu-card)",
          "border": "1px solid var(--edu-border)",
          "borderRadius": 12,
          "overflow": "hidden",
          "marginBottom": 14,

          // Table header: bg T.bg, borderBottom T.border, padding 10 14
          // 10.5px/800 textMuted uppercase letterSpacing 0.06em
          // gridTemplateColumns: 2.2fr | 0.7fr | 0.9fr | 26px
          "header": {
            "background": "var(--edu-bg)",
            "borderBottom": "1px solid var(--edu-border)",
            "padding": "10px 14px",
            "fontSize": 10.5,
            "fontWeight": 800,
            "color": "var(--edu-text-muted)",
            "letterSpacing": "0.06em",
            "textTransform": "uppercase",
            "gridTemplateColumns": "minmax(0, 2.2fr) minmax(0, 0.7fr) minmax(0, 0.9fr) 26px",
            "columns": [
              "Cột điểm / Column",
              "Số lần / Times",
              "Trọng số / Weight",
              "(delete)"
            ]
          },

          // ColumnRow — one per column
          // Same grid template as header, padding 10px 14px, borderBottom T.border
          "columnRow": {
            "gridTemplateColumns": "minmax(0, 2.2fr) minmax(0, 0.7fr) minmax(0, 0.9fr) 26px",
            "padding": "10px 14px",
            "borderBottom": "1px solid T.border",
            // Kind select: colored badge style — bg km.color+'14', border km.color+'55', color km.color
            // 10.5px/800, padding 5px 24px 5px 8px, radius 6, appearance none, chevron data-uri
            "kindSelect": {
              "padding": "5px 24px 5px 8px",
              "borderRadius": 6,
              "fontSize": 10.5,
              "fontWeight": 800,
              "background": "km.color + '14'",
              "border": "1.5px solid km.color + '55'",
              "color": "km.color",
              "kinds": {
                "TX": "T.primary (#5D87FF)",
                "GK": "T.warning (#FFAE1F)",
                "CK": "T.error (#FA896B)"
              }
            },
            // Label input: flex 1, padding 6px 10px, radius 6, border T.border, 13px/700
            "labelInput": {
              "padding": "6px 10px",
              "borderRadius": 6,
              "fontSize": 13,
              "fontWeight": 700
            },
            // Times input: width 56px, center, monospace tabular-nums
            "timesInput": { "width": 56, "textAlign": "center", "prefix": "×" },
            // Weight input: width 64px, center, suffix "%"
            "weightInput": {
              "width": 64,
              "textAlign": "center",
              "suffix": "%"
            },
            // Delete button: 24×24 radius 6, error icon, disabled when columns.length === 1
            "deleteButton": {
              "width": 24,
              "height": 24,
              "borderRadius": 6,
              "disabledOpacity": 0.35
            }
          },

          // Total row: double top border (2px solid T.border)
          // bg: isHundred → successLight+'88'; else → errorLight+'88'
          // Weight total: 16px/900 tabular-nums; color success or error
          // Icon: check (success) or alertTriangle (error), 12px
          "totalRow": {
            "gridTemplateColumns": "minmax(0, 2.2fr) minmax(0, 0.7fr) minmax(0, 0.9fr) 26px",
            "padding": "12px 14px",
            "borderTop": "2px solid var(--edu-border)",
            "backgroundSuccess": "var(--edu-success-light) + '88'",
            "backgroundError": "var(--edu-error-light) + '88'",
            "labelFontSize": 11.5,
            "labelFontWeight": 800,
            "totalFontSize": 16,
            "totalFontWeight": 900,
            "colorSuccess": "var(--edu-success)",
            "colorError": "var(--edu-error)"
          },

          // Progress bar: height 5px, bg T.bg
          // Fill: success (#13DEB9) when total===100 | error (#FA896B) when >100 | warning (#FFAE1F) when <100
          // transition: width 0.3s, background 0.2s
          "progressBar": {
            "height": 5,
            "background": "var(--edu-bg)",
            "fillSuccess": "var(--edu-success)",
            "fillWarning": "var(--edu-warning)",
            "fillError": "var(--edu-error)",
            "transition": "width 0.3s, background 0.2s",
            "widthCalc": "Math.min(total, 200)%"
          },

          // Add column button: full width, dashed top border, bg T.card, color pColor
          // padding 10px, 12.5px/800, icon "plus" 13px
          "addColumnButton": {
            "width": "100%",
            "padding": "10px",
            "borderTop": "1px dashed var(--edu-border)",
            "background": "var(--edu-card)",
            "color": "pColor",
            "fontSize": 12.5,
            "fontWeight": 800,
            "icon": "plus",
            "iconSize": 13
          }
        },

        // Weight ≠ 100 callout (Callout kind="error")
        // Shown below columnTable when !isHundred
        "weightValidation": {
          "trigger": "total weight !== 100",
          "calloutKind": "error",
          "titleVi": "Tổng trọng số phải bằng 100% (hiện tại {total}%)",
          "titleEn": "Total must equal 100% (currently {total}%)"
        },

        // Save row: marginTop 14, flex, gap 10
        // Button: variant=primary, disabled when !dirty OR !isHundred
        // Same success toast as grade scale section
        "saveRow": {
          "marginTop": 14,
          "gap": 10,
          "saveButton": {
            "variant": "primary",
            "icon": "check",
            "labelVi": "Lưu khung đánh giá",
            "labelEn": "Save scheme",
            "disabledWhen": "!dirty || !isHundred"
          },
          "successToast": {
            "samePatternAs": "leftColumn.saveRow.successToast",
            "labelVi": "Đã lưu khung đánh giá.",
            "labelEn": "Assessment scheme saved."
          }
        }
      }
    },

    // ── Token notes ───────────────────────────────────────────────────────────
    "tokens": {
      // T.teal = #00B8A9 — used as iconColor for AssessmentScheme section header
      // No new token needed; map to --edu-teal in tokens.css
      "tealIcon": "#00B8A9 (T.teal — AssessmentScheme section icon, --edu-teal)",
      // WCAG note: warning text on warningLight bg MUST use --edu-warning-foreground (#9A6A0F), NOT white
      "warningForeground": "#9A6A0F (noSubjects banner title — WCAG 4.5:1 on warningLight bg)",
      // Progress bar fill is conditional: success=100% | error>100% | warning<100%
      "progressFill": "conditional: success | warning | error based on weight sum vs 100"
    },

    // ── Responsive ────────────────────────────────────────────────────────────
    "responsive": {
      // 1024px+: two-column grid (4fr | 6fr) as designed
      // 768px (tablet): single column, leftColumn above rightColumn
      // 375px (mobile): single column, padding reduce to 16px 12px, pill rows scroll-x
      "breakpoints": {
        "1024": "grid 4fr/6fr — default",
        "768": "grid collapses to 1fr (stacked); left col above right col",
        "375": "padding: 16px 12px; preset pill rows: overflow-x: auto; min-width: 0 on pills"
      }
    },

    // ── Developer annotations ─────────────────────────────────────────────────
    "developerNotes": {
      // Components to reuse from design system / shared:
      "reuse": [
        "StatCard — not used here",
        "StatusBadge — not used here (badges are inline custom in this screen)",
        "ProgressBar — progress bar pattern matches shared ProgressBar but this instance is 5px height, inline in table",
        "Button (variant=primary/secondary) — reuse from components/ui/button",
        "Badge — reuse from components/ui/badge for ADMIN label"
      ],
      // New screen-local components (feature/presentation):
      "screenLocal": [
        "AsCard — section card wrapper (bg card, radius 14, shadow)",
        "AsSectionHeader — icon box + title + unsaved indicator",
        "AsPill — preset pill (active/inactive, title+subtitle)",
        "GradeScaleSection — left column; manages bands state",
        "BandRow — one grade band row in the band list",
        "AssessmentSchemeSection — right column; manages scheme state per subjectId",
        "SelectField — labeled select with chevron bg-image",
        "SchemeEditor — shown when subject+scheme exist; contains ColumnRow, totalRow, progressBar",
        "ColumnRow — one assessment column row",
        "LockedMeta — locked info tile (periods/year, exams/term)",
        "Callout — warning/error callout (gap/overlap/weight validation)",
        "NoSubjectsBanner — full-width warning when no subjects in catalogue",
        "NoSubjectPicked — empty state right col — no subject selected",
        "NoSchemeYet — empty state right col — no scheme for picked subject"
      ],
      // BE data shape consumed (mock-first per decision 0014 — core service not yet built):
      "beDataShape": {
        "subjectParents": "window.SM_SEED_PARENTS (shared from subjects screen) — list of {id, name, status, subjects: [{id, name, code, gradeLevel, periodCount, requiredAssessmentCount, status}]}",
        "gradeScale": "POST /admin/grade-scale — { presetId, bands: [{id, labelVi, labelEn, from, to, color}], domain }",
        "assessmentScheme": "POST /admin/assessment-scheme/{subjectId} — { presetId, columns: [{id, labelVi, labelEn, times, weight, kind}] }"
      },
      // Copy keys (i18n):
      "copyKeys": "assessmentScheme.* namespace — titles, labels, validation messages, CTA labels, preset descriptions"
    }
  },

  // ╔══════════════════════════════════════════════════════════════════════════╗
  // ║  TEACHING PLAN / PPCT                                                    ║
  // ║  Source: design_src/edu/teaching-plan.jsx (1108-line handoff, 1506)      ║
  // ║  Routes: /teacher/teaching-plan (edit) · /principal/teaching-plan (review)║
  // ║  Roles: teacher (compose + submit) · principal / admin (review + approve) ║
  // ║  US: US-E11.4 (implemented) — DR-003 reconciled 2026-06-20               ║
  // ║  Implementation: src/features/teaching-plan/                              ║
  // ║  i18n namespace: teachingPlan.*                                           ║
  // ╚══════════════════════════════════════════════════════════════════════════╝
  "teachingPlan": {
    "routes": {
      "teacher": "/teacher/teaching-plan",
      "principal": "/principal/teaching-plan",
      "admin": "/principal/teaching-plan"
    },
    "designFile": "design_src/edu/teaching-plan.jsx — TeachingPlanScreen (teacher) + TeachingPlanReviewScreen (principal)",
    "i18nNamespace": "teachingPlan",

    // ── Domain model ──────────────────────────────────────────────────────────
    // A plan = (teacher × subject × class × term) keyed by (classId|subjectId|termId).
    // Each plan row = (week × periodInWeek) → { title, learningObjective?, notes? }.
    // Status lifecycle: DRAFT → SUBMITTED → APPROVED | REJECTED → DRAFT (resubmit).
    "domainModel": {
      "planEntity": "src/features/teaching-plan/domain/entities/teaching-plan.entity.ts",
      "cellEntity": "src/features/teaching-plan/domain/entities/plan-cell.entity.ts",
      "statusType": "TeachingPlanStatus = 'DRAFT' | 'SUBMITTED' | 'APPROVED' | 'REJECTED'",
      "viewModel": "src/features/teaching-plan/presentation/teaching-plan-screen/teaching-plan-screen.i-vm.ts"
    },

    // ── Status chip colours (design_src/edu/teaching-plan.jsx TP_STATUS) ─────
    // All use bg = color/15 (canonical badge rule; design-system.md §Badge).
    "statusChip": {
      "DRAFT": {
        "color": "var(--edu-warning)",
        "bg": "var(--edu-warning)/15",
        "icon": "penLine"
      },
      "SUBMITTED": {
        "color": "var(--edu-info)",
        "bg": "var(--edu-info)/15",
        "icon": "send"
      },
      "APPROVED": {
        "color": "var(--edu-success)",
        "bg": "var(--edu-success)/15",
        "icon": "check"
      },
      "REJECTED": {
        "color": "var(--edu-error)",
        "bg": "var(--edu-error)/15",
        "icon": "alertTriangle"
      }
    },

    // ── Teacher screen — TeachingPlanScreen ──────────────────────────────────
    "teacherScreen": {
      // Page container: flex:1, overflowY:auto, padding:24px 32px, bg:var(--edu-bg)
      // Inner wrapper: maxWidth 1320, margin 0 auto
      "layout": {
        "pageContainer": {
          "flex": 1,
          "overflowY": "auto",
          "padding": "24px 32px",
          "background": "var(--edu-bg)"
        },
        "innerWrapper": {
          "maxWidth": 1320,
          "margin": "0 auto",
          "display": "flex",
          "flexDirection": "column",
          "gap": 16
        }
      },

      // ── Page header ───────────────────────────────────────────────────────
      "pageHeader": {
        "breadcrumb": {
          // fontSize 11, fontWeight 700, textMuted, uppercase, letterSpacing 0.07em
          "text": "teachingPlan.pageTitle label (PPCT)"
        },
        "title": {
          "fontSize": 22,
          "fontWeight": 800,
          "color": "var(--edu-text-primary)",
          "i18nKey": "teachingPlan.pageTitle"
        },
        "subtitle": {
          "fontSize": 12.5,
          "color": "var(--edu-text-muted)",
          "i18nKey": "teachingPlan.teacherSubtitle"
        },
        // Save-flash toast: inline pill top-right of header
        // approved → successLight/success; draft → primaryLight/primary
        "saveFlash": {
          "borderRadius": 99,
          "padding": "8px 14px",
          "fontSize": 12,
          "fontWeight": 700,
          "autoDismiss": "2200ms (draft) / 2400ms (submit)"
        }
      },

      // ── Selector bar ──────────────────────────────────────────────────────
      // Card shell: bg card, borderRadius 12, border 1px border, padding:14px 20px
      "selectorBar": {
        "layout": "flex row, gap 14, flexWrap:wrap",
        "cardShell": {
          "background": "var(--edu-card)",
          "borderRadius": 12,
          "border": "1px solid var(--edu-border)",
          "padding": "14px 20px"
        },
        "fields": [
          {
            "key": "class",
            "icon": "grid",
            "i18nKey": "teachingPlan.selector.class",
            "minWidth": 170
          },
          {
            "key": "subject",
            "icon": "bookOpen",
            "i18nKey": "teachingPlan.selector.subject",
            "minWidth": 180
          },
          {
            "key": "term",
            "icon": "calendar",
            "i18nKey": "teachingPlan.selector.term",
            "minWidth": 220
          }
        ],
        // Each select field: dropdown button, border 1.5px border, radius 8, 13px/700
        // Dropdown panel: radius 9, shadow 0 8px 24px rgba(0,0,0,0.12), maxHeight 280, overflowY auto
        // Active option: bg primary/12, color primary, fw700
        "selectField": {
          "button": {
            "border": "1.5px solid var(--edu-border)",
            "borderRadius": 8,
            "padding": "9px 12px",
            "fontSize": 13,
            "fontWeight": 700
          },
          "dropdownPanel": {
            "borderRadius": 9,
            "boxShadow": "0 8px 24px rgba(0,0,0,0.12)",
            "maxHeight": 280
          }
        }
      },

      // ── Status banners (approved / rejected) ─────────────────────────────
      // Shown above the plan table when plan exists and status is terminal.
      "statusBanners": {
        "shared": {
          "borderRadius": 12,
          "padding": "14px 18px",
          "iconBox": { "width": 38, "height": 38, "borderRadius": 10 }
        },
        "approved": {
          "background": "var(--edu-success-light)",
          "border": "1px solid var(--edu-success)40",
          "titleColor": "var(--edu-success)",
          "fontSize": 14,
          "fontWeight": 800,
          "i18nKey": "teachingPlan.actions.approveSuccess"
        },
        "rejected": {
          "background": "var(--edu-error-light)",
          "border": "1px solid var(--edu-error)40",
          "titleColor": "var(--edu-error)",
          "fontSize": 14,
          "fontWeight": 800,
          // Resubmit button: border 1.5px error, bg #fff, color error, radius 8, 12.5px/700
          "resubmitButton": {
            "border": "1.5px solid var(--edu-error)",
            "borderRadius": 8,
            "fontSize": 12.5,
            "fontWeight": 700,
            "i18nKey": "teachingPlan.rejection.editHint"
          }
        }
      },

      // ── Plan table (main content area) ────────────────────────────────────
      // Card shell wraps scrollable table; maxHeight: calc(100vh - 280px)
      "planTable": {
        "outerShell": {
          "background": "var(--edu-card)",
          "borderRadius": 12,
          "border": "1px solid var(--edu-border)",
          "boxShadow": "0 2px 12px rgba(0,0,0,0.04)",
          "overflow": "hidden"
        },
        "scrollArea": {
          "overflow": "auto",
          "maxHeight": "calc(100vh - 280px)"
        },
        "table": {
          "minWidth": 920,
          "borderCollapse": "separate",
          "borderSpacing": 0
        },
        "columns": [
          {
            "key": "week",
            "width": 64,
            "align": "center",
            "i18nKey": "teachingPlan.grid.weekLabel"
          },
          {
            "key": "period",
            "width": 64,
            "align": "center",
            "i18nKey": "teachingPlan.grid.periodLabel"
          },
          {
            "key": "lesson",
            "width": "28%",
            "align": "left",
            "i18nKey": "teachingPlan.cell.title"
          },
          {
            "key": "objectives",
            "width": "auto",
            "align": "left",
            "i18nKey": "teachingPlan.cell.learningObjective"
          },
          {
            "key": "notes",
            "width": "20%",
            "align": "left",
            "i18nKey": "teachingPlan.cell.notes"
          },
          {
            "key": "status",
            "width": 100,
            "align": "center",
            "i18nKey": "teachingPlan.actions.saveDraft"
          }
        ],
        "thead": {
          "padding": "11px 14px",
          "fontSize": 10.5,
          "fontWeight": 800,
          "color": "var(--edu-text-muted)",
          "letterSpacing": "0.06em",
          "textTransform": "uppercase",
          "borderBottom": "1px solid var(--edu-border)",
          "background": "var(--edu-bg)",
          "position": "sticky",
          "top": 0,
          "zIndex": 5
        },
        "td": {
          "padding": "12px 14px",
          "borderBottom": "1px solid var(--edu-border)",
          "verticalAlign": "middle"
        },
        // Row states
        "rowStates": {
          "filled": {
            "background": "var(--edu-card)",
            "cursor": "pointer",
            "hoverBackground": "subjectColor/06"
          },
          "empty": {
            "background": "#FAFBFD",
            "cursor": "pointer",
            "hoverBackground": "subjectColor/06"
          },
          "editing": {
            "background": "subjectColor/08"
            // Inline edit: lesson = <input>, objectives + notes = <textarea rows=2>
            // Save btn: bg subjectColor (disabled=textMuted), color #fff, radius 7, 11.5px/700
            // Cancel btn: border border, bg #fff, color textSecondary, radius 7
          },
          "readOnly": {
            "cursor": "default"
            // readOnly = true when status APPROVED or SUBMITTED (teacher view)
            // readOnly = true always in principal review
          }
        },
        // Cell fill badge
        "cellBadge": {
          "filled": {
            "background": "var(--edu-success-light)",
            "color": "var(--edu-success)",
            "icon": "check",
            "i18nKey": "teachingPlan.cell.save"
          },
          "empty": {
            "background": "var(--edu-bg)",
            "color": "var(--edu-text-muted)",
            "border": "1px dashed var(--edu-border)",
            "i18nKey": "teachingPlan.grid.emptyState"
          }
        }
      },

      // ── Right sidebar (progress + actions) ────────────────────────────────
      "progressSidebar": {
        "width": 280,
        "flexShrink": 0,
        "display": "flex",
        "flexDirection": "column",
        "gap": 14,

        // Panel 1: status + metadata card
        "statusMetaCard": {
          "padding": 16,
          "fields": [
            "status chip",
            "class",
            "subject",
            "term",
            "weeks",
            "periods/week"
          ]
        },

        // Panel 2: progress card
        "progressCard": {
          "padding": 16,
          "statValue": {
            "fontSize": 22,
            "fontWeight": 800,
            "color": "var(--edu-text-primary)"
          },
          "progressBar": {
            "height": 8,
            "color": "conditional: success when 100%, else subjectColor"
          },
          // Remaining hint: 11.5px, textMuted, shown when pct < 100 and not APPROVED
          "remainingHint": {
            "fontSize": 11.5,
            "color": "var(--edu-text-muted)"
          }
        },

        // Panel 3: week quick-jump
        "weekJump": {
          "grid": "5 columns, gap 4",
          "weekButton": {
            "padding": "7px 0",
            "borderRadius": 6,
            "fontSize": 11.5,
            "fontWeight": 800,
            "states": {
              "full": {
                "border": "success60",
                "bg": "var(--edu-success-light)",
                "color": "var(--edu-success)"
              },
              "partial": {
                "border": "subjectColor40",
                "bg": "subjectColor/0E",
                "color": "subjectColor"
              },
              "empty": {
                "border": "var(--edu-border)",
                "bg": "var(--edu-card)",
                "color": "var(--edu-text-muted)"
              }
            }
          }
        },

        // Panel 4: actions card (hidden when APPROVED)
        "actionsCard": {
          "padding": 16,
          "gap": 8,
          "copyPriorButton": {
            "border": "1.5px dashed var(--edu-border)",
            "borderRadius": 8,
            "fontSize": 12,
            "fontWeight": 700,
            "icon": "archive",
            "i18nKey": "teachingPlan.actions.saveDraft",
            "hoverBorder": "subjectColor"
          },
          // Resubmit (REJECTED state): primary bg, send icon
          "resubmitButton": {
            "background": "subjectColor",
            "borderRadius": 9,
            "fontSize": 13,
            "fontWeight": 700,
            "icon": "send",
            "i18nKey": "teachingPlan.actions.submit"
          },
          // Normal draft/submitted state: two buttons
          "saveDraftButton": {
            "border": "1.5px solid var(--edu-border)",
            "background": "var(--edu-card)",
            "borderRadius": 9,
            "fontSize": 13,
            "fontWeight": 700,
            "icon": "penLine",
            "disabled": "when status = SUBMITTED",
            "i18nKey": "teachingPlan.actions.saveDraft"
          },
          "submitButton": {
            "background": "subjectColor (disabled: var(--edu-text-muted))",
            "color": "#fff",
            "borderRadius": 9,
            "fontSize": 13,
            "fontWeight": 700,
            "icon": "send",
            "disabled": "when SUBMITTED or filled=0",
            "i18nKey": "teachingPlan.actions.submit"
          }
        }
      },

      // ── Screen states ─────────────────────────────────────────────────────
      "states": {
        "notStarted": {
          // Full-width card shell, textAlign center, padding 64px 24px
          "iconBox": {
            "width": 72,
            "height": 72,
            "borderRadius": 18,
            "background": "subjectColor/14",
            "icon": "calendar",
            "iconSize": 32
          },
          "title": {
            "fontSize": 17,
            "fontWeight": 800,
            "color": "var(--edu-text-primary)",
            "i18nKey": "teachingPlan.grid.emptyStateCta"
          },
          "subtitle": {
            "fontSize": 13,
            "color": "var(--edu-text-muted)",
            "maxWidth": 480
          },
          "buttons": [
            "create (primary, plus icon)",
            "copy from last year (secondary, archive icon)"
          ],
          "i18nKeys": "teachingPlan.grid.emptyState + teachingPlan.grid.emptyStateCta"
        },
        "loading": {
          // Skeleton: selector bar shimmer + table row skeletons (min 5 rows)
          "component": "teaching-plan-skeleton (mirroring GradeBookSkeleton pattern)"
        },
        "draft": {
          "description": "Plan exists, status=DRAFT. Table editable (click row to inline-edit). Sidebar: saveDraft + submit buttons active. No banner."
        },
        "submitted": {
          "description": "Status=SUBMITTED. Table read-only. saveDraft button disabled (opacity 0.5). Submit button shows 'Đã nộp — chờ duyệt'. No edit possible."
        },
        "approved": {
          "description": "Status=APPROVED. Table read-only. Banner success shown. Sidebar actions panel hidden. No inline edit.",
          "banner": "teachingPlan.actions.approveSuccess + approvedBy + approvedAt"
        },
        "rejected": {
          "description": "Status=REJECTED. Table editable (re-enter draft editing). Banner warning shows rejectionReason. Sidebar: 'Nộp lại kế hoạch' button. No saveDraft button.",
          "bannerFields": ["rejectedBy", "rejectedAt", "rejectionReason"],
          "i18nKey": "teachingPlan.rejection.bannerTitle + teachingPlan.rejection.reason"
        },
        "error": {
          "networkError": "teachingPlan.errors.network-error",
          "notFound": "teachingPlan.errors.not-found",
          "unauthorized": "teachingPlan.errors.unauthorized"
        }
      }
    },

    // ── Principal review screen — TeachingPlanReviewScreen ───────────────────
    "principalScreen": {
      // Two-panel master-detail layout
      "layout": {
        "pageContainer": {
          "flex": 1,
          "overflowY": "hidden",
          "padding": 0,
          "display": "flex",
          "flexDirection": "column"
        },
        "pageHeader": {
          "padding": "20px 32px 12px",
          "title": {
            "fontSize": 22,
            "fontWeight": 800,
            "color": "var(--edu-text-primary)"
          },
          "subtitle": { "fontSize": 12.5, "color": "var(--edu-text-muted)" },
          "i18nKey": "teachingPlan.principalSubtitle"
        },
        "body": {
          "display": "flex",
          "padding": "0 32px 24px",
          "gap": 16,
          "minHeight": 0
        },
        // Left panel: submission list
        "listPanel": {
          "width": 360,
          "flexShrink": 0,
          "borderRadius": 12,
          "border": "1px solid var(--edu-border)",
          "display": "flex",
          "flexDirection": "column",
          "overflow": "hidden"
        },
        // Right panel: read-only plan + review actions
        "detailPanel": {
          "flex": 1,
          "minWidth": 0,
          "display": "flex",
          "flexDirection": "column",
          "gap": 14,
          "overflow": "hidden"
        }
      },

      // ── Status filter tabs ─────────────────────────────────────────────────
      "filterTabs": {
        "container": {
          "padding": "12px 14px",
          "borderBottom": "1px solid var(--edu-border)"
        },
        "tab": {
          "padding": "5px 10px",
          "borderRadius": 99,
          "fontSize": 11.5,
          "fontWeight": 700
        },
        "tabActiveStyle": {
          "border": "1px solid subjectColor",
          "background": "subjectColor/12",
          "color": "subjectColor"
        },
        "tabCountBadge": {
          "borderRadius": 99,
          "padding": "0 6px",
          "fontSize": 10,
          "fontWeight": 800,
          "activeStyle": { "background": "subjectColor", "color": "#fff" }
        },
        "tabs": [
          { "id": "submitted", "i18nKey": "teachingPlan.status.SUBMITTED" },
          { "id": "approved", "i18nKey": "teachingPlan.status.APPROVED" },
          { "id": "rejected", "i18nKey": "teachingPlan.status.REJECTED" },
          { "id": "all", "i18nKey": "teachingPlan.principal.allTeachers" }
        ]
      },

      // ── Submission list item ──────────────────────────────────────────────
      "listItem": {
        "padding": "14px 18px",
        "borderBottom": "1px solid var(--edu-border)",
        "selectedStyle": {
          "background": "primaryColor/16"
        },
        "avatar": { "size": 32 },
        "teacherName": { "fontSize": 13, "fontWeight": 700 },
        "subjectClassTerm": {
          "fontSize": 11.5,
          "color": "var(--edu-text-muted)"
        },
        "miniProgressBar": { "height": 4 },
        "submittedAt": {
          "fontSize": 10.5,
          "color": "var(--edu-text-muted)",
          "i18nKey": "teachingPlan.principal.submittedAt"
        }
      },

      // ── Submission detail header ──────────────────────────────────────────
      "detailHeader": {
        "cardShell": { "padding": "16px 20px" },
        "avatar": { "size": 44 },
        "teacherName": { "fontSize": 15, "fontWeight": 800 },
        "progressStat": { "fontSize": 18, "fontWeight": 800 },
        // Rejection inline panel (below meta):
        "rejectionPanel": {
          "padding": "10px 14px",
          "background": "var(--edu-error-light)",
          "border": "1px solid var(--edu-error)30",
          "borderRadius": 9
        },
        // Approval inline note:
        "approvalNote": {
          "background": "var(--edu-success-light)",
          "border": "1px solid var(--edu-success)30",
          "borderRadius": 9
        }
      },

      // ── Review action buttons (submitted plans only) ───────────────────────
      "reviewActions": {
        "position": "bottom-right of detail header card, flexEnd",
        "requestChangesButton": {
          "border": "1.5px solid var(--edu-border)",
          "background": "var(--edu-card)",
          "borderRadius": 9,
          "padding": "9px 18px",
          "fontSize": 13,
          "fontWeight": 700,
          "icon": "alertTriangle",
          "i18nKey": "teachingPlan.actions.reject"
        },
        "approveButton": {
          "background": "var(--edu-success)",
          "color": "#fff",
          "borderRadius": 9,
          "padding": "9px 18px",
          "fontSize": 13,
          "fontWeight": 700,
          "icon": "check",
          "i18nKey": "teachingPlan.actions.approve"
        }
      },

      // ── Reject reason form (inline in detail header) ──────────────────────
      "rejectReasonForm": {
        "container": {
          "background": "var(--edu-bg)",
          "borderRadius": 9,
          "border": "1px solid var(--edu-border)",
          "padding": 14
        },
        "label": {
          "i18nKey": "teachingPlan.reject.reasonLabel",
          "required": true
        },
        "textarea": {
          "border": "1.5px solid var(--edu-border)",
          "borderRadius": 7,
          "fontSize": 12.5,
          "resize": "vertical",
          "i18nKey": "teachingPlan.reject.reasonPlaceholder"
        },
        "validation": {
          "minLength": 10,
          "i18nKey": "teachingPlan.reject.reasonMinLength"
        },
        "buttons": {
          "cancel": {
            "variant": "ghost",
            "i18nKey": "teachingPlan.reject.cancel"
          },
          "confirm": {
            "variant": "danger",
            "i18nKey": "teachingPlan.reject.confirm",
            "disabled": "when reason.trim() empty"
          }
        }
      },

      // ── Empty state (no submissions matching filter) ───────────────────────
      "emptyState": {
        "text": "teachingPlan.principal.emptyPending",
        "padding": 40,
        "textAlign": "center",
        "color": "var(--edu-text-muted)",
        "fontSize": 13
      },

      // ── No selection state (right panel) ──────────────────────────────────
      "noSelectionState": {
        "padding": 60,
        "textAlign": "center",
        "color": "var(--edu-text-muted)"
      }
    },

    // ── Shared component decisions ────────────────────────────────────────────
    "developerNotes": {
      // Components to reuse from design system / shared:
      "reuse": [
        "Avatar — initials avatar (size 32 / 44); from components/shared/avatar or feature-local",
        "ProgressBar — shared progress bar; height prop (4px list items, 8px sidebar)",
        "StatusBadge / TPStatusChip — feature-local chip wrapping icon + label; bg=color/15",
        "Button (variant=primary/secondary/ghost/danger) — components/ui/button"
      ],
      // Feature-local components (presentation layer):
      "screenLocal": [
        "TPSelectField — labeled select dropdown with icon (mirrors TTSelectField from timetable.jsx)",
        "TPStatusChip — status chip with icon; 3 sizes (sm/md)",
        "TPStatusBanner — approved/rejected full-width banner with icon box and resubmit CTA",
        "TPRow — inline-editable table row (read/edit mode); renders input+textareas in edit",
        "TPPlanTable — scrollable plan table; orchestrates TPRow list",
        "TPProgressSidebar — right rail: status meta + progress + week-jump + actions",
        "TPNotStarted — empty state card (notStarted status)",
        "TeachingPlanScreen — teacher route wrapper (class/subject/term state, plan CRUD)",
        "TeachingPlanReviewScreen — principal route wrapper (filter tabs, list/detail split)"
      ],
      // BE data shape (mock-first per decision 0014 — core service not yet built):
      "beDataShape": {
        "getTeachingPlan": "GET /teaching-plans?classId=&subjectId=&term= → TeachingPlan entity",
        "saveDraft": "PUT /teaching-plans/{id}/draft → updated TeachingPlan",
        "submit": "POST /teaching-plans/{id}/submit → TeachingPlan(status=SUBMITTED)",
        "approve": "POST /teaching-plans/{id}/approve → TeachingPlan(status=APPROVED)",
        "reject": "POST /teaching-plans/{id}/reject { reason } → TeachingPlan(status=REJECTED)",
        "listForPrincipal": "GET /teaching-plans?teacherId=&status= → TeachingPlan[]"
      },
      // Copy keys (i18n):
      "copyKeys": "teachingPlan.* namespace — all keys in src/bootstrap/i18n/messages/vi.json teachingPlan section",
      "i18nKeyCount": 52,
      // Accessibility notes (inherited from handoff, for /fe attention):
      "a11yNotes": [
        "TPSelectField button: needs aria-expanded, aria-haspopup='listbox'; dropdown items need role='option'",
        "TPRow inline edit: autoFocus on lesson input when entering edit mode (done in mockup); confirm with tab order",
        "Status-only conveyed by color in cell badge — icon (check/empty indicator) accompanies color (OK per design)",
        "Week jump buttons: title attribute present in mockup (tooltip); ensure keyboard reachable",
        "reject reason textarea: needs aria-required=true, aria-describedby pointing at validation message",
        "Approve/reject buttons: consider aria-label clarity ('Phê duyệt kế hoạch của {name}' vs generic)"
      ]
    },

    // ── Responsive ────────────────────────────────────────────────────────────
    "responsive": {
      "breakpoints": {
        "1320": "Default — full two-panel layout (teacher: table + 280px sidebar; principal: 360px list + flex detail)",
        "1024": "Table min-width 920 triggers horizontal scroll within card shell; sidebar stays 280px",
        "768": "teacher: sidebar moves below table (stacked); principal: list above detail (stacked); padding 16px 20px",
        "375": "padding 12px 16px; selector bar: flex-wrap forces vertical stack; sidebar gap 10px; table horizontal scroll"
      }
    }
  },

  // ╔══════════════════════════════════════════════════════════════════════════╗
  // ║  LESSON BANK — Kho bài giảng                                           ║
  // ║  Source: design_src/edu/lesson-bank.jsx (1506 handoff)                 ║
  // ║  Routes: /teacher/lesson-bank (upload + manage) · /principal/lesson-bank (read) ║
  // ║  Roles: teacher (upload + edit/delete own) · principal (school-wide read-only)  ║
  // ║  US: US-E11.2 (implemented, design-review APPROVED 2026-06-20)         ║
  // ║  Implementation: src/features/lesson-bank/                             ║
  // ║  i18n namespace: lessonBank.*                                          ║
  // ║  DR: DR-004 (reconciled 2026-06-20 — spec entry was the only gap)      ║
  // ╚══════════════════════════════════════════════════════════════════════════╝
  "lessonBank": {
    "routes": {
      "teacher": "/teacher/lesson-bank",
      "principal": "/principal/lesson-bank"
    },
    "designFile": "design_src/edu/lesson-bank.jsx — LessonBankScreen (teacher + principal role) + UploadLessonDrawer + LessonDetailSheet",
    "i18nNamespace": "lessonBank",
    "i18nKeyCount": 65, // keys in src/bootstrap/i18n/messages/vi.json lessonBank section
    "us": "US-E11.2",
    "designReviewVerdict": "APPROVED — docs/stories/epics/E11-lms-exams/US-E11.2-lesson-bank/design-review.md",

    // ── Page layout ───────────────────────────────────────────────────────────
    // LessonBankScreen: main flex:1, overflowY:auto, padding:24px 32px, background:var(--edu-bg)
    // Inner wrapper: maxWidth:1380, margin:0 auto, flex column, gap:16px
    "layout": {
      "pageContainer": {
        "padding": "24px 32px",
        "background": "var(--edu-bg)",
        "flex": 1,
        "overflowY": "auto"
      },
      "innerWrapper": {
        "maxWidth": 1380,
        "margin": "0 auto",
        "display": "flex",
        "flexDirection": "column",
        "gap": 16
      }
    },

    // ── Page header ───────────────────────────────────────────────────────────
    // Row: flex, alignItems:flex-end, gap:16, flexWrap:wrap
    // Left block: breadcrumb label (11px/700 muted uppercase tracking 0.07em) +
    //   page-title (22px/800 text-primary) + subtitle (12.5px muted)
    // Right block: "Của tôi / Toàn trường" owner toggle (teacher only) + "Thêm bài giảng" button
    "header": {
      "breadcrumbLabel": {
        "fontSize": 11,
        "fontWeight": 700,
        "color": "var(--edu-text-muted)",
        "textTransform": "uppercase",
        "letterSpacing": "0.07em"
      },
      "pageTitle": {
        "fontSize": 22,
        "fontWeight": 800,
        "color": "var(--edu-text-primary)",
        "marginTop": 4
      },
      "subtitle": {
        "fontSize": 12.5,
        "color": "var(--edu-text-muted)",
        "marginTop": 3
      },
      "ownerToggle": {
        "note": "Teacher role only — switches between 'Của tôi' (own lessons) and 'Toàn trường' (school-wide browse)",
        "borderRadius": 9,
        "border": "1.5px solid var(--edu-border)",
        "overflow": "hidden",
        "background": "var(--edu-card)",
        "activeBackground": "var(--edu-primary) + '14'",
        "activeColor": "var(--edu-primary)",
        "inactiveColor": "var(--edu-text-secondary)",
        "padding": "8px 14px",
        "fontSize": 12.5,
        "fontWeight": 700,
        "countBadge": {
          "padding": "1px 7px",
          "borderRadius": 99,
          "fontSize": 10,
          "fontWeight": 800
        }
      },
      "uploadButton": {
        "icon": "upload",
        "label": "lessonBank.uploadButton",
        "note": "Hidden in principal view — principal is read-only"
      }
    },

    // ── Filter bar ────────────────────────────────────────────────────────────
    // Card: background:var(--edu-card), borderRadius:12, border:1px solid var(--edu-border)
    // padding:14px 16px, flex row, gap:10, flexWrap:wrap
    "filterBar": {
      "container": {
        "background": "var(--edu-card)",
        "borderRadius": 12,
        "padding": "14px 16px",
        "gap": 10
      },
      "searchInput": {
        "flex": "1 1 240px",
        "minWidth": 200,
        "padding": "9px 12px 9px 34px",
        "borderRadius": 9,
        "border": "1.5px solid var(--edu-border)",
        "fontSize": 12.5,
        "icon": "search",
        "iconSize": 14,
        "placeholder": "lessonBank.filter.searchPlaceholder"
      },
      "subjectDropdown": {
        "minWidth": 170,
        "icon": "bookOpen",
        "label": "lessonBank.filter.subjectAriaLabel"
      },
      "gradeDropdown": {
        "minWidth": 140,
        "icon": "graduationCap",
        "label": "lessonBank.filter.allSubjects"
      },
      "sortDropdown": {
        "minWidth": 150,
        "icon": "layers",
        "options": ["newest", "name", "size"],
        "i18nKeys": "lessonBank.filter.sort.newest / .title-asc"
      },
      "viewToggle": {
        "borderRadius": 9,
        "border": "1.5px solid var(--edu-border)",
        "modes": ["grid", "list"],
        "activeBackground": "var(--edu-primary) + '14'",
        "activeColor": "var(--edu-primary)",
        "padding": "7px 12px",
        "fontSize": 11.5,
        "fontWeight": 700,
        "a11y": "role='group' + aria-label (lessonBank.filter.layoutAriaLabel)"
      }
    },

    // ── Lesson card (grid view) ───────────────────────────────────────────────
    // Grid: repeat(auto-fill, minmax(260px, 1fr)), gap:16px
    "gridCard": {
      "grid": {
        "templateColumns": "repeat(auto-fill, minmax(260px, 1fr))",
        "gap": 16
      },
      "card": {
        "background": "var(--edu-card)",
        "borderRadius": 12,
        "border": "1px solid var(--edu-border)",
        "boxShadow": "var(--edu-shadow-card)",
        "overflow": "hidden",
        "hoverTransform": "translateY(-2px)",
        "hoverShadow": "var(--edu-shadow-card-hover)",
        "hoverTransition": "transform 0.15s, box-shadow 0.15s"
      },
      "thumbnail": {
        "height": 140,
        "width": "100%",
        "borderRadius": "10px 10px 0 0",
        "background": "ft.color + '12'",
        "backgroundGradient": "linear-gradient(135deg, ft.color+'10' 0%, ft.color+'22' 100%)",
        "iconSize": 44,
        "iconStrokeWidth": 1.6,
        "fileTypeBadge": {
          "position": "absolute bottom:10px left:10px",
          "padding": "3px 8px",
          "borderRadius": 6,
          "background": "ft.color",
          "color": "#fff",
          "fontSize": 10,
          "fontWeight": 800
        },
        "subjectBadge": {
          "position": "absolute top:10px right:10px",
          "padding": "4px 10px",
          "borderRadius": 99,
          "background": "#fff",
          "fontSize": 10.5,
          "fontWeight": 700,
          "dotSize": 6
        },
        "videoPlayOverlay": {
          "circle": {
            "width": 44,
            "height": 44,
            "borderRadius": "50%",
            "background": "rgba(255,255,255,0.92)"
          },
          "iconSize": 18
        }
      },
      "cardBody": {
        "padding": 14,
        "flexGrow": 1,
        "gap": 8
      },
      "titleText": {
        "fontSize": 14,
        "fontWeight": 700,
        "lineClamp": 2,
        "color": "var(--edu-text-primary)"
      },
      "metaLine1": {
        "fontSize": 12,
        "color": "var(--edu-text-muted)",
        "subjectColor": "ft.color",
        "fontWeight": 700
      },
      "metaLine2": {
        "fontSize": 11,
        "color": "var(--edu-text-muted)",
        "icon": "upload",
        "iconSize": 10
      },
      "visibilityBadge": {
        "display": "inline-flex",
        "padding": "2px 8px",
        "borderRadius": 99,
        "background": "vis.color + '14'",
        "color": "vis.color",
        "fontSize": 10,
        "fontWeight": 700
      },
      "statsRow": {
        "fontSize": 10.5,
        "color": "var(--edu-text-muted)",
        "icons": ["eye", "download"]
      },
      "actionRow": {
        "marginTop": 6,
        "paddingTop": 10,
        "borderTop": "1px solid var(--edu-border)",
        "gap": 4,
        "buttons": {
          "view": {
            "color": "var(--edu-primary)",
            "icon": "eye",
            "label": "lessonBank.detail.edit → 'Xem'"
          },
          "edit": {
            "color": "var(--edu-text-secondary)",
            "icon": "penLine",
            "label": "'Sửa'",
            "note": "teacher + own lesson only"
          },
          "delete": {
            "color": "var(--edu-error)",
            "icon": "trash",
            "label": "'Xoá'",
            "note": "teacher + own lesson only"
          }
        },
        "buttonStyle": {
          "flex": 1,
          "padding": "6px 10px",
          "borderRadius": 6,
          "fontSize": 11.5,
          "fontWeight": 700
        }
      }
    },

    // ── List view ─────────────────────────────────────────────────────────────
    // Card wrapper: background:var(--edu-card), borderRadius:12, border:1px solid var(--edu-border), overflow:hidden
    // Row columns: 56px | 1fr | 120px | 110px | 100px | 110px | 200px (thumbnail | title | subject | grade | size | date | actions)
    "listView": {
      "wrapper": {
        "background": "var(--edu-card)",
        "borderRadius": 12,
        "border": "1px solid var(--edu-border)",
        "overflow": "hidden"
      },
      "header": {
        "fontSize": 10.5,
        "fontWeight": 800,
        "color": "var(--edu-text-muted)",
        "letterSpacing": "0.06em",
        "textTransform": "uppercase",
        "padding": "10px 16px",
        "background": "var(--edu-bg)",
        "borderBottom": "1px solid var(--edu-border)",
        "columns": [
          "(thumb)",
          "Tên bài giảng",
          "Môn",
          "Khối",
          "Dung lượng",
          "Tải lên",
          "Thao tác"
        ]
      },
      "row": {
        "gridTemplateColumns": "56px 1fr 120px 110px 100px 110px 200px",
        "gap": 14,
        "padding": "12px 16px",
        "borderBottom": "1px solid var(--edu-border)",
        "hoverBackground": "var(--edu-bg)",
        "transition": "background 0.12s"
      },
      "thumbnail": { "width": 56, "height": 56, "borderRadius": 8 }
    },

    // ── File-type vocabulary ──────────────────────────────────────────────────
    // Used for thumbnail background, icon, and badge color
    "fileTypes": {
      "pdf": { "color": "#E5363A", "icon": "fileText", "accept": ".pdf" },
      "pptx": { "color": "#D24726", "icon": "layers", "accept": ".ppt,.pptx" },
      "docx": {
        "color": "#2A6FDB",
        "icon": "fileText",
        "accept": ".doc,.docx"
      },
      "mp4": {
        "color": "#7B5EA7",
        "icon": "fileVideo",
        "accept": ".mp4,.mov,.webm"
      },
      "link": { "color": "#13DEB9", "icon": "externalLink", "accept": "" },
      "img": {
        "color": "#FFAE1F",
        "icon": "image",
        "accept": ".png,.jpg,.jpeg,.webp"
      }
    },

    // ── Visibility vocabulary ─────────────────────────────────────────────────
    "visibility": {
      "private": {
        "color": "var(--edu-text-secondary)",
        "icon": "lock",
        "i18nKey": "lessonBank.visibility.private"
      },
      "dept": {
        "color": "var(--edu-primary)",
        "icon": "users",
        "i18nKey": "lessonBank.visibility.dept"
      },
      "school": {
        "color": "var(--edu-success)",
        "icon": "globe",
        "i18nKey": "lessonBank.visibility.school"
      }
    },

    // ── Upload drawer ─────────────────────────────────────────────────────────
    // Right slide-in, 480px wide, animation lb-slide-in 0.22s ease-out
    // Triggered by FAB (bottom-right 56×56) or header "Thêm bài giảng" button
    "uploadDrawer": {
      "width": 480,
      "maxWidth": "100vw",
      "position": "fixed top:0 right:0 bottom:0",
      "background": "var(--edu-card)",
      "boxShadow": "-12px 0 40px rgba(0,0,0,0.18)",
      "animation": "lb-slide-in 0.22s ease-out",
      "overlay": {
        "background": "rgba(20,30,50,0.45)",
        "backdropFilter": "blur(2px)"
      },
      "header": {
        "padding": "18px 22px",
        "borderBottom": "1px solid var(--edu-border)",
        "iconBox": {
          "width": 36,
          "height": 36,
          "borderRadius": 10,
          "background": "var(--edu-primary)+'18'"
        },
        "title": { "fontSize": 15, "fontWeight": 800 },
        "subtitle": {
          "fontSize": 11.5,
          "color": "var(--edu-text-muted)",
          "marginTop": 2
        }
      },
      "body": { "padding": "20px 22px", "gap": 18 },
      "footer": {
        "padding": "14px 22px",
        "borderTop": "1px solid var(--edu-border)"
      },
      "lessonTypeToggle": {
        "note": "3-button grid: Tệp tin | Video | Liên kết — only shown on create (not edit)",
        "gridColumns": "repeat(3, 1fr)",
        "gap": 6,
        "activeButtonBorder": "1.5px solid var(--edu-primary)",
        "activeBackground": "var(--edu-primary)+'0E'",
        "fontSize": 12,
        "fontWeight": 700,
        "iconSize": 16
      },
      "dropZone": {
        "note": "Drag & drop area — shows file name + size once picked; clicking also triggers file picker",
        "border": "2px dashed var(--edu-border)",
        "activeBorder": "2px dashed var(--edu-primary)",
        "borderRadius": 10,
        "padding": "20px 18px",
        "textAlign": "center",
        "cursor": "pointer",
        "iconSize": 28,
        "titleFontSize": 13,
        "hintFontSize": 11.5,
        "acceptedTypes": "PDF, PPTX, DOCX, MP4 · tối đa 500 MB",
        "a11y": "Implement as <button type='button'> for native keyboard (Enter/Space); aria-label=lessonBank.upload.dropZoneAriaLabel"
      },
      "linkInput": {
        "placeholder": "https://…",
        "icon": "link",
        "iconSize": 14,
        "note": "Shown when Liên kết type selected; replaces drop zone"
      },
      "formFields": {
        "titleInput": {
          "maxLength": 200,
          "counterDisplay": true,
          "required": true
        },
        "subjectSelect": {
          "required": true,
          "options": "from SubjectOption[] in ViewModel"
        },
        "gradeSelect": { "required": true, "values": [10, 11, 12] },
        "tagsInput": {
          "required": false,
          "placeholder": "VD: Chương 1, Ôn tập, CT2018"
        },
        "visibilityRadioGroup": {
          "style": "stacked radio cards with icon + description per option",
          "borderActive": "1.5px solid vis.color",
          "backgroundActive": "vis.color + '0E'",
          "padding": "10px 12px",
          "borderRadius": 9
        }
      },
      "submitButton": {
        "states": {
          "createEnabled": "icon:upload + label:'Tải lên'",
          "editEnabled": "icon:check + label:'Lưu thay đổi'",
          "disabled": "title empty OR no file/link selected"
        }
      }
    },

    // ── FAB (floating action button) ──────────────────────────────────────────
    // Visible when drawer + detail sheet both closed; teacher role only
    "fab": {
      "size": 56,
      "borderRadius": "50%",
      "background": "var(--edu-primary)",
      "color": "#fff",
      "icon": "plus",
      "iconSize": 22,
      "iconStrokeWidth": 2.6,
      "position": "fixed bottom:28px right:28px",
      "zIndex": 60,
      "boxShadow": "0 8px 24px var(--edu-primary)+'55'",
      "hoverTransform": "scale(1.08)",
      "hoverShadow": "0 12px 28px var(--edu-primary)+'77'",
      "transition": "transform 0.15s, box-shadow 0.15s",
      "title": "Thêm bài giảng"
    },

    // ── Upload in-progress / error placeholder (grid card) ────────────────────
    "uploadPlaceholder": {
      "thumbnail": {
        "height": 140,
        "inProgress": {
          "background": "var(--edu-primary)+'08'",
          "icon": "upload",
          "iconSize": 36
        },
        "error": {
          "background": "var(--edu-error)+'08'",
          "icon": "alertTriangle",
          "iconSize": 36
        }
      },
      "progressBar": {
        "height": 6,
        "color": "var(--edu-primary)",
        "errorColor": "var(--edu-error)"
      },
      "border": {
        "inProgress": "1px dashed var(--edu-primary)",
        "error": "1px solid var(--edu-error)"
      },
      "actions": {
        "inProgress": [{ "label": "Huỷ", "color": "var(--edu-text-muted)" }],
        "error": [
          { "label": "Bỏ qua", "color": "var(--edu-text-muted)" },
          { "label": "Thử lại", "color": "var(--edu-error)", "icon": "upload" }
        ]
      }
    },

    // ── Detail sheet (read-only) ──────────────────────────────────────────────
    // Same slide-in pattern as upload drawer — 480px, lb-slide-in animation
    "detailSheet": {
      "width": 480,
      "animation": "lb-slide-in 0.22s ease-out",
      "header": {
        "padding": "16px 22px",
        "label": "lessonBank.detail.title",
        "fontSize": 10.5,
        "fontWeight": 800,
        "textTransform": "uppercase"
      },
      "preview": {
        "height": 220,
        "background": "linear-gradient(135deg, ft.color+'14' 0%, ft.color+'28' 100%)",
        "pdfPreview": {
          "width": 130,
          "height": 170,
          "background": "#fff",
          "borderRadius": 6,
          "boxShadow": "0 8px 24px rgba(0,0,0,0.16)",
          "padding": 14
        },
        "videoPreview": {
          "width": 200,
          "height": 130,
          "background": "#1F2937",
          "borderRadius": 8
        },
        "fileTypeBadge": {
          "position": "absolute top:14px left:14px",
          "padding": "4px 10px",
          "borderRadius": 6,
          "background": "ft.color",
          "color": "#fff",
          "fontSize": 10.5,
          "fontWeight": 800
        }
      },
      "subjectPill": {
        "display": "inline-flex",
        "padding": "3px 10px",
        "borderRadius": 99,
        "background": "subj.color+'14'",
        "color": "subj.color",
        "fontSize": 11,
        "fontWeight": 700,
        "dotSize": 6
      },
      "titleText": { "fontSize": 17, "fontWeight": 800, "lineHeight": 1.35 },
      "tagChips": {
        "padding": "3px 10px",
        "borderRadius": 99,
        "background": "var(--edu-bg)",
        "fontSize": 11,
        "fontWeight": 600,
        "border": "1px solid var(--edu-border)"
      },
      "statsGrid": {
        "columns": 3,
        "gap": 8,
        "cell": {
          "display": "flex",
          "alignItems": "center",
          "gap": 8,
          "padding": "10px 12px",
          "borderRadius": 9,
          "background": "var(--edu-bg)",
          "border": "1px solid var(--edu-border)"
        },
        "value": {
          "fontSize": 18,
          "fontWeight": 800,
          "color": "var(--edu-text-primary)"
        },
        "label": {
          "fontSize": 10,
          "fontWeight": 600,
          "color": "var(--edu-text-muted)",
          "textTransform": "uppercase"
        }
      },
      "metaTable": {
        "background": "var(--edu-bg)",
        "borderRadius": 10,
        "border": "1px solid var(--edu-border)",
        "padding": "12px 14px",
        "rowGap": 8,
        "fields": [
          "Người tải lên (Avatar + name)",
          "Ngày tải lên",
          "Tệp tin / URL",
          "Quyền xem"
        ]
      },
      "actionBar": {
        "padding": "14px 20px",
        "borderTop": "1px solid var(--edu-border)",
        "gap": 8,
        "buttons": {
          "download": {
            "icon": "download",
            "label": "lessonBank.detail.download",
            "variant": "secondary"
          },
          "copyLink": {
            "icon": "link",
            "label": "'Copy link'",
            "variant": "ghost"
          },
          "share": {
            "icon": "share2",
            "label": "'Chia sẻ'",
            "variant": "ghost"
          },
          "edit": {
            "icon": "penLine",
            "label": "lessonBank.detail.edit",
            "variant": "ghost",
            "note": "owner only"
          },
          "delete": {
            "icon": "trash",
            "label": "lessonBank.detail.delete",
            "color": "var(--edu-error)",
            "note": "owner only"
          }
        }
      }
    },

    // ── Delete confirm dialog ─────────────────────────────────────────────────
    "deleteDialog": {
      "style": "centered overlay modal (not sheet)",
      "width": 440,
      "maxWidth": "calc(100vw - 32px)",
      "borderRadius": 16,
      "background": "var(--edu-card)",
      "padding": "28px 28px 20px",
      "iconBox": {
        "size": 52,
        "borderRadius": 16,
        "background": "var(--edu-error)+'12'"
      },
      "title": {
        "fontSize": 17,
        "fontWeight": 800,
        "color": "var(--edu-text-primary)"
      },
      "body": {
        "fontSize": 13.5,
        "color": "var(--edu-text-muted)",
        "lineHeight": 1.6
      },
      "actions": {
        "cancelButton": {
          "label": "lessonBank.detail.confirmCancel",
          "variant": "secondary"
        },
        "deleteButton": {
          "label": "lessonBank.detail.confirmDelete",
          "color": "var(--edu-error)"
        }
      },
      "i18nKeys": "lessonBank.detail.confirmDeleteTitle / .confirmDeleteBody / .confirmDelete / .confirmCancel"
    },

    // ── Toast notifications ───────────────────────────────────────────────────
    "toast": {
      "position": "fixed bottom:24px left:50% transform:translateX(-50%)",
      "background": "#1F2937",
      "color": "#fff",
      "padding": "10px 18px",
      "borderRadius": 10,
      "fontSize": 13,
      "fontWeight": 600,
      "zIndex": 1100,
      "animation": "lb-toast-in 0.2s ease-out",
      "icon": "check",
      "iconColor": "var(--edu-success)",
      "messages": {
        "uploaded": "lessonBank.toast.uploaded",
        "deleted": "lessonBank.toast.deleted"
      }
    },

    // ── Empty states ──────────────────────────────────────────────────────────
    "emptyStates": {
      "noLessons": {
        "variant": "all",
        "icon": "bookOpen",
        "iconBoxSize": 96,
        "iconBoxBorderRadius": 24,
        "iconBoxBackground": "var(--edu-primary)+'0E'",
        "iconSize": 44,
        "iconColor": "var(--edu-primary)+'B0'",
        "title": "lessonBank.empty.title",
        "body": "lessonBank.empty.body",
        "cta": { "label": "lessonBank.empty.cta", "icon": "upload" },
        "border": "1px dashed var(--edu-border)"
      },
      "noMatch": {
        "variant": "filter",
        "title": "lessonBank.empty.noMatch",
        "body": "lessonBank.empty.noMatchBody",
        "cta": { "label": "'Bỏ lọc'", "icon": "x", "variant": "secondary" }
      }
    },

    // ── Skeleton state ────────────────────────────────────────────────────────
    "skeleton": {
      "a11y": "role='status' + sr-only text 'Đang tải...'",
      "grid": "repeat(auto-fill, minmax(260px, 1fr)) — same as populated grid",
      "cardHeight": 280,
      "animationClass": "animate-pulse"
    },

    // ── Role-variant summary ──────────────────────────────────────────────────
    "roleVariants": {
      "teacher": {
        "defaultOwnerFilter": "me (own lessons only on first load)",
        "ownerToggle": true,
        "canUpload": true,
        "canEdit": "own lessons only (currentUserId === lesson.teacherId)",
        "canDelete": "own lessons only",
        "visibilityFilter": "none — sees own (all visibilities) + others (dept/school only)",
        "showFAB": true
      },
      "principal": {
        "defaultOwnerFilter": "all — school-wide by default",
        "ownerToggle": false,
        "canUpload": false,
        "canEdit": false,
        "canDelete": false,
        "visibilityFilter": "visibility=school only (or dept within same department)",
        "showFAB": false,
        "note": "Upload / edit / delete buttons hidden; filter bar still active"
      }
    },

    // ── API contract (mock-first — lms service not yet shipped) ───────────────
    "api": {
      "note": "lms service — mock-first per decision 0014; US-053 BE deferred",
      "list": "GET  /lms/api/v1/lessons?visibility=&subjectId=&departmentId=&search=&sort=&cursor= → LessonEntity[]",
      "upload": "POST /lms/api/v1/lessons (multipart/form-data OR { url, title, … })",
      "update": "PUT  /lms/api/v1/lessons/:id",
      "delete": "DELETE /lms/api/v1/lessons/:id"
    },

    // ── Accessibility notes (for /fe implementation) ──────────────────────────
    "a11yNotes": [
      "Drop-zone: implement as <button type='button'> (not div role=button) — native keyboard (Enter/Space) + focus-visible:ring-ring. APPROVED in design-review.",
      "Drop-zone keyboard alternative: <input type='file'> hidden, triggered by button click — essential for keyboard-only users who cannot drag.",
      "Upload progress: when upload starts, inject aria-live='polite' region announcing progress (e.g. 'Đang tải lên 42%'); announce completion 'Đã thêm bài giảng'.",
      "View toggle (Grid/List): wrap in role='group' + aria-label (lessonBank.filter.layoutAriaLabel). APPROVED in design-review.",
      "Owner toggle (Của tôi / Toàn trường): role='group' + aria-label; active button aria-pressed=true.",
      "Lesson cards: interactive action buttons (Xem/Sửa/Xoá) need distinct aria-label including lesson title (e.g. 'Xoá bài giảng – Bài giảng Mệnh đề'). Do NOT rely on visual context alone.",
      "Detail sheet: focus-trap (Radix Sheet maintains this); on close return focus to trigger card.",
      "Delete dialog: modal with role='dialog', aria-modal='true', aria-labelledby=title; focus on 'Huỷ' on open (destructive default to safe action).",
      "Visibility radio group: stacked radio inputs (not div-based); label wraps radio + icon + text per option.",
      "Toast: role='status' + aria-live='polite' for success; role='alert' + aria-live='assertive' only for errors.",
      "Color-only status (file type badge color): file type label text always accompanies color — no pure-color-only information.",
      "File size display: ensure screen-reader-friendly format ('8.4 MB', not raw bytes or abbreviations without units)."
    ],

    // ── Responsive ────────────────────────────────────────────────────────────
    "responsive": {
      "breakpoints": {
        "1380": "Default — grid minmax(260px, 1fr) fills full width; list view all 7 columns visible",
        "1024": "Grid collapses to ~3 columns; list view action column may truncate edit/delete to icon-only",
        "768": "Grid 2 columns (minmax 240px); filter bar wraps — search full-width on own row; list view scrolls horizontally within card wrapper; upload drawer max-width 100vw",
        "375": "Grid 1 column; filter bar stacks vertically; padding 12px 16px; FAB stays bottom:28px right:16px; drawer full width"
      }
    }
  },

  // ╔══════════════════════════════════════════════════════════════════════════╗
  // ║  EXAM BANK + EXAM BUILDER                                               ║
  // ║  Routes: /teacher/exam-bank (list) · /teacher/exam-bank/create (build) ║
  // ║          /admin/exam-bank (aggregate)                                   ║
  // ║  Roles:  teacher (create/manage own) · admin/principal (read overview)  ║
  // ║  Story:  US-E11.3 (FE) — completed 2026-06-19                          ║
  // ║  JSX:    design_src/edu/exam-bank.jsx (edustaff_5 handoff, 1546 lines)  ║
  // ║  i18n namespace: examBank.*                                              ║
  // ╚══════════════════════════════════════════════════════════════════════════╝
  "examBank": {
    // ── Meta ─────────────────────────────────────────────────────────────────
    "story": "US-E11.3",
    "routes": [
      "/teacher/exam-bank",
      "/teacher/exam-bank/create",
      "/teacher/exam-bank/:id/edit",
      "/admin/exam-bank"
    ],
    "roles": ["teacher", "admin", "principal"],
    "designSrc": "design_src/edu/exam-bank.jsx",
    "i18nNamespace": "examBank",
    "i18nKeyCount": 71, // keys in src/bootstrap/i18n/messages/vi.json examBank section
    "status": "design-ready (reconciled DR-005, 2026-06-20)",
    "components": ["ExamBankScreen", "ExamBuilderScreen"],

    // ── SCREEN 1: Exam Bank List (/teacher/exam-bank, /admin/exam-bank) ──────
    "listScreen": {
      // ── Shell ───────────────────────────────────────────────────────────────
      "layout": "single-column, maxWidth 1280, margin 0 auto, padding 24px 32px, background var(--edu-bg)",
      "gap": 16,

      // ── Page header ─────────────────────────────────────────────────────────
      "pageHeader": {
        "display": "flex, alignItems flex-end, gap 16, flexWrap wrap",
        "breadcrumb": {
          "text": "examBank.title (Kho đề thi)",
          "fontSize": 11,
          "fontWeight": 700,
          "color": "var(--edu-text-muted)",
          "textTransform": "uppercase",
          "letterSpacing": "0.07em"
        },
        "title": {
          "teacher": {
            "i18nKey": "examBank.title",
            "text": "Kho đề thi của tôi"
          },
          "admin": {
            "i18nKey": "examBank.title",
            "text": "Kho đề thi toàn trường"
          },
          "fontSize": 22,
          "fontWeight": 800,
          "color": "var(--edu-text-primary)",
          "marginTop": 4
        },
        "subtitle": {
          "teacher": "Bạn có N đề · Toàn trường M đề.",
          "admin": "N đề từ tất cả giáo viên trong trường.",
          "fontSize": 12.5,
          "color": "var(--edu-text-muted)",
          "marginTop": 3
        },
        "ownerToggle": {
          "visibleFor": "teacher only",
          "options": ["me (Của tôi)", "all (Toàn trường)"],
          "display": "inline-flex, borderRadius 9, border 1.5px solid var(--edu-border), background #fff",
          "activeButton": {
            "background": "var(--edu-primary)+'14'",
            "color": "var(--edu-primary)",
            "fontWeight": 700
          },
          "inactiveButton": {
            "background": "transparent",
            "color": "var(--edu-text-secondary)"
          },
          "countBadge": {
            "padding": "1px 7px",
            "borderRadius": 99,
            "active": { "background": "var(--edu-primary)", "color": "#fff" },
            "inactive": {
              "background": "var(--edu-border)",
              "color": "var(--edu-text-secondary)"
            },
            "fontSize": 10,
            "fontWeight": 800
          },
          "a11y": "role='group' + aria-label; active button aria-pressed=true"
        },
        "createCTA": {
          "label": "examBank.createButton",
          "icon": "plus",
          "variant": "primary",
          "position": "top-right header area",
          "visibleFor": "teacher only"
        }
      },

      // ── Filter bar ──────────────────────────────────────────────────────────
      "filterBar": {
        "containerStyle": "white card, padding 14px 16px, borderRadius 12, border 1px solid var(--edu-border), boxShadow 0 2px 12px rgba(0,0,0,0.04)",
        "display": "flex, alignItems center, gap 10, flexWrap wrap",
        "search": {
          "flex": "1 1 240px",
          "minWidth": 220,
          "padding": "9px 12px 9px 34px",
          "borderRadius": 9,
          "border": "1.5px solid var(--edu-border)",
          "fontSize": 12.5,
          "leadingIcon": "search, size 14, color var(--edu-text-muted)",
          "placeholder": "examBank.filter.searchPlaceholder",
          "a11yLabel": "examBank.filter.searchAriaLabel"
        },
        "subjectDropdown": {
          "label": "examBank.filter.allSubjects",
          "icon": "bookOpen",
          "minWidth": 170,
          "options": "all + each subject from EB_SUBJECTS",
          "a11yLabel": "examBank.filter.subjectAriaLabel"
        },
        "gradeDropdown": {
          "icon": "graduationCap",
          "minWidth": 140,
          "options": "all + grades 10/11/12"
        },
        "examTypeDropdown": {
          "icon": "layers",
          "minWidth": 150,
          "options": [
            "all",
            "midterm (Giữa kỳ)",
            "final (Cuối kỳ)",
            "quiz (Thường xuyên)",
            "other (Khác)"
          ]
        },
        "teacherDropdown": {
          "visibleFor": "admin/principal only",
          "label": "examBank.filter.allTeachers",
          "a11yLabel": "examBank.filter.teacherAriaLabel",
          "options": "all + each teacher from school roster"
        },
        "statusSummary": {
          "display": "inline-flex, alignItems center, gap 8",
          "position": "right side of filter bar",
          "shows": "EBStatusChip for published + count, draft + count",
          "fontSize": 11.5,
          "color": "var(--edu-text-muted)"
        }
      },

      // ── Results heading ──────────────────────────────────────────────────────
      "resultsHeading": {
        "i18nKey": "examBank.resultsHeading",
        "text": "{count} đề thi",
        "fontSize": 12.5,
        "fontWeight": 600,
        "color": "var(--edu-text-secondary)"
      },

      // ── Exam card ────────────────────────────────────────────────────────────
      "examCard": {
        "layout": "flex row, alignItems flex-start, gap 16",
        "padding": "18px 20px",
        "borderRadius": 12,
        "border": "1px solid var(--edu-border)",
        "background": "var(--edu-card)",
        "boxShadow": "0 2px 12px rgba(0,0,0,0.04)",
        "hoverStyle": {
          "boxShadow": "0 8px 22px rgba(0,0,0,0.08)",
          "transform": "translateY(-1px)",
          "transition": "box-shadow 0.15s, transform 0.15s"
        },
        "iconBlock": {
          "size": "52x52",
          "borderRadius": 12,
          "background": "linear-gradient(135deg, examType.color+'1A' 0%, examType.color+'33' 100%)",
          "icon": "clipboardList, size 24, strokeWidth 1.7, color examType.color"
        },
        "body": {
          "header": {
            "title": {
              "fontSize": 14,
              "fontWeight": 800,
              "color": "var(--edu-text-primary)"
            },
            "statusChip": "EBStatusChip — see statusChip spec",
            "examTypeBadge": "EBTypeBadge — see typeBadge spec",
            "ownerAvatar": {
              "size": "28x28",
              "borderRadius": "50%",
              "background": "var(--edu-primary)+'18'",
              "fontSize": 10,
              "fontWeight": 800,
              "color": "var(--edu-primary)",
              "visibleFor": "admin/principal (shows teacher initials) or teacher when viewing 'all'"
            }
          },
          "metaRow": {
            "display": "flex, alignItems center, gap 12, flexWrap wrap",
            "items": [
              {
                "icon": "bookOpen",
                "text": "subj.vi (subject name)",
                "fontSize": 12
              },
              {
                "icon": "graduationCap",
                "text": "Lớp N (grade level)",
                "fontSize": 12
              },
              { "icon": "clock", "text": "N phút (duration)", "fontSize": 12 },
              {
                "icon": "helpCircle",
                "text": "N câu hỏi (question count)",
                "fontSize": 12
              }
            ],
            "iconSize": 12,
            "color": "var(--edu-text-muted)"
          },
          "secondaryRow": {
            "items": [
              {
                "text": "examBank.card.createdAt (Tạo ngày {date})",
                "fontSize": 11.5,
                "color": "var(--edu-text-muted)"
              },
              {
                "text": "Đã dùng: N lần (usedCount)",
                "fontSize": 11.5,
                "color": "var(--edu-text-muted)",
                "icon": "repeat"
              }
            ]
          }
        },
        "actions": {
          "position": "right side of card body",
          "teacher (isMine)": [
            "Xem/Chỉnh sửa (edit)",
            "Nhân bản (duplicate)",
            "Giao bài (assign)",
            "Xóa (delete — draft only)"
          ],
          "teacher (others)": [
            "Xem (view-only)",
            "Nhân bản (duplicate into own)"
          ],
          "admin/principal": ["Xem (view-only)"],
          "deleteButton": {
            "visibleWhen": "status === 'draft' AND isMine",
            "hiddenWhen": "published (cannot delete published)",
            "color": "var(--edu-error)",
            "a11yLabel": "Xoá đề thi – {title}"
          },
          "menuAriaLabel": "examBank.card.menuAriaLabel"
        }
      },

      // ── Status chip ──────────────────────────────────────────────────────────
      "statusChip": {
        "draft": {
          "background": "#FEF5E5",
          "color": "#FFAE1F",
          "icon": "penLine",
          "label": "examBank.status.draft"
        },
        "published": {
          "background": "#E6FFFA",
          "color": "var(--edu-success)",
          "icon": "check",
          "label": "examBank.status.published"
        },
        "padding": { "sm": "3px 8px", "md": "4px 11px" },
        "borderRadius": 99,
        "fontSize": { "sm": 10.5, "md": 11.5 },
        "fontWeight": 700,
        "display": "inline-flex, alignItems center, gap 5"
      },

      // ── Exam type badge ──────────────────────────────────────────────────────
      "typeBadge": {
        "padding": "3px 9px",
        "borderRadius": 6,
        "background": "examType.color+'15'",
        "color": "examType.color",
        "fontSize": 11,
        "fontWeight": 700,
        "display": "inline-flex, alignItems center, gap 4",
        "types": {
          "midterm": {
            "color": "var(--edu-primary)",
            "icon": "calendarDays",
            "label": "Giữa kỳ"
          },
          "final": { "color": "#7B5EA7", "icon": "award", "label": "Cuối kỳ" },
          "quiz": {
            "color": "var(--edu-success)",
            "icon": "clock",
            "label": "Thường xuyên"
          },
          "other": {
            "color": "var(--edu-text-muted)",
            "icon": "fileText",
            "label": "Khác"
          }
        }
      },

      // ── Dialogs ──────────────────────────────────────────────────────────────
      "deleteDialog": {
        "width": 440,
        "maxWidth": "calc(100vw - 32px)",
        "background": "var(--edu-card)",
        "borderRadius": 14,
        "boxShadow": "0 16px 48px rgba(0,0,0,0.24)",
        "padding": 24,
        "backdropBackground": "rgba(20,30,50,0.55)",
        "iconBlock": {
          "size": "44x44",
          "borderRadius": 12,
          "background": "var(--edu-error-light)",
          "icon": "trash, size 20, color var(--edu-error)"
        },
        "title": { "fontSize": 16, "fontWeight": 800 },
        "body": {
          "fontSize": 13,
          "lineHeight": 1.55,
          "color": "var(--edu-text-secondary)"
        },
        "actions": ["Huỷ (ghost)", "Xoá (danger, var(--edu-error))"],
        "animation": "eb-fadein 0.18s ease-out",
        "i18nKeys": {
          "title": "examBank.deleteDialog.title",
          "body": "examBank.deleteDialog.body",
          "cancel": "examBank.deleteDialog.cancel",
          "confirm": "examBank.deleteDialog.confirm",
          "deleting": "examBank.deleteDialog.deleting"
        },
        "a11y": "role='dialog', aria-modal=true, aria-labelledby=title; focus on Huỷ on open (safe default for destructive)"
      },
      "assignDialog": {
        "note": "Light placeholder — full assign flow lives in classops/exam-management",
        "width": 440,
        "icon": "send",
        "actions": ["Huỷ", "Tiếp tục giao bài (primary)"],
        "a11y": "role='dialog', aria-modal=true"
      },
      "publishDialog": {
        "width": 440,
        "i18nKeys": {
          "title": "examBank.publishDialog.title",
          "body": "examBank.publishDialog.body",
          "cancel": "examBank.publishDialog.cancel",
          "confirm": "examBank.publishDialog.confirm",
          "publishing": "examBank.publishDialog.publishing"
        }
      },

      // ── Toast ────────────────────────────────────────────────────────────────
      "toast": {
        "position": "fixed, bottom 24, left 50%, transform translateX(-50%)",
        "background": "#1F2937",
        "color": "#fff",
        "padding": "10px 18px",
        "borderRadius": 10,
        "fontSize": 13,
        "fontWeight": 600,
        "boxShadow": "0 8px 24px rgba(0,0,0,0.2)",
        "animation": "eb-toast-in 0.2s ease-out",
        "duration": "2400ms",
        "icon": "check, size 14, color var(--edu-success)",
        "a11y": "role='status' + aria-live='polite' for success; role='alert' for errors",
        "messages": {
          "deleted": "examBank.toast.deleted",
          "draftSaved": "examBank.toast.draftSaved",
          "published": "examBank.toast.published"
        }
      },

      // ── Empty states ─────────────────────────────────────────────────────────
      "emptyStates": {
        "noExams": {
          "variant": "all — no exams in bank yet",
          "icon": "clipboardList",
          "iconBoxSize": 80,
          "iconBoxBorderRadius": 20,
          "iconBoxBackground": "var(--edu-primary)+'0E'",
          "iconSize": 36,
          "iconColor": "var(--edu-primary)+'B0'",
          "title": "examBank.empty.title",
          "body": "examBank.empty.body",
          "cta": {
            "label": "examBank.empty.cta",
            "icon": "plus",
            "visibleFor": "teacher only"
          },
          "border": "1px dashed var(--edu-border)"
        },
        "noMatch": {
          "variant": "filter — filters applied but no results",
          "title": "examBank.empty.noMatch",
          "body": "examBank.empty.noMatchBody",
          "cta": { "label": "Bỏ lọc", "icon": "x", "variant": "secondary" }
        }
      },

      // ── Loading / skeleton state ──────────────────────────────────────────────
      "skeleton": {
        "a11y": "role='status' + sr-only 'Đang tải...' (i18nKey: examBank.loadingAriaLabel)",
        "cardCount": 3,
        "cardHeight": 100,
        "animationClass": "animate-pulse"
      }
    },

    // ── SCREEN 2: Exam Builder (/teacher/exam-bank/create, /:id/edit) ─────────
    "builderScreen": {
      // ── Shell ────────────────────────────────────────────────────────────────
      "layout": "full-height flex column, background var(--edu-bg), overflow hidden",
      "note": "Builder is full-screen — no sidebar padding. Navigation via top-bar back button.",

      // ── Top bar ──────────────────────────────────────────────────────────────
      "topBar": {
        "background": "var(--edu-card)",
        "borderBottom": "1px solid var(--edu-border)",
        "padding": "14px 24px",
        "display": "flex, alignItems center, gap 12",
        "elements": [
          {
            "name": "backButton",
            "label": "examBank.builder.back",
            "icon": "chevronLeft, size 12",
            "padding": "7px 12px",
            "borderRadius": 8,
            "border": "1px solid var(--edu-border)",
            "background": "#fff",
            "a11yLabel": "examBank.builder.backAriaLabel"
          },
          {
            "name": "titleBlock",
            "flex": 1,
            "breadcrumb": {
              "fontSize": 11,
              "fontWeight": 700,
              "color": "var(--edu-text-muted)",
              "textTransform": "uppercase"
            },
            "examTitle": {
              "fontSize": 16,
              "fontWeight": 800,
              "color": "var(--edu-text-primary)",
              "overflow": "hidden",
              "textOverflow": "ellipsis",
              "fallback": "— Chưa đặt tên đề — (examBank.builder.titlePlaceholder)"
            }
          },
          { "name": "statusChip", "ref": "statusChip spec above" },
          {
            "name": "unsavedIndicator",
            "visibleWhen": "isDirty === true (any edit not yet saved)",
            "display": "inline-flex, alignItems center, gap 5",
            "padding": "3px 9px",
            "borderRadius": 99,
            "background": "var(--edu-warning)+'18'",
            "color": "var(--edu-warning)",
            "fontSize": 10.5,
            "fontWeight": 800,
            "dot": {
              "size": "7x7",
              "borderRadius": "50%",
              "background": "var(--edu-warning)",
              "boxShadow": "0 0 0 3px var(--edu-warning)+'25'"
            },
            "label": "examBank.builder.saving (Chưa lưu)",
            "position": "absolute top 8 right 14 — inside metadata header"
          },
          {
            "name": "previewButton",
            "label": "examBank.builder.publish (Xem trước đề)",
            "icon": "eye, size 13",
            "padding": "9px 16px",
            "borderRadius": 8,
            "border": "1.5px solid var(--edu-primary)+'40'",
            "background": "var(--edu-primary)+'0E'",
            "color": "var(--edu-primary)"
          },
          {
            "name": "saveDraftButton",
            "label": "examBank.builder.saveDraft",
            "icon": "penLine, size 12",
            "padding": "9px 16px",
            "borderRadius": 8,
            "border": "1.5px solid var(--edu-border)",
            "background": "#fff",
            "color": "var(--edu-text-secondary)"
          },
          {
            "name": "publishButton",
            "label": "examBank.builder.publish",
            "icon": "check, size 13",
            "padding": "9px 18px",
            "borderRadius": 8,
            "background": {
              "enabled": "var(--edu-success)",
              "disabled": "var(--edu-text-muted)"
            },
            "color": "#fff",
            "disabled": "canPublish === false (validation incomplete)",
            "cursor": { "enabled": "pointer", "disabled": "not-allowed" }
          }
        ]
      },

      // ── Metadata header ────────────────────────────────────────────────────
      "metadataHeader": {
        "background": "var(--edu-card)",
        "borderBottom": "1px solid var(--edu-border)",
        "padding": "14px 24px",
        "display": "grid",
        "gridTemplateColumns": "2fr 1fr 1fr 1fr 1fr 1fr",
        "gap": 14,
        "fields": [
          {
            "key": "title",
            "label": "examBank.builder.titleLabel",
            "type": "text input",
            "maxLength": 200,
            "required": true,
            "placeholder": "examBank.builder.titlePlaceholder",
            "validation": "minLength 4, maxLength 200"
          },
          {
            "key": "subjectId",
            "label": "examBank.builder.subjectLabel",
            "type": "select",
            "placeholder": "examBank.builder.subjectPlaceholder",
            "options": "EB_SUBJECTS list"
          },
          {
            "key": "gradeLevel",
            "label": "Khối",
            "type": "select",
            "options": [10, 11, 12]
          },
          {
            "key": "examType",
            "label": "examBank.builder.difficultyLabel (Loại đề)",
            "type": "select",
            "options": "EB_EXAM_TYPES"
          },
          {
            "key": "durationMin",
            "label": "examBank.builder.durationLabel",
            "type": "number",
            "min": 5,
            "max": 240,
            "fontVariantNumeric": "tabular-nums"
          },
          {
            "key": "totalPoints",
            "label": "Tổng điểm",
            "type": "read-only computed (sum of all question points)",
            "display": "flex, alignItems center, gap 6",
            "icon": "award, size 14, color var(--edu-success)",
            "fontSize": 14,
            "fontWeight": 800,
            "background": "var(--edu-bg)",
            "border": "1.5px solid var(--edu-border)"
          }
        ],
        "fieldLabel": {
          "fontSize": 10.5,
          "fontWeight": 800,
          "color": "var(--edu-text-muted)",
          "textTransform": "uppercase",
          "letterSpacing": "0.07em",
          "marginBottom": 6
        },
        "fieldInput": {
          "padding": "9px 12px",
          "borderRadius": 8,
          "border": "1.5px solid var(--edu-border)",
          "fontSize": 13,
          "color": "var(--edu-text-primary)",
          "background": "#fff"
        }
      },

      // ── Two-column body ────────────────────────────────────────────────────
      "twoColumnBody": {
        "display": "flex, flex 1, minHeight 0, overflow hidden",
        "leftColumn": {
          "width": "30%",
          "minWidth": 280,
          "maxWidth": 380,
          "background": "var(--edu-card)",
          "borderRight": "1px solid var(--edu-border)",
          "display": "flex, flexDirection column, overflow hidden"
        },
        "rightColumn": {
          "flex": 1,
          "background": "var(--edu-bg)",
          "overflow": "auto",
          "padding": "20px 24px"
        }
      },

      // ── Question list (left column) ────────────────────────────────────────
      "questionList": {
        "header": {
          "padding": "14px 16px",
          "borderBottom": "1px solid var(--edu-border)",
          "title": {
            "i18nKey": "examBank.builder.questionsHeading",
            "text": "Câu hỏi ({count})",
            "fontSize": 13,
            "fontWeight": 800
          },
          "totalPoints": {
            "fontSize": 12,
            "color": "var(--edu-text-muted)",
            "fontVariantNumeric": "tabular-nums"
          }
        },
        "questionItem": {
          "padding": "10px 14px",
          "display": "flex, alignItems flex-start, gap 8",
          "selected": {
            "background": "var(--edu-primary)+'16'"
          },
          "unselected": {
            "background": "transparent"
          },
          "typePill": {
            "mcq": {
              "background": "var(--edu-primary)+'14'",
              "color": "var(--edu-primary)",
              "label": "TN"
            },
            "essay": {
              "background": "#7B5EA7+'14'",
              "color": "#7B5EA7",
              "label": "TL"
            },
            "fontSize": 9,
            "fontWeight": 800,
            "padding": "2px 6px",
            "borderRadius": 5
          },
          "prompt": {
            "fontSize": 11.5,
            "fontWeight": 500,
            "color": "var(--edu-text-primary)",
            "lineClamp": 2
          },
          "errorIndicator": {
            "visibleWhen": "question has validation error",
            "color": "var(--edu-error)",
            "icon": "alertCircle, size 12",
            "label": "examBank.builder.questionHasError"
          },
          "points": {
            "fontSize": 11,
            "color": "var(--edu-text-muted)",
            "fontVariantNumeric": "tabular-nums"
          },
          "reorderButtons": {
            "icons": ["chevronUp (move up)", "chevronDown (move down)"],
            "size": 12,
            "a11yLabels": [
              "examBank.moveUpAriaLabel",
              "examBank.moveDownAriaLabel"
            ],
            "note": "Keyboard reorder via Up/Down buttons — NO drag-and-drop dependency (ADR 0043)"
          },
          "deleteButton": {
            "icon": "trash, size 11",
            "color": "var(--edu-error)",
            "a11yLabel": "examBank.removeQuestionAriaLabel"
          }
        },
        "addQuestionBar": {
          "padding": "12px 14px",
          "borderTop": "1px solid var(--edu-border)",
          "buttons": [
            {
              "type": "mcq",
              "label": "examBank.builder.addQuestion + TN",
              "icon": "listChecks"
            },
            {
              "type": "essay",
              "label": "examBank.builder.addQuestion + TL",
              "icon": "penLine"
            }
          ],
          "buttonStyle": "secondary/ghost, full-width or split"
        }
      },

      // ── Question editor (right column) ─────────────────────────────────────
      "questionEditor": {
        "noSelection": {
          "display": "centered placeholder text",
          "i18nKey": "examBank.builder.noSelection",
          "text": "Chọn câu hỏi để chỉnh sửa",
          "color": "var(--edu-text-muted)"
        },
        "typeToggle": {
          "options": ["mcq (Trắc nghiệm)", "essay (Tự luận)"],
          "display": "radio-button group or toggle bar",
          "activeStyle": {
            "background": "var(--edu-primary)+'14'",
            "color": "var(--edu-primary)",
            "fontWeight": 700
          }
        },
        "promptField": {
          "label": "examBank.builder.contentLabel",
          "type": "textarea",
          "minHeight": 80,
          "placeholder": "examBank.builder.contentPlaceholder",
          "resize": "vertical"
        },
        "mcqOptions": {
          "count": 4,
          "letters": ["A", "B", "C", "D"],
          "optionRow": {
            "display": "flex, alignItems center, gap 8",
            "letterBox": {
              "width": 28,
              "height": 28,
              "borderRadius": 8,
              "fontSize": 12,
              "fontWeight": 800
            },
            "input": {
              "flex": 1,
              "fontSize": 13,
              "placeholder": "examBank.builder.optionPlaceholder"
            },
            "correctRadio": {
              "type": "radio button",
              "selected": {
                "letterBox": {
                  "background": "var(--edu-success)",
                  "color": "#fff",
                  "border": "1.5px solid var(--edu-success)"
                }
              },
              "unselected": {
                "letterBox": {
                  "background": "var(--edu-bg)",
                  "border": "1.5px solid var(--edu-border)"
                }
              },
              "a11yLabel": "examBank.builder.correctOptionAriaLabel"
            }
          }
        },
        "essayFields": {
          "hintField": {
            "label": "Gợi ý đáp án (ẩn với học sinh)",
            "type": "textarea",
            "placeholder": "Nhập gợi ý chấm điểm...",
            "background": "var(--edu-warning)+'0E'",
            "border": "1px solid var(--edu-warning)+'33'",
            "note": "Visible to teacher only; hidden from students during exam"
          }
        },
        "pointsField": {
          "label": "Điểm",
          "type": "number input",
          "min": 0.25,
          "step": 0.25,
          "fontVariantNumeric": "tabular-nums"
        }
      },

      // ── Preview modal ──────────────────────────────────────────────────────
      "previewModal": {
        "type": "full-screen overlay modal",
        "backdropBackground": "rgba(20,30,50,0.75)",
        "contentWidth": "min(820px, 100vw - 32px)",
        "maxHeight": "90vh",
        "overflow": "auto",
        "borderRadius": 16,
        "padding": 24,
        "background": "var(--edu-card)",
        "note": "Shows exam as student would see it — renders EBPreviewQuestion for each question",
        "mcqOptionPreview": {
          "selected/correct": {
            "background": "var(--edu-success-light)",
            "border": "1.5px solid var(--edu-success)"
          },
          "letterBox": { "width": 28, "height": 28, "borderRadius": 8 },
          "correctBadge": {
            "background": "var(--edu-success)",
            "color": "#fff",
            "fontSize": 10,
            "fontWeight": 800
          }
        },
        "essayAnswerArea": {
          "padding": "18px 16px",
          "borderRadius": 10,
          "border": "1.5px dashed var(--edu-border)",
          "background": "var(--edu-bg)",
          "color": "var(--edu-text-muted)",
          "fontStyle": "italic"
        },
        "essayHintBlock": {
          "background": "var(--edu-warning)+'0E'",
          "border": "1px solid var(--edu-warning)+'33'",
          "label": {
            "fontSize": 10.5,
            "fontWeight": 800,
            "color": "var(--edu-warning)",
            "icon": "info"
          }
        },
        "a11y": "role='dialog', aria-modal=true, focus-trap, close on Escape or backdrop click"
      },

      // ── Builder: empty-questions state ──────────────────────────────────────
      "emptyQuestionsState": {
        "note": "When all questions are deleted, auto-add blank MCQ — prevents truly empty question list",
        "behavior": "deleteQuestion() auto-adds ebBlankMCQ() when length reaches 0"
      },

      // ── Builder: validation state ────────────────────────────────────────────
      "validationState": {
        "canPublish": "title.length >= 4 AND durationMin in [5,240] AND all questions have non-empty prompt AND MCQ questions have at least 2 filled options",
        "publishBlockedIndicator": {
          "publishButton": "disabled, background var(--edu-text-muted), cursor not-allowed"
        },
        "saveFlashError": {
          "position": "inline near top-bar or below metadata header",
          "background": "var(--edu-error-light)",
          "color": "var(--edu-error)",
          "duration": "3200ms auto-dismiss"
        },
        "perQuestionError": {
          "indicator": "red alertCircle icon on question list item",
          "i18nKey": "examBank.builder.questionHasError"
        }
      }
    },

    // ── ADMIN VARIANT (/admin/exam-bank) ──────────────────────────────────────
    "adminVariant": {
      "route": "/admin/exam-bank",
      "roles": ["admin", "principal"],
      "subtitle": "examBank.subtitleAdmin — Xem toàn bộ đề thi trắc nghiệm của trường.",
      "differences": [
        "ownerToggle hidden (admin always sees all exams)",
        "createCTA hidden (admin/principal cannot create exams)",
        "teacherFilter shown in filter bar (filter by teacher)",
        "card actions: view-only (no edit/delete/assign)",
        "ownerAvatar always shown on cards (shows teacher initials)",
        "title: 'Kho đề thi toàn trường' vs teacher's 'Kho đề thi của tôi'"
      ],
      "filter": {
        "extraFilter": "teacherDropdown (allTeachers + each teacher)",
        "a11yLabel": "examBank.filter.teacherAriaLabel"
      }
    },

    // ── Role variants summary ─────────────────────────────────────────────────
    "roleVariants": {
      "teacher": {
        "defaultOwnerFilter": "me (own exams first)",
        "ownerToggle": true,
        "canCreate": true,
        "canEdit": "own exams only (ownerId === currentUserId)",
        "canDelete": "own draft exams only (status === 'draft')",
        "canDuplicate": true,
        "canAssign": "own published exams",
        "showBuilderRoute": true
      },
      "admin": {
        "defaultOwnerFilter": "all",
        "ownerToggle": false,
        "canCreate": false,
        "canEdit": false,
        "canDelete": false,
        "canDuplicate": false,
        "canAssign": false,
        "showBuilderRoute": false,
        "note": "Read-only aggregate view; builder route not accessible"
      },
      "principal": {
        "note": "Same as admin — read-only aggregate, no create/edit/delete"
      }
    },

    // ── API contract (mock-first — lms service not yet shipped) ──────────────
    "api": {
      "note": "lms service — mock-first per decision 0014; US-054/055 BE deferred",
      "list": "GET  /lms/api/v1/exams?ownerId=&subjectId=&gradeLevel=&examType=&search=&cursor= → ExamEntity[]",
      "create": "POST /lms/api/v1/exams (ExamPayload)",
      "update": "PUT  /lms/api/v1/exams/:id",
      "delete": "DELETE /lms/api/v1/exams/:id",
      "publish": "PATCH /lms/api/v1/exams/:id/publish"
    },

    // ── Accessibility notes (for /fe implementation) ───────────────────────────
    "a11yNotes": [
      "Question reorder: implemented via Up/Down buttons (NOT drag-and-drop) per ADR 0043 — buttons must have distinct aria-labels with question index (examBank.moveUpAriaLabel / moveDownAriaLabel).",
      "Owner toggle: role='group' + aria-label; active button aria-pressed=true.",
      "Exam cards: action buttons need distinct aria-label including exam title (e.g. 'Xoá đề thi – Kiểm tra Giữa kỳ 1 — Toán lớp 10'). Do NOT rely on visual context alone.",
      "Delete / Publish / Assign dialogs: role='dialog', aria-modal=true, aria-labelledby=title; focus on 'Huỷ' on open (safe default for destructive actions).",
      "MCQ correct-answer radio: each option row has radio input with aria-label (examBank.builder.correctOptionAriaLabel replacing {option} with letter); correct state conveyed by both visual highlight AND icon, not color alone.",
      "Preview modal: role='dialog', aria-modal=true, focus-trap (Radix Dialog or custom); close on Escape + backdrop click; on close return focus to Preview button.",
      "Warning for unsaved changes: 'Chưa lưu' indicator is visual-only — add aria-live='polite' region that announces when isDirty becomes true ('Có thay đổi chưa lưu').",
      "Essay hint block: 'Gợi ý chấm (ẩn với HS)' — label text must be present (not color-only); conveyed by warning icon + text label.",
      "Publish button disabled state: aria-disabled=true + tooltip/title explaining why (validation incomplete).",
      "Toast: role='status' + aria-live='polite' for success toasts; role='alert' + aria-live='assertive' for error flash messages.",
      "Filter dropdowns: implement as native <select> or Radix Select with aria-label; keyboard-navigable.",
      "Builder two-column layout: aside role='complementary' (question list) + main role='main' (editor); aria-label each region."
    ],

    // ── Responsive ─────────────────────────────────────────────────────────────
    "responsive": {
      "listScreen": {
        "1280": "Default — exam cards full width (single column list); filter bar all controls on one row",
        "1024": "Filter bar may wrap; status summary moves below dropdowns",
        "768": "Filter bar wraps: search full-width; dropdowns stack 2-per-row; card actions collapse to icon-only menu",
        "375": "Filter bar stacks vertically; card actions in dropdown menu (3-dot); padding 12px 16px"
      },
      "builderScreen": {
        "1280": "Default — left 30% (280-380px) / right 70% two-column split; metadata header 6-column grid",
        "1024": "Left column min 260px; metadata grid may wrap to 3+3",
        "768": "Two-column collapses to single column: question list becomes collapsible drawer (Radix Sheet or accordion); metadata header stacks 2-per-row",
        "375": "Metadata header stacks vertically (1 field per row); question list full-width above editor"
      }
    }
  },

  // ── Announcements ─────────────────────────────────────────────────────────────
  // Source: design_src/edu/announcements.jsx (1506 handoff)
  // Story: US-E10.3 (implemented)
  // Roles: admin / principal (create + manage); all roles receive via Notifications Center (DR-006)
  // Routes: /admin/announcements · /principal/announcements
  // DR: docs/design-requests/DR-007-announcements.md (reconcile 2026-06-20)
  "announcements": {
    // ── Page layout ──────────────────────────────────────────────────────────────
    "page": {
      "padding": "28px 32px 40px",
      "maxWidth": 1120,
      "margin": "0 auto",
      "background": "var(--edu-bg)"
    },

    // ── Breadcrumb ───────────────────────────────────────────────────────────────
    "breadcrumb": {
      "fontSize": 12.5,
      "color": "var(--edu-text-muted)",
      "marginBottom": 12,
      "homeIcon": { "name": "home", "size": 12 },
      "separator": { "name": "chevronRight", "size": 11 },
      "activeColor": "var(--edu-text-primary)",
      "activeFontWeight": 700
    },

    // ── Title row ────────────────────────────────────────────────────────────────
    "titleRow": {
      "marginBottom": 22,
      "gap": 14,
      "iconBox": {
        "size": 44,
        "borderRadius": 12,
        "background": "primaryColor + '18'",
        "icon": "megaphone",
        "iconSize": 22,
        "iconColor": "primaryColor",
        "iconStrokeWidth": 1.8
      },
      "title": {
        "fontSize": 22,
        "fontWeight": 800,
        "color": "var(--edu-text-primary)"
      },
      "subtitle": {
        "fontSize": 13,
        "color": "var(--edu-text-muted)",
        "marginTop": 2
      },
      "roleChip": {
        "color": "var(--edu-error)",
        "text": "ADMIN · BGH",
        "icon": "shield",
        "iconSize": 11,
        "iconStrokeWidth": 2.4
      },
      "ctaButton": {
        "variant": "primary",
        "icon": "plus",
        "labelKey": "announcements.createButton"
      }
    },

    // ── Status filter pills ───────────────────────────────────────────────────────
    "filterPills": {
      "container": {
        "background": "var(--edu-card)",
        "borderRadius": 12,
        "border": "1px solid var(--edu-border)",
        "shadow": "0 2px 12px rgba(0,0,0,0.04)",
        "padding": 8,
        "gap": 8
      },
      "pill": {
        "padding": "7px 13px",
        "borderRadius": 8,
        "fontSize": 12.5,
        "inactiveFontWeight": 600,
        "activeFontWeight": 800,
        "activeBorder": "1.5px solid <pillColor>",
        "activeBackground": "<pillColor> + '14'",
        "inactiveBorder": "1.5px solid transparent"
      },
      "countBadge": {
        "fontSize": 10.5,
        "fontWeight": 800,
        "padding": "1px 7px",
        "borderRadius": 99,
        "minWidth": 16
      },
      "filters": [
        {
          "id": "all",
          "labelKey": "announcements.filterAll",
          "color": "primaryColor",
          "icon": null
        },
        {
          "id": "sent",
          "labelKey": "announcements.filterSent",
          "color": "var(--edu-success)",
          "icon": "check"
        },
        {
          "id": "scheduled",
          "labelKey": "announcements.filterScheduled",
          "color": "var(--edu-primary)",
          "icon": "clock"
        },
        {
          "id": "draft",
          "labelKey": "announcements.filterDraft",
          "color": "var(--edu-warning)",
          "icon": "penLine"
        }
      ]
    },

    // ── Announcement card (list item) ────────────────────────────────────────────
    "announcementCard": {
      "background": "var(--edu-card)",
      "borderRadius": 12,
      "border": {
        "default": "1px solid var(--edu-border)",
        "draft": "1px solid var(--edu-warning) + '44'"
      },
      "shadow": "0 2px 12px rgba(0,0,0,0.04)",
      "padding": "18px 22px",
      "overflow": "hidden",

      "urgentAccentBar": {
        "width": 4,
        "position": "absolute left 0, top 0, bottom 0",
        "background": "var(--edu-error)",
        "visibleWhen": "priority === 'urgent'"
      },

      "layout": "flex row — iconBox | content flex-1 | actions column",
      "gap": 14,

      "iconBox": {
        "size": 40,
        "borderRadius": 10,
        "background": "priorityColor + '18'",
        "icon": "megaphone",
        "iconSize": 19,
        "iconStrokeWidth": 2
      },

      "title": {
        "fontSize": 15,
        "fontWeight": 800,
        "color": "var(--edu-text-primary)"
      },

      "priorityBadge": {
        "priorities": {
          "normal": {
            "color": "var(--edu-text-secondary)",
            "bg": "var(--edu-bg)",
            "icon": "bell",
            "labelKey": "announcements.priorityNormal"
          },
          "important": {
            "color": "var(--edu-warning)",
            "bg": "var(--edu-warning)/15",
            "icon": "alertTriangle",
            "labelKey": "announcements.priorityImportant"
          },
          "urgent": {
            "color": "var(--edu-error)",
            "bg": "var(--edu-error)/15",
            "icon": "alertTriangle",
            "labelKey": "announcements.priorityUrgent"
          }
        }
      },

      "statusBadge": {
        "statuses": {
          "draft": {
            "color": "var(--edu-warning)",
            "bg": "var(--edu-warning)/15",
            "icon": "penLine",
            "labelKey": "announcements.statusDraft"
          },
          "scheduled": {
            "color": "var(--edu-primary)",
            "bg": "var(--edu-primary)/15",
            "icon": "clock",
            "labelKey": "announcements.statusScheduled"
          },
          "sent": {
            "color": "var(--edu-success)",
            "bg": "var(--edu-success)/15",
            "icon": "check",
            "labelKey": "announcements.statusSent"
          }
        }
      },

      "meta": {
        "fontSize": 12.5,
        "color": "var(--edu-text-muted)",
        "gap": 8,
        "audienceIcon": "users",
        "audienceIconSize": 11,
        "timeIcon": "clock",
        "timeIconSize": 11,
        "authorIcon": "userCheck",
        "authorIconSize": 11,
        "dotSeparator": {
          "width": 3,
          "height": 3,
          "borderRadius": "50%",
          "background": "var(--edu-border)"
        }
      },

      "readReceiptStrip": {
        "visibleWhen": "status === 'sent'",
        "background": "var(--edu-bg)",
        "borderRadius": 8,
        "border": "1px solid var(--edu-border)",
        "padding": "8px 12px",
        "gap": 14,
        "progressBar": {
          "height": 6,
          "trackBackground": "var(--edu-border)",
          "fillColor": "var(--edu-success)",
          "borderRadius": 99,
          "transition": "width 0.3s"
        }
      },

      "draftNotice": {
        "visibleWhen": "status === 'draft'",
        "background": "var(--edu-warning)/15",
        "border": "1px solid var(--edu-warning) + '33'",
        "borderRadius": 7,
        "padding": "6px 10px",
        "fontSize": 11.5,
        "color": "var(--edu-warning-foreground)",
        "fontStyle": "italic",
        "icon": "alertTriangle",
        "iconColor": "var(--edu-warning)"
      },

      "actions": {
        "layout": "flex column align-end",
        "gap": 7,
        "viewDetail": {
          "variant": "primary",
          "icon": "eye",
          "size": "sm",
          "visibleWhen": "status !== 'draft'"
        },
        "editDraft": {
          "variant": "primary",
          "icon": "penLine",
          "size": "sm",
          "visibleWhen": "status === 'draft'"
        },
        "delete": {
          "variant": "ghost",
          "icon": "x",
          "size": "sm",
          "color": "var(--edu-error)",
          "border": "1px solid var(--edu-border)"
        }
      }
    },

    // ── Empty states ──────────────────────────────────────────────────────────────
    "emptyState": {
      "background": "var(--edu-card)",
      "borderRadius": 12,
      "border": "1px dashed var(--edu-border)",
      "padding": "52px 24px",
      "textAlign": "center",
      "icon": {
        "name": "megaphone",
        "size": 40,
        "color": "var(--edu-border)",
        "strokeWidth": 1.6
      },
      "title": {
        "fontSize": 14,
        "fontWeight": 800,
        "color": "var(--edu-text-secondary)",
        "marginTop": 12
      },
      "body": {
        "fontSize": 12,
        "color": "var(--edu-text-muted)",
        "marginBottom": 18
      },
      "variants": {
        "all": {
          "titleKey": "announcements.emptyTitle",
          "bodyKey": "announcements.emptyBody",
          "cta": {
            "variant": "primary",
            "icon": "plus",
            "labelKey": "announcements.createButton"
          }
        },
        "filter": {
          "cta": {
            "variant": "ghost",
            "border": "1px solid var(--edu-border)",
            "color": "var(--edu-text-secondary)"
          }
        }
      }
    },

    // ── Loading state ─────────────────────────────────────────────────────────────
    "loadingState": {
      "ariaLabel": "announcements.loadingAriaLabel",
      "skeletonCards": 3,
      "skeletonHeight": 90,
      "skeletonBorderRadius": 12,
      "skeletonBackground": "var(--edu-border)"
    },

    // ── Error state ───────────────────────────────────────────────────────────────
    "errorState": {
      "messageKey": "announcements.loadError",
      "icon": "alertTriangle",
      "color": "var(--edu-error)"
    },

    // ── Create / Edit drawer ──────────────────────────────────────────────────────
    "createDrawer": {
      "width": 480,
      "maxWidth": "100vw",
      "position": "fixed right 0, top 0, bottom 0",
      "background": "var(--edu-card)",
      "shadow": "-12px 0 40px rgba(0,0,0,0.18)",
      "zIndex": 1001,
      "animation": "slideInFromRight 0.22s ease-out",
      "scrim": {
        "background": "rgba(20,30,50,0.45)",
        "backdropFilter": "blur(2px)",
        "zIndex": 1000
      },

      "header": {
        "padding": "18px 22px",
        "borderBottom": "1px solid var(--edu-border)",
        "iconBox": {
          "size": 36,
          "borderRadius": 10,
          "background": "primaryColor + '18'"
        },
        "icon": "megaphone",
        "iconSize": 17,
        "titleFontSize": 16,
        "titleFontWeight": 800,
        "subtitleFontSize": 11.5,
        "subtitleColor": "var(--edu-text-muted)",
        "closeButton": { "icon": "x", "size": 16 }
      },

      "body": { "padding": "20px 22px", "gap": 14 },

      "fields": {
        "fieldLabel": {
          "fontSize": 10.5,
          "fontWeight": 800,
          "color": "var(--edu-text-muted)",
          "letterSpacing": "0.08em",
          "textTransform": "uppercase",
          "marginBottom": 6
        },
        "input": {
          "padding": "10px 12px",
          "borderRadius": 8,
          "border": "1.5px solid var(--edu-border)",
          "background": "var(--edu-card)",
          "fontSize": 13.5,
          "color": "var(--edu-text-primary)",
          "focusBorder": "1.5px solid primaryColor"
        },
        "charCount": {
          "fontSize": 10.5,
          "fontWeight": 700,
          "marginTop": 5,
          "okColor": "var(--edu-success)",
          "pendingColor": "var(--edu-text-muted)",
          "nearLimitColor": "var(--edu-warning)",
          "nearLimitThreshold": "90% of max"
        },

        "titleField": {
          "type": "input",
          "maxLength": 200,
          "minLength": 5,
          "labelKey": "announcements.fieldTitle",
          "placeholderKey": "announcements.fieldTitlePlaceholder",
          "required": true
        },

        "bodyField": {
          "type": "textarea",
          "rows": 5,
          "maxLength": 2000,
          "minLength": 10,
          "labelKey": "announcements.fieldBody",
          "placeholderKey": "announcements.fieldBodyPlaceholder",
          "resize": "vertical",
          "lineHeight": 1.55,
          "required": true
        },

        "audienceField": {
          "labelKey": "announcements.fieldAudience",
          "required": true,
          "presetChips": {
            "display": "flex wrap",
            "gap": 7,
            "chip": {
              "padding": "6px 11px",
              "borderRadius": 99,
              "activeBorder": "1.5px solid primaryColor",
              "activeBackground": "primaryColor + '14'",
              "activeColor": "primaryColor",
              "inactiveBorder": "1.5px solid var(--edu-border)",
              "fontSize": 12,
              "fontWeight": 700
            },
            "presets": [
              {
                "id": "all",
                "labelKey": "announcements.audienceAll",
                "icon": "users",
                "est": 1280,
                "exclusive": true
              },
              {
                "id": "teachers",
                "labelKey": "announcements.audienceTeachers",
                "icon": "userCheck",
                "est": 42
              },
              {
                "id": "parents",
                "labelKey": "announcements.audienceParents",
                "icon": "users",
                "est": 768
              },
              {
                "id": "students",
                "labelKey": "announcements.audienceStudents",
                "icon": "graduationCap",
                "est": 480
              }
            ]
          },
          "gradeFilter": {
            "collapsible": true,
            "labelKey": "announcements.fieldGradeFilter",
            "grades": [10, 11, 12],
            "chip": {
              "padding": "5px 12px",
              "borderRadius": 7,
              "fontSize": 12,
              "fontWeight": 700
            }
          },
          "classFilter": {
            "source": "window.ROSTER_CLASSES (exported by roster.jsx)",
            "chip": {
              "padding": "5px 11px",
              "borderRadius": 7,
              "fontSize": 12,
              "fontWeight": 700
            }
          },
          "estimateStrip": {
            "background": "primaryColor + '08'",
            "border": "1px solid primaryColor + '33'",
            "borderRadius": 8,
            "padding": "8px 12px",
            "fontSize": 12,
            "labelKey": "announcements.estimatedRecipients",
            "valueColor": "primaryColor",
            "valueFontWeight": 800
          }
        },

        "priorityField": {
          "labelKey": "announcements.fieldPriority",
          "required": true,
          "type": "radioGroup",
          "options": [
            {
              "value": "normal",
              "labelKey": "announcements.priorityNormal",
              "color": "var(--edu-text-secondary)",
              "icon": "bell"
            },
            {
              "value": "important",
              "labelKey": "announcements.priorityImportant",
              "color": "var(--edu-warning)",
              "icon": "alertTriangle"
            },
            {
              "value": "urgent",
              "labelKey": "announcements.priorityUrgent",
              "color": "var(--edu-error)",
              "icon": "alertTriangle"
            }
          ],
          "radioButton": {
            "flex": 1,
            "minWidth": 100,
            "padding": "8px 11px",
            "borderRadius": 8,
            "activeBorder": "1.5px solid <optionColor>",
            "activeBackground": "<optionColor> + '12'",
            "radioCircleSize": 18,
            "radioCircleBorder": "2px solid <optionColor>",
            "radioDotSize": 9
          }
        },

        "sendModeField": {
          "labelKey": "announcements.fieldSendMode",
          "required": true,
          "options": [
            {
              "value": "now",
              "labelKey": "announcements.sendModeNow",
              "icon": "send"
            },
            {
              "value": "schedule",
              "labelKey": "announcements.sendModeSchedule",
              "icon": "clock"
            }
          ],
          "radioButton": {
            "flex": 1,
            "padding": "9px 11px",
            "borderRadius": 8,
            "activeBorder": "1.5px solid primaryColor",
            "activeBackground": "primaryColor + '14'"
          }
        },

        "schedulePicker": {
          "visibleWhen": "sendMode === 'schedule'",
          "labelKey": "announcements.fieldScheduledAt",
          "trigger": {
            "type": "button",
            "style": "inputStyle",
            "icon": "calendar",
            "iconSize": 14,
            "chevron": "chevronDown",
            "placeholderColor": "var(--edu-text-muted)",
            "selectedFontWeight": 700
          },
          "popover": {
            "position": "absolute top: calc(100% + 6px) left: 0",
            "zIndex": 61,
            "background": "var(--edu-card)",
            "border": "1px solid var(--edu-border)",
            "borderRadius": 12,
            "shadow": "0 12px 32px rgba(0,0,0,0.16)",
            "padding": 14,
            "minWidth": 460,
            "layout": "flex row gap-14"
          },
          "calendar": {
            "width": 260,
            "weekdayRow": {
              "gridCols": 7,
              "gap": 2,
              "fontSize": 10,
              "fontWeight": 700,
              "textTransform": "uppercase"
            },
            "dayCell": {
              "height": 32,
              "borderRadius": 7,
              "fontSize": 12.5,
              "selectedBackground": "primaryColor",
              "selectedColor": "#fff",
              "todayBorder": "1px solid primaryColor + '55'"
            },
            "pastDayOpacity": 0.4,
            "weekStartDay": "Monday (Vietnamese convention)"
          },
          "timePicker": {
            "width": 170,
            "borderLeft": "1px solid var(--edu-border)",
            "steppers": {
              "incrementIcon": "chevronUp",
              "decrementIcon": "chevronDown",
              "inputFontSize": 18,
              "inputFontWeight": 800,
              "inputColor": "primaryColor",
              "stepSize": { "hour": 1, "minute": 5 }
            },
            "confirmButton": {
              "fontSize": 12.5,
              "fontWeight": 800,
              "background": "primaryColor",
              "color": "#fff",
              "borderRadius": 8,
              "disabledBackground": "var(--edu-border)"
            }
          }
        },

        "attachmentsField": {
          "optional": true,
          "maxFiles": 3,
          "container": {
            "background": "var(--edu-bg)",
            "border": "1px dashed var(--edu-border)",
            "borderRadius": 8,
            "padding": 10
          },
          "fileRow": {
            "padding": "6px 10px",
            "borderRadius": 6,
            "border": "1px solid var(--edu-border)",
            "background": "var(--edu-card)",
            "icon": "fileText",
            "iconColor": "primaryColor",
            "removeIcon": "x",
            "removeIconColor": "var(--edu-error)"
          },
          "addButton": {
            "icon": "plus",
            "fontSize": 11.5,
            "fontWeight": 800,
            "border": "1px dashed primaryColor + '55'",
            "color": "primaryColor",
            "borderRadius": 6
          }
        }
      },

      "previewPanel": {
        "trigger": {
          "background": "primaryColor + '0F'",
          "border": "1px solid primaryColor + '33'",
          "borderRadius": 8,
          "color": "primaryColor",
          "fontSize": 12.5,
          "fontWeight": 800,
          "icon": "eye",
          "labelKey": "announcements.previewToggle"
        },
        "notificationPreview": {
          "padding": 12,
          "borderRadius": 10,
          "background": "var(--edu-bg)",
          "border": "1px dashed var(--edu-border)",
          "labelKey": "announcements.previewHeading",
          "notificationRow": {
            "background": "primaryColor + '08'",
            "border": "1px solid primaryColor + '33'",
            "borderRadius": 10,
            "padding": "12px 14px",
            "layout": "grid — 28px icon | flex-1 content",
            "gap": 12,
            "iconBox": { "size": 28, "borderRadius": 8 },
            "title": { "fontSize": 13.5, "fontWeight": 800 },
            "body": { "fontSize": 12, "lineClamp": 2 },
            "unreadDot": {
              "size": 7,
              "borderRadius": "50%",
              "background": "primaryColor"
            }
          }
        }
      },

      "footer": {
        "padding": "14px 22px",
        "background": "var(--edu-bg)",
        "borderTop": "1px solid var(--edu-border)",
        "layout": "flex row gap-10",
        "actions": [
          {
            "variant": "ghost",
            "labelKey": "announcements.btnCancel",
            "position": "left",
            "border": "1px solid var(--edu-border)"
          },
          {
            "variant": "ghost",
            "labelKey": "announcements.btnSaveDraft",
            "icon": "fileText",
            "position": "left",
            "disabledWhen": "!titleOk"
          },
          {
            "variant": "primary",
            "labelKey": "announcements.btnSchedule",
            "icon": "clock",
            "position": "right",
            "visibleWhen": "sendMode === 'schedule'",
            "disabledWhen": "!canSubmit"
          },
          {
            "variant": "primary",
            "labelKey": "announcements.btnSendNow",
            "icon": "send",
            "position": "right",
            "visibleWhen": "sendMode === 'now'",
            "disabledWhen": "!canSubmit"
          }
        ]
      }
    },

    // ── Detail side-sheet (read receipts) ─────────────────────────────────────────
    "detailSheet": {
      "width": 620,
      "maxWidth": "100vw",
      "position": "fixed right 0, top 0, bottom 0",
      "background": "var(--edu-card)",
      "shadow": "-12px 0 40px rgba(0,0,0,0.18)",
      "zIndex": 1001,
      "animation": "slideInFromRight 0.22s ease-out",
      "scrim": {
        "background": "rgba(20,30,50,0.45)",
        "backdropFilter": "blur(2px)",
        "zIndex": 1000
      },

      "header": {
        "padding": "20px 22px",
        "borderBottom": "1px solid var(--edu-border)",
        "iconBox": { "size": 42, "borderRadius": 11 },
        "icon": "megaphone",
        "iconSize": 19,
        "titleFontSize": 17,
        "titleFontWeight": 800,
        "metaFontSize": 11.5,
        "metaColor": "var(--edu-text-muted)"
      },

      "audienceStrip": {
        "padding": "10px 14px",
        "background": "var(--edu-bg)",
        "borderRadius": 10,
        "border": "1px solid var(--edu-border)",
        "icon": "users",
        "iconSize": 13,
        "fontSize": 12.5,
        "marginBottom": 16
      },

      "bodyText": {
        "padding": "14px 16px",
        "borderRadius": 10,
        "border": "1px solid var(--edu-border)",
        "fontSize": 13.5,
        "lineHeight": 1.6,
        "color": "var(--edu-text-secondary)",
        "whiteSpace": "pre-wrap",
        "marginBottom": 16
      },

      "attachmentList": {
        "marginBottom": 18,
        "fileRow": {
          "padding": "8px 12px",
          "borderRadius": 8,
          "border": "1px solid var(--edu-border)",
          "background": "var(--edu-card)",
          "icon": "fileText",
          "iconColor": "primaryColor",
          "iconSize": 14,
          "downloadButton": { "size": 24, "icon": "arrowDown" }
        }
      },

      "readReceiptSection": {
        "visibleWhen": "status === 'sent'",
        "ratioPanel": {
          "padding": "14px 16px",
          "background": "primaryColor + '08'",
          "border": "1px solid primaryColor + '33'",
          "borderRadius": 10,
          "marginBottom": 12,
          "layout": "flex row align-end gap-14",
          "label": {
            "fontSize": 10.5,
            "fontWeight": 800,
            "color": "var(--edu-text-muted)",
            "textTransform": "uppercase"
          },
          "pctValue": {
            "fontSize": 26,
            "fontWeight": 900,
            "color": "primaryColor",
            "lineHeight": 1
          },
          "countLabel": {
            "fontSize": 12,
            "color": "var(--edu-text-muted)",
            "fontWeight": 700
          },
          "progressBar": {
            "height": 6,
            "fillColor": "primaryColor",
            "borderRadius": 99,
            "transition": "width 0.3s"
          },
          "unreadCountLabel": {
            "fontSize": 11,
            "marginTop": 6,
            "color": "var(--edu-text-muted)"
          },
          "remindButton": {
            "variant": "secondary",
            "icon": "bell",
            "labelKey": "announcements.btnRemind",
            "disabledWhen": "unreadCount === 0"
          }
        },
        "filterTabs": {
          "gap": 8,
          "tabs": [
            {
              "id": "all",
              "labelKey": "announcements.recipientFilterAll",
              "color": "var(--edu-text-secondary)"
            },
            {
              "id": "read",
              "labelKey": "announcements.recipientFilterRead",
              "color": "var(--edu-success)"
            },
            {
              "id": "unread",
              "labelKey": "announcements.recipientFilterUnread",
              "color": "var(--edu-error)"
            }
          ],
          "tab": {
            "padding": "5px 12px",
            "borderRadius": 7,
            "fontSize": 12,
            "fontWeight": 800,
            "activeBorder": "1.5px solid <tabColor>",
            "activeBackground": "<tabColor> + '14'"
          },
          "countBadge": {
            "fontSize": 10,
            "fontWeight": 800,
            "padding": "1px 6px",
            "borderRadius": 99
          },
          "exportButton": {
            "variant": "ghost",
            "icon": "fileText",
            "size": "sm"
          }
        },
        "recipientList": {
          "background": "var(--edu-card)",
          "border": "1px solid var(--edu-border)",
          "borderRadius": 10,
          "overflow": "hidden",
          "row": {
            "layout": "grid — 30px avatar | content | status column",
            "gap": 10,
            "padding": "10px 14px",
            "borderBottom": "1px solid var(--edu-border)",
            "avatar": {
              "size": 30,
              "borderRadius": "50%",
              "fontSize": 11,
              "fontWeight": 800
            },
            "name": {
              "fontSize": 13,
              "fontWeight": 700,
              "color": "var(--edu-text-primary)"
            },
            "child": {
              "fontSize": 11,
              "color": "var(--edu-text-muted)",
              "marginTop": 1
            },
            "readBadge": {
              "color": "var(--edu-success)",
              "icon": "check",
              "labelKey": "announcements.recipientStatusRead"
            },
            "unreadBadge": {
              "color": "var(--edu-error)",
              "icon": "clock",
              "labelKey": "announcements.recipientStatusUnread"
            },
            "readAtTimestamp": {
              "fontSize": 10.5,
              "color": "var(--edu-text-muted)",
              "fontFamily": "monospace",
              "marginTop": 3
            }
          },
          "emptyRow": {
            "padding": 24,
            "textAlign": "center",
            "fontSize": 12.5,
            "color": "var(--edu-text-muted)",
            "messageKey": "announcements.recipientsEmpty"
          }
        }
      },

      "footer": {
        "padding": "14px 22px",
        "borderTop": "1px solid var(--edu-border)",
        "layout": "flex row",
        "actions": [
          {
            "variant": "ghost",
            "icon": "x",
            "labelKey": "announcements.btnDelete",
            "color": "var(--edu-error)",
            "border": "1px solid var(--edu-error) + '55'",
            "background": "var(--edu-error)/10",
            "position": "left"
          },
          {
            "variant": "ghost",
            "labelKey": "announcements.btnClose",
            "border": "1px solid var(--edu-border)",
            "color": "var(--edu-text-secondary)",
            "position": "right"
          }
        ]
      }
    },

    // ── Delete confirm dialog ─────────────────────────────────────────────────────
    "deleteDialog": {
      "role": "alertdialog",
      "ariaModal": true,
      "maxWidth": 460,
      "background": "var(--edu-card)",
      "borderRadius": 14,
      "shadow": "0 24px 60px rgba(0,0,0,0.25)",
      "animation": "fadeIn 0.18s ease-out",
      "iconBox": {
        "size": 42,
        "borderRadius": 11,
        "background": "var(--edu-error)/14",
        "icon": "alertTriangle",
        "iconColor": "var(--edu-error)",
        "iconSize": 19
      },
      "titleFontSize": 16,
      "titleFontWeight": 800,
      "bodyFontSize": 12.5,
      "bodyLineHeight": 1.6,
      "titleKey": "announcements.deleteTitle",
      "bodyKey": "announcements.deleteDescription",
      "footer": {
        "padding": "14px 24px",
        "background": "var(--edu-bg)",
        "borderTop": "1px solid var(--edu-border)",
        "actions": [
          {
            "variant": "ghost",
            "labelKey": "announcements.btnCancel",
            "border": "1px solid var(--edu-border)"
          },
          {
            "variant": "danger",
            "labelKey": "announcements.btnDelete",
            "icon": "x"
          }
        ]
      }
    },

    // ── Toast notifications ───────────────────────────────────────────────────────
    "toast": {
      "position": "fixed bottom-28 center (translateX -50%)",
      "background": "var(--edu-text-primary)",
      "color": "#fff",
      "padding": "11px 18px",
      "borderRadius": 12,
      "shadow": "0 12px 40px rgba(0,0,0,0.25)",
      "fontSize": 13,
      "fontWeight": 600,
      "zIndex": 9000,
      "animation": "slideUpFadeIn 0.2s ease-out",
      "autoDismiss": "2600ms",
      "successIcon": {
        "size": 22,
        "borderRadius": "50%",
        "background": "var(--edu-success)",
        "checkSize": 12,
        "checkColor": "#fff"
      },
      "variants": {
        "send": { "messageKey": "announcements.sendToast" },
        "schedule": { "messageKey": "announcements.scheduleToast" },
        "draft": { "messageKey": "announcements.draftToast" },
        "delete": { "messageKey": "announcements.deleteToast" },
        "remind": { "messageKey": "announcements.remindToast" }
      }
    },

    // ── Role variant behavior ─────────────────────────────────────────────────────
    "roleVariants": {
      "admin": {
        "route": "/admin/announcements",
        "primaryColor": "var(--edu-primary)",
        "canCreate": true,
        "canDelete": true,
        "canViewReadReceipts": true,
        "roleChip": "ADMIN · BGH"
      },
      "principal": {
        "route": "/principal/announcements",
        "primaryColor": "var(--edu-success)",
        "canCreate": true,
        "canDelete": true,
        "canViewReadReceipts": true,
        "roleChip": "BGH"
      },
      "recipientRoles": {
        "note": "All other roles (teacher/student/parent) receive announcements via Notifications Center (DR-006 / US-E10.2). No compose UI shown for these roles.",
        "deliveryChannel": "SSE fan-out — noti service",
        "notificationTab": "announcement (type: announcement) in Notifications Center filter pills"
      }
    },

    // ── Priority / audience / status lookups ──────────────────────────────────────
    "lookups": {
      "priority": {
        "normal": {
          "labelKey": "announcements.priorityNormal",
          "color": "var(--edu-text-secondary)",
          "bg": "var(--edu-bg)",
          "icon": "bell",
          "stamp": "NORMAL"
        },
        "important": {
          "labelKey": "announcements.priorityImportant",
          "color": "var(--edu-warning)",
          "bg": "var(--edu-warning)/15",
          "icon": "alertTriangle",
          "stamp": "IMPORTANT"
        },
        "urgent": {
          "labelKey": "announcements.priorityUrgent",
          "color": "var(--edu-error)",
          "bg": "var(--edu-error)/15",
          "icon": "alertTriangle",
          "stamp": "URGENT",
          "urgentAccentBar": true
        }
      },
      "status": {
        "draft": {
          "labelKey": "announcements.statusDraft",
          "color": "var(--edu-warning)",
          "bg": "var(--edu-warning)/15",
          "icon": "penLine"
        },
        "scheduled": {
          "labelKey": "announcements.statusScheduled",
          "color": "var(--edu-primary)",
          "bg": "var(--edu-primary)/15",
          "icon": "clock"
        },
        "sent": {
          "labelKey": "announcements.statusSent",
          "color": "var(--edu-success)",
          "bg": "var(--edu-success)/15",
          "icon": "check"
        }
      },
      "audiencePresets": [
        {
          "id": "all",
          "labelKey": "announcements.audienceAll",
          "icon": "users",
          "est": 1280,
          "exclusive": true
        },
        {
          "id": "teachers",
          "labelKey": "announcements.audienceTeachers",
          "icon": "userCheck",
          "est": 42
        },
        {
          "id": "parents",
          "labelKey": "announcements.audienceParents",
          "icon": "users",
          "est": 768
        },
        {
          "id": "students",
          "labelKey": "announcements.audienceStudents",
          "icon": "graduationCap",
          "est": 480
        }
      ],
      "gradeLevels": [10, 11, 12]
    },

    // ── API contract (mock-first — noti service fan-out) ─────────────────────────
    "api": {
      "note": "noti service — mock-first per decision 0014; fan-out over SSE (decision 0009)",
      "list": "GET  /noti/api/v1/announcements?status=&cursor= → AnnouncementEntity[]",
      "create": "POST /noti/api/v1/announcements (AnnouncementPayload)",
      "update": "PUT  /noti/api/v1/announcements/:id",
      "delete": "DELETE /noti/api/v1/announcements/:id",
      "readReceipts": "GET /noti/api/v1/announcements/:id/receipts?status=&cursor=",
      "remind": "POST /noti/api/v1/announcements/:id/remind"
    },

    // ── Accessibility notes (for /fe implementation) ──────────────────────────────
    "a11yNotes": [
      "Create drawer: role='dialog', aria-modal=true, aria-labelledby=drawer title; focus on first input on open; trap focus within; close on Escape + backdrop click.",
      "Detail sheet: role='dialog', aria-modal=true, aria-labelledby=announcement title; close button aria-label='Đóng'.",
      "Delete dialog: role='alertdialog', aria-modal=true; focus on 'Huỷ' on open (safe default for destructive actions).",
      "Audience preset chips: role='checkbox' + aria-checked per chip (multi-select); 'all' chip is exclusive — selecting it must aria-announce via aria-live region.",
      "Priority radio group: role='radiogroup' + role='radio' per option; aria-checked; keyboard arrow-key navigation between options.",
      "Schedule picker: calendar dates — aria-label includes full date (e.g. 'Thứ 2, 15 tháng 6 năm 2026'); disabled past dates aria-disabled=true; confirmed date aria-selected=true.",
      "Read-receipt progress bar: aria-label using readProgressLabel key with pct value (e.g. 'Tỷ lệ đã đọc: 89%').",
      "Remind button: aria-live='polite' toast confirmation; disabled state aria-disabled=true with reason (all read).",
      "Status filter pills: role='radiogroup' + role='radio' per pill; active state aria-checked=true.",
      "Toast: role='status' + aria-live='polite' for success; role='alert' + aria-live='assertive' for error.",
      "Urgent announcement card: communicates urgency via icon + badge (not color alone); urgentCardAriaLabel key wraps full announcement title.",
      "Warning foreground: draft notice uses var(--edu-warning-foreground) (#2A3547) — NOT white on warning yellow (a11y compliance, decision 0013).",
      "Close buttons: icon-only — aria-label='Đóng' in Vietnamese."
    ],

    // ── Responsive ────────────────────────────────────────────────────────────────
    "responsive": {
      "1280": "Default — list cards full width; filter pills on one row; CTA top-right",
      "1024": "Filter pills may wrap to two rows; card action column stays visible",
      "768": "Card meta wraps; action column stacks below content; drawer width max 100vw; detail sheet width max 100vw",
      "375": "Filter pills scroll horizontally; card padding 12px 16px; action buttons icon-only with tooltip; drawer + detail sheet full-screen"
    }
  },

  // ─────────────────────────────────────────────────────────────────────────
  // DR-010 — Responsive breakpoints + empty states
  // Source: DR-010 (UX-03 + UX-01); branch docs/dr-010-responsive-empty-states
  // Applies to: discipline, gradebook, messaging, notifications, lesson-bank
  // ─────────────────────────────────────────────────────────────────────────

  // ── Responsive grid system (UX-03) ────────────────────────────────────────
  "responsiveGrid": {
    // NORMATIVE breakpoints for stat-card / summary grids across all dashboards.
    // All stat grids using repeat(N, 1fr) MUST adopt this pattern.
    "statGrid": {
      "default": "repeat(4, 1fr)",
      "tablet": "repeat(2, 1fr)",
      "mobile": "1fr",
      "breakpoints": {
        ">1024px": "4 columns",
        "640–1024px": "2 columns",
        "<640px": "1 column"
      },
      "implementation": "CSS Grid auto-responsive: gridTemplateColumns: 'repeat(auto-fit, minmax(200px, 1fr))' — collapses naturally without JS breakpoint detection; minmax floor 200px = 2 cols at 440px, 1 col at 220px (375px viewport gives single col with 16px padding each side)"
    },
    // Grade table: horizontal scroll on mobile, sticky first column
    "gradeTable": {
      "mobile": {
        "overflowX": "auto",
        "WebkitOverflowScrolling": "touch",
        "firstColumn": {
          "position": "sticky",
          "left": 0,
          "background": "var(--edu-card)",
          "zIndex": 1,
          "borderRight": "1px solid var(--edu-border)"
        },
        "minWidth": "640px",
        "padding": "0"
      }
    },
    // Messaging: single-pane toggle (list OR chat) on mobile
    "messagingLayout": {
      ">768px": "side-by-side: conversation list (300px) + chat pane (flex 1)",
      "<=768px": "single pane; show list by default; tapping a conversation slides in chat pane (full width); back button returns to list; no list/chat overlap",
      "mobileTransition": "transform 0.25s ease (slide left/right); @media (prefers-reduced-motion: reduce) → no transform, instant show/hide"
    },
    // Touch targets — all interactive elements on mobile
    "touchTarget": {
      "minHeight": 44,
      "minWidth": 44,
      "note": "WCAG 2.5.5 AA — applies to buttons, nav items, list rows, table action icons"
    }
  },

  // ── Empty state design pattern (UX-01) ────────────────────────────────────
  "emptyStatePattern": {
    // Canonical empty state design — reused across all list/table screens.
    // Icon + title + body + optional CTA. All copy via i18n keys.
    "layout": "centered column; padding 40px 20px; text-align center",
    "icon": {
      "size": 64,
      "color": "var(--edu-text-muted)",
      "ariaHidden": true,
      "note": "Use contextual icon from design_src/edu/icons.jsx (e.g. inbox, file-text, message-square, shield); NEVER inline SVG raw color"
    },
    "title": {
      "fontSize": 16,
      "fontWeight": 700,
      "color": "var(--edu-text-primary)",
      "marginTop": 16
    },
    "body": {
      "fontSize": 13,
      "color": "var(--edu-text-muted)",
      "marginTop": 8,
      "maxWidth": 320
    },
    "cta": {
      "optional": true,
      "marginTop": 20,
      "variant": "primary",
      "minTouchTarget": 44
    },
    "a11y": "role=status on the container so screen readers announce the empty state; icon aria-hidden=true; title rendered as <p> not <h2> (no heading hierarchy disruption)"
  },

  // Per-screen empty state specs
  "emptyStates": {
    "discipline.violations": {
      "i18nKey": "discipline.violations.empty",
      "icon": "shield",
      "hasCTA": false,
      "note": "Existing key discipline.violations.empty ('Không có vi phạm nào!') re-used; conduct table uses discipline.conduct.empty"
    },
    "discipline.leaveRequests": {
      "i18nKey": "discipline.leave.empty",
      "icon": "calendar-off",
      "hasCTA": false,
      "note": "Existing key discipline.leave.empty re-used; no new key needed"
    },
    "gradebook.gradeTable": {
      "i18nKey": "grades.gradeBook.emptyState",
      "icon": "file-text",
      "hasCTA": false,
      "note": "Existing key grades.gradeBook.emptyState re-used; shown when class has no students or no grades entered yet"
    },
    "notifications.list": {
      "allTab": {
        "titleKey": "notifications.emptyAllTitle",
        "bodyKey": "notifications.emptyAllBody",
        "icon": "bell-off"
      },
      "unreadTab": {
        "titleKey": "notifications.emptyUnreadTitle",
        "bodyKey": "notifications.emptyUnreadBody",
        "icon": "check-circle"
      },
      "note": "All 4 keys already exist in messages.json — no new keys"
    },
    "lessonBank.list": {
      "allVariant": {
        "titleKey": "lessonBank.empty.title",
        "bodyKey": "lessonBank.empty.body",
        "icon": "book-open",
        "hasCTA": true,
        "ctaKey": "lessonBank.empty.cta"
      },
      "filterVariant": {
        "titleKey": "lessonBank.empty.noMatch",
        "bodyKey": "lessonBank.empty.noMatchBody",
        "icon": "search",
        "hasCTA": false
      },
      "note": "All keys already exist in messages.json under lessonBank.empty — no new keys needed"
    },
    "messaging.conversations": {
      "titleKey": "messaging.empty.title",
      "bodyKey": "messaging.empty.subtitle",
      "icon": "message-square",
      "hasCTA": true,
      "ctaKey": "messaging.empty.cta",
      "note": "All keys already exist in messages.json under messaging.empty — no new keys needed"
    }
  },

  // DR-011 — UX-02/04/05/06/07/08 cross-cutting interaction patterns (2026-06-21)
  "interactionPatterns": {
    // UX-02 — Destructive Confirm Dialog
    "destructiveConfirmDialog": {
      "canonicalHome": "components/shared/destructive-confirm-dialog/",
      "builtOn": "shadcn AlertDialog (Radix UI)",
      "usedBy": [
        "announcements (send-to-school confirm)",
        "discipline-violations (delete violation)",
        "staff-leave (reject request)",
        "exam-bank (delete exam)"
      ],
      "props": {
        "open": "boolean",
        "title": "string",
        "body": "string",
        "confirmLabel": "string",
        "isLoading": "boolean (optional, default false)",
        "onConfirm": "() => void",
        "onCancel": "() => void"
      },
      "layout": {
        "iconTitleRow": {
          "icon": "lucide AlertTriangle",
          "iconSize": 20,
          "iconColor": "text-destructive",
          "titleTypography": "text-base font-bold text-foreground"
        },
        "body": {
          "typography": "text-sm text-muted-foreground",
          "placement": "below icon+title row"
        },
        "footer": {
          "cancelPlacement": "left",
          "confirmPlacement": "right"
        }
      },
      "tokens": {
        "confirmButton": "variant='destructive' → bg-destructive text-destructive-foreground",
        "title": "text-foreground text-base font-bold",
        "body": "text-muted-foreground text-sm",
        "icon": "text-destructive"
      },
      "states": {
        "isLoading=true": {
          "confirmButton": "disabled + aria-busy='true'",
          "cancelButton": "disabled"
        },
        "isLoading=false": "both buttons interactive"
      },
      "keyboard": {
        "Escape": "cancel (Radix AlertDialog default)",
        "Enter": "confirm (Radix AlertDialog default)"
      },
      "a11y": {
        "focusTrap": "Radix AlertDialog built-in",
        "focusRestoreOnClose": "returns to trigger element",
        "role": "alertdialog (Radix default)"
      },
      "specificInstances": {
        "announcements.sendToSchool": {
          "titleKey": "announcements.sendConfirmTitle",
          "bodyKey": "announcements.sendConfirmBody",
          "bodyInterpolation": "{recipientCount}",
          "confirmLabelKey": "announcements.btnSendNow"
        },
        "discipline.violations.delete": {
          "titleKey": "discipline.violations.deleteDialog.title",
          "bodyKey": "discipline.violations.deleteDialog.body",
          "confirmLabelKey": "discipline.violations.deleteDialog.confirmLabel"
        },
        "staffLeave.reject": {
          "titleKey": "staffLeave.rejectConfirmTitle",
          "confirmLabelKey": "staffLeave.actions.confirmReject"
        }
      }
    },

    // UX-04 — Detail Panel Back Navigation
    "detailPanelHeader": {
      "canonicalHome": "components/shared/detail-panel-header/",
      "usedBy": [
        "announcements detail drawer",
        "group-chat info panel",
        "exam-builder header"
      ],
      "props": {
        "backLabel": "string — i18n key resolved by caller",
        "onBack": "() => void",
        "title": "string (optional)",
        "actions": "React.ReactNode (optional)"
      },
      "layout": {
        "structure": "3-zone row: [back button left] [title center] [actions right]",
        "backButton": {
          "variant": "ghost",
          "icon": "lucide ChevronLeft, 16px",
          "minHeight": "min-h-[44px]",
          "minWidth": "min-w-[44px]",
          "ariaLabel": "aria-label={backLabel}",
          "typography": "text-sm text-muted-foreground"
        },
        "title": {
          "typography": "text-base font-bold text-foreground",
          "overflow": "truncate on mobile (375px)"
        },
        "actions": {
          "desktop": "visible right-aligned",
          "mobile": "collapse to icon-only via md:hidden on label text"
        }
      },
      "responsive": {
        "375": "title truncates, actions icon-only",
        "768+": "full title, labeled actions"
      },
      "keyboard": {
        "Tab": "reaches back button",
        "Enter/Space": "activates back action"
      },
      "a11y": {
        "backButtonAriaLabel": "must equal backLabel prop (descriptive: e.g. 'Quay lại danh sách thông báo')",
        "focusRing": "ring token visible, never outline:none bare"
      }
    },

    // UX-05 — Loading Skeletons
    "loadingSkeleton": {
      "placement": "feature-local per screen; promote to components/shared/ only when ≥2 features share an identical shape",
      "baseComponent": "shadcn Skeleton (src/components/ui/skeleton/)",
      "motionGate": "motion-safe:animate-pulse — confirm Skeleton component wraps pulse in motion-safe; FE must add gate if absent",
      "wrapper": {
        "role": "status",
        "ariaBusy": "true",
        "ariaLabel": "t('Common.skeleton.loading')",
        "srOnlyText": "<span className='sr-only'>{t('Common.skeleton.loading')}</span>"
      },
      "shapes": {
        "StatCardSkeleton": {
          "iconBox": "52×52px, bg-muted animate-pulse, radius 12px",
          "valueBlock": "h-7 w-16 bg-muted animate-pulse",
          "labelBlock": "h-3 w-20 bg-muted animate-pulse",
          "cardPadding": "20px",
          "cardRadius": "12px"
        },
        "TableRowSkeleton": {
          "rowHeight": "min-h-[44px] (touch-safe baseline)",
          "cells": "Skeleton blocks of varying widths (e.g. w-24 / w-16 / w-32)",
          "border": "border-b border-border",
          "background": "bg-muted animate-pulse per cell"
        }
      },
      "appliesTo": [
        "StatCard grids — discipline dashboard, teacher dashboard, student dashboard",
        "Table bodies — grade-entry, discipline-conduct",
        "List items — lesson-bank, exam-bank"
      ],
      "i18nKey": "Common.skeleton.loading"
    },

    // UX-08 — Mobile Touch Target ≥44px
    "touchTarget": {
      "rule": "All interactive elements on mobile must have min-h-[44px]; icon-only buttons also min-w-[44px]",
      "tailwindUtility": "min-h-[44px] = Tailwind min-h-11 (44px); min-w-[44px] = min-w-11",
      "noNewToken": true,
      "patterns": {
        "tableRows": {
          "interactiveTr": "add min-h-[44px] to <tr> or row container when row is clickable/tappable",
          "interactiveTd": "add min-h-[44px] to data cell when cell is individually tappable"
        },
        "gradeTable": {
          "dataCell": "min-h-[44px] per row",
          "stickyFirstColumn": {
            "position": "sticky",
            "left": 0,
            "background": "bg-card",
            "zIndex": "z-10",
            "purpose": "horizontal scroll on mobile — first column stays visible"
          }
        },
        "auditLogViolationRows": {
          "rowContainer": "py-2.5 min-h-[44px]"
        },
        "iconOnlyButtons": {
          "size": "min-h-[44px] min-w-[44px]",
          "note": "action buttons in table rows, tab items, floating action triggers"
        }
      },
      "scope": "375px mobile breakpoint and up; not needed when element is desktop-only non-interactive"
    },

    // UX-06 — Contextual Toast Messages
    "contextualToast": {
      "toastLibrary": "sonner (already wired in project)",
      "rule": "Toast messages affecting specific entities or counts MUST include context (entity name or count + optional timestamp)",
      "format": "[Past-tense verb] [entity/count] [optional: lúc {time}]",
      "duration": {
        "contextual": "4000ms",
        "generic": "2000ms"
      },
      "variant": "success",
      "replacements": {
        "announcements": {
          "genericKey": "announcements.sendToast",
          "genericValue": "Đã gửi thông báo",
          "contextualKey": "announcements.sendToastContext",
          "contextualValue": "Đã gửi thông báo đến {recipientCount} người nhận lúc {time}",
          "interpolation": "{recipientCount: number, time: string (HH:mm)}"
        },
        "discipline.violations": {
          "genericKey": "discipline.violations.success",
          "genericValue": "Đã ghi nhận vi phạm thành công!",
          "contextualKey": "discipline.violations.successContext",
          "contextualValue": "Đã ghi nhận vi phạm của {studentName}",
          "interpolation": "{studentName: string}"
        }
      },
      "note": "Do NOT delete generic keys — add contextual variant alongside. Caller supplies interpolation data. Fall back to generic key when context data unavailable."
    },

    // UX-07 — Onboarding Stepper
    "setupStepper": {
      "currentLocation": "feature-local: src/features/admin-school-setup/presentation/school-setup-screen/",
      "promoteCondition": "Move to components/shared/setup-stepper/ when a second onboarding flow appears",
      "visual": {
        "progressBar": {
          "track": "h-1.5 rounded-full bg-muted",
          "fill": "bg-primary",
          "fillWidth": "(completedSteps / totalSteps * 100)%",
          "transition": "transition-[width] duration-[400ms] ease-out — gated: motion-safe:transition-[width]",
          "placement": "top of the setup guide card"
        },
        "stepCounter": {
          "typography": "text-xs font-bold text-muted-foreground uppercase tracking-wide",
          "format": "BƯỚC {current}/{total}",
          "i18nKey": "adminSchoolSetup.stepper.progress",
          "i18nInterpolation": "{current: number, total: number}"
        },
        "stepItems": {
          "done": "check icon, color text-edu-success (green)",
          "current": "spinner or clock icon, color text-primary",
          "pending": "circle icon, color text-muted-foreground",
          "noTokenChange": true
        }
      },
      "a11y": {
        "role": "progressbar",
        "ariaValuenow": "pct (0–100, integer)",
        "ariaValuemin": 0,
        "ariaValuemax": 100,
        "ariaLabel": "t('adminSchoolSetup.stepper.ariaLabel')",
        "i18nKey": "adminSchoolSetup.stepper.ariaLabel"
      },
      "tokens": {
        "track": "bg-muted",
        "fill": "bg-primary",
        "stepDone": "text-edu-success",
        "stepCurrent": "text-primary",
        "stepPending": "text-muted-foreground",
        "counterText": "text-muted-foreground"
      }
    }
  },

  // ── DR-021 (2026-07-17): Lesson Plan Authoring + Question Bank (net-new) ──
  "lessonPlan": {
    "story": "US-E18.16 (design follow-up, DR-021)",
    "routes": [
      "/teacher/lesson-plans",
      "/teacher/lesson-plans/create",
      "/teacher/lesson-plans/:id/edit"
    ],
    "roles": ["teacher"], // no admin/principal aggregate ground-truthed for this BE contract
    "designSrc": "design_src/edu/lesson-plan.jsx",
    "components": [
      "LessonPlanScreen",
      "LessonPlanBuilderScreen",
      "LPCard",
      "LPStatusChip",
      "LPTagChipsInput",
      "LPDropdown",
      "LPConfirmDialog"
    ],
    "i18nNamespace": "lessonPlan",
    "i18nKeyCount": 80, // keys in src/bootstrap/i18n/messages/vi.json lessonPlan section (uiux-ux-writer, DR-021)
    "status": "design-ready (DR-021, 2026-07-17)",
    "beContract": {
      "service": "core (lessonplan sub-domain)",
      "routes": "POST/GET /api/v1/lms/lesson-plans, GET /:id, PUT /:id (DRAFT only), PUT /:id/publish (one-way), GET /subject/:subjectId (PUBLISHED browse)",
      "responseFields": "planId, teacherId, subjectId, gradeLevel, title, objectives, contentOutline, activities, assessmentMethod, status (DRAFT|PUBLISHED), tags, publishedAt, createdAt, updatedAt",
      "errorTaxonomy": "11-code LESSON_PLAN_* — edu-api/services/core/docs/ERROR_CODES.md:337-346",
      "noDeleteEndpoint": "No delete endpoint ground-truthed — list/card design has NO destructive delete CTA"
    },

    // ── SCREEN A1: Lesson Plan List (/teacher/lesson-plans) ─────────────────
    "listScreen": {
      "layout": "single-column, maxWidth 1280, margin 0 auto, padding 24px 32px (mobile 20px 16px), background var(--edu-bg)",
      "gap": 16,
      "pageHeader": {
        "display": "flex, alignItems flex-end, gap 16, flexWrap wrap",
        "breadcrumb": "US-E18.16 · Soạn giáo án — 11px/700 muted uppercase, letterSpacing 0.07em",
        "title": {
          "i18nKey": "lessonPlan.title",
          "note": "static title, same for both owner-toggle scopes",
          "fontSize": 22,
          "fontWeight": 800,
          "color": "var(--edu-text-primary)"
        },
        "subtitle": {
          "i18nKey": "lessonPlan.subtitle (owner=me) / lessonPlan.subtitleBrowse (owner=all)",
          "fontSize": 12.5,
          "color": "var(--edu-text-muted)"
        },
        "ownerToggle": {
          "note": "Của tôi (own DRAFT+PUBLISHED) vs Toàn trường (cross-teacher, PUBLISHED-only browse via GET /subject/:subjectId)",
          "options": [
            "me (lessonPlan.ownerToggle.mine)",
            "all (lessonPlan.ownerToggle.school)"
          ],
          "i18nKey": "lessonPlan.ownerToggle.{mine,school,ariaLabel}",
          "style": "same as examBank.listScreen.pageHeader.ownerToggle — border 1.5px solid var(--edu-border), active bg primary/14",
          "a11y": "role='group' + aria-label (lessonPlan.ownerToggle.ariaLabel); active button aria-pressed=true"
        },
        "createCTA": {
          "i18nKey": "lessonPlan.createButton",
          "icon": "plus",
          "variant": "primary",
          "visibleFor": "teacher only"
        }
      },
      "filterBar": {
        "containerStyle": "white card, padding 14px 16px, borderRadius 12, border 1px solid var(--edu-border)",
        "search": {
          "placeholder": "lessonPlan.filter.searchPlaceholder",
          "leadingIcon": "search"
        },
        "subjectDropdown": {
          "icon": "bookOpen",
          "i18nKey": "lessonPlan.filter.allSubjects"
        },
        "gradeDropdown": {
          "icon": "graduationCap",
          "i18nKey": "lessonPlan.filter.allGrades"
        },
        "statusDropdown": {
          "visibleFor": "owner=me only (Toàn trường scope is PUBLISHED-only, no status filter needed)",
          "options": ["all", "DRAFT (Nháp)", "PUBLISHED (Đã phát hành)"]
        }
      },
      "cardGrid": {
        "note": "Grid card layout — mirrors lesson-bank.jsx grid (NOT exam-bank's row-list)",
        "grid": {
          "templateColumns": "repeat(auto-fill, minmax(260px, 1fr))",
          "gap": 16
        },
        "card": {
          "background": "var(--edu-card)",
          "borderRadius": 12,
          "border": "1px solid var(--edu-border)",
          "boxShadow": "var(--edu-shadow-card)",
          "hoverShadow": "var(--edu-shadow-card-hover)",
          "hoverTransform": "translateY(-2px)"
        },
        "headerStrip": {
          "height": 64,
          "background": "linear-gradient(135deg, subject.color+'12' 0%, subject.color+'26' 100%)",
          "iconBox": "40x40, borderRadius 10, background #fff, icon 'scrollText' size 19",
          "statusBadge": "LPStatusChip — DRAFT=warning/PUBLISHED=success (2-value, exam-bank convention, no new token)"
        },
        "body": {
          "title": { "fontSize": 14, "fontWeight": 700, "lineClamp": 2 },
          "sectionsProgress": "N/4 mục đã soạn — icon checkSquare, fontSize 11, muted",
          "tags": "pill chips, bg var(--edu-bg), fontSize 10/700",
          "metaLine": "Cập nhật: <date> · GV: <owner> (owner shown only when scope=all)",
          "actionButton": "Xem/Sửa (own) or Xem chi tiết (others), icon penLine/eye"
        },
        "noDeleteCTA": true,
        "noDuplicateCTA": "kept minimal per DR scope — not in BE contract for this screen"
      },
      "states": {
        "loading": "EduSkeleton variant='cards' count=6",
        "error": "EduError + onRetry",
        "emptyAll": {
          "icon": "scrollText",
          "action": "Soạn giáo án mới (owner=me only)"
        },
        "emptyFiltered": { "icon": "search", "action": "Bỏ lọc" }
      }
    },

    // ── SCREEN A2: Lesson Plan Builder (/teacher/lesson-plans/create, /:id/edit) ─
    "builderScreen": {
      "layout": "2-column (mirrors ExamBuilderScreen) — left 320px plan-meta card, right flex-1 stacked 4 document-section cards. Mobile (<860px): stacks to single column.",
      "topBar": {
        "back": "chevronLeft + Về danh sách",
        "titleArea": "breadcrumb US-E18.16 + draft.title or placeholder",
        "statusChip": "LPStatusChip",
        "actions": {
          "visibleWhen": "status !== PUBLISHED",
          "saveDraft": {
            "icon": "penLine",
            "i18nKey": "lessonPlan.builder.saveDraft"
          },
          "publish": {
            "icon": "check",
            "i18nKey": "lessonPlan.builder.publish",
            "disabledUntil": "title (4-200 chars) AND all 4 sections non-empty",
            "confirmDialog": "one-way DRAFT→PUBLISHED, irreversible — mirrors exam-bank builder's confirm pattern"
          }
        },
        "lockedBanner": {
          "visibleWhen": "status === PUBLISHED",
          "icon": "lock",
          "background": "var(--edu-success)/light",
          "i18nKey": "lessonPlan.lockedNotice.{title,body}",
          "note": "Once PUBLISHED, all fields render disabled/read-only — mirrors exam-bank's published-exam lock intent"
        },
        "unsavedIndicator": "dot + Chưa lưu, warning tone, same pattern as exam-bank builder"
      },
      "leftColumn_planMeta": {
        "width": 320,
        "fields": [
          {
            "key": "title",
            "type": "text",
            "required": true,
            "validation": "4-200 chars",
            "i18nKey": "lessonPlan.builder.{titleLabel,titlePlaceholder}"
          },
          {
            "key": "subjectId",
            "type": "select",
            "i18nKey": "lessonPlan.builder.{subjectLabel,subjectPlaceholder}"
          },
          {
            "key": "gradeLevel",
            "type": "select",
            "i18nKey": "lessonPlan.builder.{gradeLevelLabel,gradeLevelPlaceholder}"
          },
          {
            "key": "tags",
            "type": "tag-chips-input",
            "i18nKey": "lessonPlan.builder.{tagsLabel,tagsPlaceholder,tagsHelper}"
          }
        ],
        "metaFooter": "Tạo: <date> / Phát hành: <date> — 11px muted"
      },
      "rightColumn_documentSections": {
        "note": "Exactly 4 named sections — do NOT invent a richer schema",
        "sections": [
          {
            "key": "objectives",
            "icon": "flag",
            "i18nKey": "lessonPlan.builder.{objectivesLabel,objectivesPlaceholder}"
          },
          {
            "key": "contentOutline",
            "icon": "list",
            "i18nKey": "lessonPlan.builder.{contentOutlineLabel,contentOutlinePlaceholder}"
          },
          {
            "key": "activities",
            "icon": "users",
            "i18nKey": "lessonPlan.builder.{activitiesLabel,activitiesPlaceholder}"
          },
          {
            "key": "assessmentMethod",
            "icon": "checkSquare",
            "i18nKey": "lessonPlan.builder.{assessmentMethodLabel,assessmentMethodPlaceholder}"
          }
        ],
        "fieldStyle": "card shell, label uppercase 10.5px/800 muted + required asterisk, textarea rows=4",
        "validation": "each required to publish — inline field-level error banner (role=alert, aria-invalid, aria-describedby) per 11-code LESSON_PLAN_* taxonomy; /ba maps exact codes"
      }
    },

    "a11y": {
      "contrast": "DRAFT/PUBLISHED badges reuse exam-bank's proven-AA warning/success token pairing",
      "focus": "all inputs/selects/buttons use default browser + var(--ring) focus visibility",
      "keyboard": "tab order = reading order (meta column → 4 sections top-to-bottom)",
      "motion": "toast/dialog fade-in gated behind prefers-reduced-motion: reduce",
      "statusNotColorOnly": "every status/badge pairs icon + text label"
    }
  },

  "questionBank": {
    "story": "US-E18.16 (design follow-up, DR-021)",
    "routes": [
      "/teacher/question-bank",
      "/teacher/question-bank/create",
      "/teacher/question-bank/:id/edit"
    ],
    "roles": ["teacher"], // staff-only search per BE contract; no admin aggregate ground-truthed
    "designSrc": "design_src/edu/question-bank.jsx",
    "components": [
      "QuestionBankScreen",
      "QuestionBankBuilderScreen",
      "QBQuestionCard",
      "QBStatusChip",
      "QBTypeBadge",
      "QBDifficultyBadge",
      "QBFilterRequiredPrompt",
      "QBTagChipsInput",
      "QBDropdown",
      "QBConfirmDialog"
    ],
    "i18nNamespace": "questionBank",
    "i18nKeyCount": 94, // keys in src/bootstrap/i18n/messages/vi.json questionBank section (uiux-ux-writer DR-021 base 87 + uiux-lead reconcile +7: scopeToggle.*, filter.allGrades/gradeAriaLabel, filter.mandatorySatisfied/mandatoryRequired)
    "status": "design-ready (DR-021, 2026-07-17)",
    "beContract": {
      "service": "core (exercisebank sub-domain)",
      "routes": "GET /api/v1/lms/questions/search (staff-only, PUBLISHED only, requires subjectId or tag else 422 QUESTION_SEARCH_FILTER_REQUIRED), POST/GET /questions (own, no filter required), GET/PUT /:id, PUT /:id/publish (one-way)",
      "responseFields": "id, tenantId, authorId, questionType (ESSAY|SHORT_ANSWER|FILL_IN), subjectId, gradeLevel, difficulty (EASY|MEDIUM|HARD), body, expectedAnswer, status (DRAFT|PUBLISHED), tags, createdAt, updatedAt, publishedAt",
      "errorTaxonomy": "~12-code QUESTION_* incl. search 422 — edu-api/services/core/docs/ERROR_CODES.md:457-468",
      "noMcqOptions": "No options array on the wire — do NOT design an MCQ options-editor UI (cross-repo ask #24, out of scope)"
    },

    // ── SCREEN B1: Question Bank List (/teacher/question-bank) ──────────────
    "listScreen": {
      "layout": "single-column, maxWidth 1280, margin 0 auto, padding 24px 32px (mobile 20px 16px), background var(--edu-bg)",
      "note": "Row-card list layout — mirrors exam-bank.jsx list (NOT lesson-bank's grid)",
      "pageHeader": {
        "breadcrumb": "US-E18.16 · Ngân hàng câu hỏi",
        "title": {
          "i18nKey": "questionBank.title",
          "note": "static title, same for both scopes"
        },
        "subtitle": {
          "i18nKey": "questionBank.subtitle",
          "note": "static subtitle, same for both scopes"
        },
        "scopeToggle": {
          "note": "Của tôi (own DRAFT+PUBLISHED, GET /questions — no mandatory filter) vs Tìm kiếm (cross-teacher PUBLISHED, GET /questions/search — mandatory subjectId OR tag, 422 gate)",
          "options": [
            "mine (questionBank.scopeToggle.mine)",
            "search (questionBank.scopeToggle.search)"
          ],
          "i18nKey": "questionBank.scopeToggle.{mine,search,ariaLabel}",
          "a11y": "role='group' + aria-label (questionBank.scopeToggle.ariaLabel); active button aria-pressed=true"
        },
        "createCTA": { "i18nKey": "questionBank.createButton", "icon": "plus" }
      },
      "filterBar": {
        "search": {
          "i18nKey": "questionBank.filter.searchPlaceholder",
          "note": "In scope=search, this input (as free-text tag) OR the subject dropdown satisfies the mandatory-filter gate; entering either flips the 422-prevention indicator to satisfied"
        },
        "subjectDropdown": {
          "icon": "bookOpen",
          "i18nKey": "questionBank.filter.allSubjects",
          "note": "one of the two mandatory-filter satisfiers in scope=search"
        },
        "gradeDropdown": {
          "icon": "graduationCap",
          "i18nKey": "questionBank.filter.allGrades"
        },
        "typeDropdown": {
          "icon": "layers",
          "options": [
            "all",
            "ESSAY (Tự luận)",
            "SHORT_ANSWER (Trả lời ngắn)",
            "FILL_IN (Điền khuyết)"
          ]
        },
        "difficultyDropdown": {
          "icon": "flag",
          "options": ["all", "EASY (Dễ)", "MEDIUM (Trung bình)", "HARD (Khó)"]
        },
        "statusDropdown": {
          "visibleFor": "scope=mine only",
          "options": ["all", "DRAFT", "PUBLISHED"]
        },
        "mandatoryFilterIndicator": {
          "visibleFor": "scope=search only",
          "satisfied": {
            "icon": "check",
            "color": "var(--edu-success)",
            "i18nKey": "questionBank.filter.mandatorySatisfied"
          },
          "unsatisfied": {
            "icon": "alertTriangle",
            "color": "var(--edu-warning-foreground) / var(--edu-warning-text)",
            "i18nKey": "questionBank.filter.mandatoryRequired"
          }
        }
      },
      "requiredFilterPrompt": {
        "note": "DISTINCT from generic empty-state — shown when scope=search AND neither subjectId nor tag set (client-side gate mirrors BE 422 QUESTION_SEARCH_FILTER_REQUIRED; no request fires until satisfied)",
        "component": "QBFilterRequiredPrompt",
        "icon": "search",
        "iconSize": 32,
        "title": {
          "i18nKey": "questionBank.requiredFilterPrompt.title",
          "text": "Chọn môn học hoặc thẻ để tìm"
        },
        "desc": { "i18nKey": "questionBank.requiredFilterPrompt.body" },
        "style": "dashed border card, 64px 24px padding — visually distinct from EduEmpty (solid border)"
      },
      "rowCard": {
        "note": "Row layout — mirrors EBExamCard structure in exam-bank.jsx",
        "iconBlock": "52x52, borderRadius 12, gradient by questionType color",
        "bodyPreview": "truncated body (140 chars), fontSize 14/700",
        "metaLine": "subject (colored) · grade · QBTypeBadge · QBDifficultyBadge (+ author when scope=search)",
        "difficultyBadgeMapping": "EASY→success, MEDIUM→warning, HARD→error — reuses EXISTING GPA-tier convention (design-system.md §Score/performance màu), NOT a new token",
        "typeBadgeMapping": "ESSAY(purple)/SHORT_ANSWER(primary)/FILL_IN(teal) — distinct hues from existing palette, no new token",
        "tags": "pill chips",
        "statusBadge": "QBStatusChip — DRAFT=warning/PUBLISHED=success (2-value, exam-bank convention)",
        "actionButton": "Xem/Sửa (scope=mine) or Xem chi tiết (scope=search), icon penLine/eye"
      },
      "states": {
        "requiredFilterGate": "QBFilterRequiredPrompt (scope=search, no filter set)",
        "loading": "EduSkeleton variant='rows' count=4",
        "error": "EduError + onRetry",
        "emptyAll": {
          "icon": "clipboardList",
          "action": "Tạo câu hỏi mới (scope=mine only)"
        },
        "emptyFiltered": { "icon": "search", "action": "Bỏ lọc" }
      }
    },

    // ── SCREEN B2: Question Bank Builder (/teacher/question-bank/create, /:id/edit) ─
    "builderScreen": {
      "layout": "single-column form, maxWidth 760, stacked cards — questionType selector → subject/grade/difficulty grid → body → expectedAnswer → tags",
      "topBar": "same pattern as lessonPlan.builderScreen.topBar (back, breadcrumb+title truncated body, QBStatusChip, saveDraft/publish OR locked banner)",
      "questionTypeSelector": {
        "note": "3-option segmented control (NOT 2-option like exam-bank MCQ/Essay) — ESSAY / SHORT_ANSWER / FILL_IN, icon+label, active tinted by type color",
        "icons": {
          "ESSAY": "scrollText",
          "SHORT_ANSWER": "edit",
          "FILL_IN": "list"
        }
      },
      "metaGrid": {
        "columns": "1.4fr 1fr 1fr (subject / grade / difficulty), mobile: stacks to 1 col",
        "fields": [
          "subjectId (select)",
          "gradeLevel (select)",
          "difficulty (select, EASY/MEDIUM/HARD)"
        ]
      },
      "bodyField": {
        "i18nKey": "questionBank.builder.bodyLabel (+ bodyPlaceholderEssay/bodyPlaceholderShortAnswer/bodyPlaceholderFillIn by questionType)",
        "required": true,
        "validation": "min 4 chars",
        "rows": "6 for ESSAY, 3 for FILL_IN, 4 for SHORT_ANSWER (longer for essay per DR)",
        "fillInHint": "placeholder text (questionBank.builder.bodyPlaceholderFillIn) shown only when questionType=FILL_IN"
      },
      "expectedAnswerField": {
        "i18nKey": "questionBank.builder.expectedAnswerLabel (+ expectedAnswerPlaceholderEssay/expectedAnswerPlaceholderShortAnswer/expectedAnswerPlaceholderFillIn by questionType)",
        "required": false,
        "note": "optional for ALL questionTypes (ESSAY/SHORT_ANSWER/FILL_IN) — corrected 2026-07-17 (US-E11.9 BA pass, OQ-1) after ground-truthing edu-api Go source (`CreateQuestionRequest`/`UpdateQuestionRequest.ExpectedAnswer *string` with only `omitempty,max=5000`, no per-type required validation). Was incorrectly marked required:true; placeholder copy per type still encourages filling it in, it just isn't enforced.",
        "rows": "4 for ESSAY, 2 for SHORT_ANSWER/FILL_IN"
      },
      "tagsField": {
        "i18nKey": "questionBank.builder.{tagsLabel,tagsPlaceholder,tagsHelper}",
        "component": "tag-chips-input (shared shape with lessonPlan)"
      },
      "publish": {
        "disabledUntil": "body (>=4 chars) — expectedAnswer is NOT a publish gate (corrected 2026-07-17, see expectedAnswerField.note)",
        "confirmDialog": "one-way DRAFT→PUBLISHED, irreversible",
        "lockedBanner": "same as lessonPlan — all fields disabled/read-only once PUBLISHED"
      }
    },

    "a11y": {
      "contrast": "difficulty badges reuse the AA-proven GPA-tier success/warning/error pairing; warning badge uses var(--edu-warning-foreground) text tone, never white-on-yellow",
      "statusNotColorOnly": "type/difficulty/status badges always pair icon + text label",
      "focus": "segmented questionType selector and all form fields keyboard-operable, visible focus ring",
      "requiredFilterA11y": "mandatory-filter indicator uses icon+text (check/alertTriangle), not color alone",
      "motion": "toast/dialog fade-in gated behind prefers-reduced-motion: reduce"
    }
  }
}
